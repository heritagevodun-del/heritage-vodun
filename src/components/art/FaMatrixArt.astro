---
/*
  FaMatrixArt.astro - CSS Art
  Représente la trinité des signes de l&apos;année et l&apos;éveil perpétuel (Awontiin).
*/
---

<div class="fa-matrix-canvas animate-enter">
  <div class="esoteric-stage">
    {/* La géométrie des 3 signes de l'année */}
    <div class="sacred-triangle"></div>

    {/* Les 3 piliers (Akwè, Adji, Dou-Gan) */}
    <div class="pillar p-akwe">
      <div class="energy-orb"></div>
    </div>
    <div class="pillar p-adji">
      <div class="energy-orb"></div>
    </div>
    <div class="pillar p-dougan">
      <div class="energy-orb main-orb"></div>
    </div>

    {/* Le Centre : Awontiin (L'Éveil perpétuel qui ne dort jamais) */}
    <div class="awake-center">
      <div class="awake-core"></div>
      <div class="awake-pulse"></div>
    </div>

    {/* Poussière d'étoiles / Connexion spirituelle */}
    <div class="star-dust st1"></div>
    <div class="star-dust st2"></div>
    <div class="star-dust st3"></div>
  </div>
</div>

<style>
  :root {
    --matrix-bg: #0a0a0c;
    --matrix-gold: #d4af37;
    --matrix-crimson: #8e0000;
    --matrix-light: #fdfbf7;
  }

  .fa-matrix-canvas {
    width: 100%;
    height: 320px;
    background: radial-gradient(
      circle at center,
      #241410 0%,
      var(--matrix-bg) 100%
    );
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    margin-bottom: 3rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
  }

  .esoteric-stage {
    position: relative;
    width: 250px;
    height: 250px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* --- LE TRIANGLE SACRÉ --- */
  .sacred-triangle {
    position: absolute;
    width: 0;
    height: 0;
    border-left: 90px solid transparent;
    border-right: 90px solid transparent;
    border-bottom: 156px solid transparent;
    border-bottom-color: rgba(212, 175, 55, 0.1);
    transform: translateY(-20px);
    animation: rotate-slow 20s linear infinite;
  }
  .sacred-triangle::before {
    content: "";
    position: absolute;
    top: 5px;
    left: -85px;
    border-left: 85px solid transparent;
    border-right: 85px solid transparent;
    border-bottom: 147px solid transparent;
    border-bottom-color: var(--matrix-bg);
  }

  /* --- LES PILIERS (LES 3 SIGNES) --- */
  .pillar {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 2px solid var(--matrix-gold);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(10, 10, 12, 0.8);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
  }
  .p-akwe {
    top: 20px;
    left: 105px;
    animation: float-pillar 4s ease-in-out infinite;
  }
  .p-adji {
    bottom: 40px;
    left: 20px;
    animation: float-pillar 4s ease-in-out infinite 1s;
  }
  .p-dougan {
    bottom: 40px;
    right: 20px;
    border-color: var(--matrix-crimson);
    box-shadow: 0 0 20px rgba(142, 0, 0, 0.5);
    animation: float-pillar 4s ease-in-out infinite 2s;
  }

  .energy-orb {
    width: 10px;
    height: 10px;
    background: var(--matrix-gold);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--matrix-gold);
  }
  .main-orb {
    background: var(--matrix-crimson);
    box-shadow: 0 0 15px var(--matrix-crimson);
  }

  /* --- LE CENTRE ÉVEILLÉ (Awontiin) --- */
  .awake-center {
    position: absolute;
    width: 60px;
    height: 60px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 5;
  }
  .awake-core {
    width: 20px;
    height: 20px;
    background: var(--matrix-light);
    border-radius: 50%;
    box-shadow:
      0 0 20px var(--matrix-light),
      inset 0 0 5px var(--matrix-crimson);
    z-index: 2;
  }
  .awake-pulse {
    position: absolute;
    width: 60px;
    height: 60px;
    border: 2px solid var(--matrix-light);
    border-radius: 50%;
    animation: radar-pulse 2s ease-out infinite;
  }

  /* --- ANIMATIONS --- */
  @keyframes rotate-slow {
    0% {
      transform: translateY(-20px) rotate(0deg);
    }
    100% {
      transform: translateY(-20px) rotate(360deg);
    }
  }

  @keyframes float-pillar {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes radar-pulse {
    0% {
      transform: scale(0.5);
      opacity: 1;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-enter {
    animation: fadeInUp 1s ease forwards;
  }
</style>
