---
/*
  FaMatrixArt.astro - CSS Art
  Représente la trinité des signes de l&apos;année et l&apos;éveil perpétuel (Awontiin).
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#241410_0%,#0a0a0c_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.7)] opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-center">
    {/* La géométrie des 3 signes de l'année (Triangle Sacré) */}
    <div
      class="absolute w-0 h-0 border-l-[90px] border-r-[90px] border-b-[156px] border-l-transparent border-r-transparent border-b-[#d4af37]/10 -translate-y-5 animate-rotate-slow"
    >
      {/* Intérieur du triangle pour créer la bordure */}
      <div
        class="absolute top-[5px] -left-[85px] w-0 h-0 border-l-[85px] border-r-[85px] border-b-[147px] border-l-transparent border-r-transparent border-b-[#0a0a0c]"
      >
      </div>
    </div>

    {/* Les 3 piliers (Akwè, Adji, Dou-Gan) */}
    <div
      class="absolute top-[20px] left-[105px] w-10 h-10 border-2 border-[#d4af37] rounded-full flex justify-center items-center bg-[#0a0a0c]/80 shadow-[0_0_15px_rgba(212,175,55,0.3)] animate-float-pillar"
    >
      <div
        class="w-2.5 h-2.5 bg-[#d4af37] rounded-full shadow-[0_0_10px_#d4af37]"
      >
      </div>
    </div>

    <div
      class="absolute bottom-[40px] left-[20px] w-10 h-10 border-2 border-[#d4af37] rounded-full flex justify-center items-center bg-[#0a0a0c]/80 shadow-[0_0_15px_rgba(212,175,55,0.3)] animate-float-pillar [animation-delay:1s]"
    >
      <div
        class="w-2.5 h-2.5 bg-[#d4af37] rounded-full shadow-[0_0_10px_#d4af37]"
      >
      </div>
    </div>

    <div
      class="absolute bottom-[40px] right-[20px] w-10 h-10 border-2 border-[#8e0000] rounded-full flex justify-center items-center bg-[#0a0a0c]/80 shadow-[0_0_20px_rgba(142,0,0,0.5)] animate-float-pillar [animation-delay:2s]"
    >
      <div
        class="w-2.5 h-2.5 bg-[#8e0000] rounded-full shadow-[0_0_15px_#8e0000]"
      >
      </div>
    </div>

    {/* Le Centre : Awontiin (L'Éveil perpétuel qui ne dort jamais) */}
    <div
      class="absolute w-[60px] h-[60px] flex justify-center items-center z-10"
    >
      <div
        class="w-5 h-5 bg-[#fdfbf7] rounded-full shadow-[0_0_20px_#fdfbf7,inset_0_0_5px_#8e0000] z-20"
      >
      </div>
      <div
        class="absolute w-[60px] h-[60px] border-2 border-[#fdfbf7] rounded-full animate-radar-pulse"
      >
      </div>
    </div>

    {/* Poussière d'étoiles / Connexion spirituelle */}
    <div
      class="absolute top-[30px] left-[40px] w-1 h-1 bg-white/40 rounded-full animate-pulse shadow-[0_0_5px_white]"
    >
    </div>
    <div
      class="absolute bottom-[60px] right-[40px] w-1.5 h-1.5 bg-[#d4af37]/60 rounded-full animate-pulse [animation-delay:1s] shadow-[0_0_5px_#d4af37]"
    >
    </div>
    <div
      class="absolute top-[100px] right-[30px] w-1 h-1 bg-white/40 rounded-full animate-pulse [animation-delay:2s] shadow-[0_0_5px_white]"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes rotate-slow {
    0% {
      transform: translateY(-20px) rotate(0deg);
    }
    100% {
      transform: translateY(-20px) rotate(360deg);
    }
  }
  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
  }

  @keyframes float-pillar {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .animate-float-pillar {
    animation: float-pillar 4s ease-in-out infinite;
  }

  @keyframes radar-pulse {
    0% {
      transform: scale(0.5);
      opacity: 1;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }
  .animate-radar-pulse {
    animation: radar-pulse 2s ease-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
