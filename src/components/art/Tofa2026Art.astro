---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fcf9f2] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[28rem] h-80 md:h-[28rem] bg-white rounded-full blur-[50px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none px-4"
  >
  </div>

  <div
    class="relative z-20 flex items-center justify-center w-64 h-64 md:w-80 md:h-80 rounded-full bg-gradient-to-br from-[#8a4224] via-[#5c2813] to-[#3a1005] shadow-[0_25px_50px_rgba(69,26,3,0.3)] border-8 border-[#3a1005] transition-transform duration-1000 hover:-translate-y-2 animate-float"
  >
    <div
      class="absolute inset-0 rounded-full bg-[repeating-linear-gradient(45deg,transparent,transparent_4px,rgba(0,0,0,0.1)_5px,rgba(0,0,0,0.1)_8px)] opacity-50 mix-blend-multiply"
    >
    </div>
    <div
      class="absolute inset-0 rounded-full border border-[#b85a30] opacity-50"
    >
    </div>

    <div
      class="relative w-48 h-48 md:w-64 md:h-64 rounded-full bg-[#fdfbf7] shadow-[inset_0_8px_20px_rgba(0,0,0,0.15)] flex items-center justify-center overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%221.5%22 numOctaves=%222%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.03%22/%3E%3C/svg%3E')] mix-blend-multiply pointer-events-none"
      >
      </div>

      <div class="flex flex-col items-center gap-6 md:gap-8 z-10">
        <div class="flex gap-8 md:gap-12">
          <div class="flex flex-col gap-4 md:gap-6 items-center">
            <div class="flex gap-3">
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
            </div>
            <div
              class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
            >
            </div>
            <div
              class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
            >
            </div>
            <div
              class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
            >
            </div>
          </div>

          <div class="flex flex-col gap-4 md:gap-6 items-center">
            <div class="flex gap-3">
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
            </div>
            <div
              class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
            >
            </div>
            <div class="flex gap-3">
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
            </div>
            <div class="flex gap-3">
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
              <div
                class="w-3 h-3 md:w-4 md:h-4 bg-[#3a1005] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.8)]"
              >
              </div>
            </div>
          </div>
        </div>

        <span
          class="font-serif text-lg md:text-xl text-center text-[#3a1005] uppercase tracking-[0.25em] opacity-90 drop-shadow-[0_1px_1px_rgba(255,255,255,0.8)]"
        >
          TOFA 2026
        </span>
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[30%] w-2 h-2 bg-white blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[25%] right-[25%] w-3 h-3 bg-amber-100 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] left-[20%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 6s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-10px) rotate(1deg);
    }
  }
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-150px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 6s infinite ease-out;
  }
</style>
