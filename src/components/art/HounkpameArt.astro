---
/*
  HounkpameArt.astro - CSS Art
  Representation de la porte du couvent (Zogbe) et de la lueur de la metamorphose spirituelle.
  Optimise Tailwind v4 - Theme Crepuscule (Soft Dark)
*/
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#1a2225] rounded-3xl overflow-hidden border border-green-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex justify-center items-end opacity-0 animate-fade-up select-none group"
>
  {/* Brume mystique et Foret Sacree en arriere-plan */}
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(22,101,52,0.15)_0%,transparent_70%)] z-0"
  >
  </div>

  <div
    class="absolute bottom-0 left-[5%] md:left-[15%] w-16 md:w-24 h-[70%] bg-gradient-to-t from-[#0a140a] to-[#143314] rounded-t-full blur-xl z-0 opacity-80"
  >
  </div>
  <div
    class="absolute bottom-0 right-[5%] md:right-[15%] w-20 md:w-32 h-[80%] bg-gradient-to-t from-[#0a140a] to-[#0f290f] rounded-t-full blur-xl z-0 opacity-70"
  >
  </div>
  <div
    class="absolute bottom-0 left-[25%] w-12 h-[60%] bg-[#1a331a] rounded-t-full blur-lg z-0 opacity-60"
  >
  </div>

  {/* Le Mur en Terre du Couvent */}
  <div
    class="relative w-[85%] md:w-[60%] h-[60%] md:h-[65%] bg-gradient-to-b from-[#6b4226] via-[#5c3a21] to-[#29170b] rounded-t-2xl z-10 flex justify-center items-end shadow-[0_-15px_40px_rgba(0,0,0,0.6)] border-t border-amber-800/50"
  >
    {/* Texture de la terre rouge */}
    <div
      class="absolute inset-0 bg-[radial-gradient(rgba(0,0,0,0.2)_1px,transparent_1px)] bg-[size:12px_12px] opacity-40 rounded-t-2xl pointer-events-none mix-blend-overlay"
    >
    </div>
    <div
      class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_5px,rgba(0,0,0,0.1)_6px,rgba(0,0,0,0.1)_10px)] rounded-t-2xl pointer-events-none"
    >
    </div>

    {/* Symboles de scarification sur le fronton */}
    <div class="absolute top-6 md:top-8 flex gap-3 md:gap-5 opacity-80">
      <div
        class="w-1.5 h-6 md:h-8 bg-[#2d1a0f] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),1px_1px_0_rgba(255,255,255,0.1)]"
      >
      </div>
      <div
        class="w-1.5 h-6 md:h-8 bg-[#2d1a0f] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),1px_1px_0_rgba(255,255,255,0.1)]"
      >
      </div>
      <div
        class="w-1.5 h-6 md:h-8 bg-[#2d1a0f] rounded-full shadow-[inset_1px_1px_2px_rgba(0,0,0,0.8),1px_1px_0_rgba(255,255,255,0.1)]"
      >
      </div>
    </div>

    {/* La Porte Initiatique */}
    <div
      class="relative w-32 md:w-44 h-48 md:h-64 bg-[#050a05] rounded-t-full border-[6px] md:border-[8px] border-[#2d1a0f] shadow-[inset_0_20px_50px_rgba(0,0,0,1)] flex flex-col items-center overflow-hidden z-20"
    >
      {/* Mariwo (Franges de palmes suspendues a l'entree) */}
      <div class="absolute top-0 w-full flex justify-between px-1 z-30">
        <div
          class="w-1 h-6 md:h-10 bg-gradient-to-b from-green-800 to-amber-700/50"
        >
        </div>
        <div
          class="w-1 h-8 md:h-12 bg-gradient-to-b from-green-700 to-amber-600/50"
        >
        </div>
        <div
          class="w-1 h-5 md:h-8 bg-gradient-to-b from-green-800 to-amber-700/50"
        >
        </div>
        <div
          class="w-1 h-9 md:h-14 bg-gradient-to-b from-green-700 to-amber-600/50"
        >
        </div>
        <div
          class="w-1 h-7 md:h-10 bg-gradient-to-b from-green-800 to-amber-700/50"
        >
        </div>
      </div>

      {/* La lueur du Kaolin (Renaissance Spirituelle) */}
      <div
        class="absolute bottom-4 w-20 md:w-28 h-20 md:h-28 bg-[radial-gradient(circle,rgba(253,251,247,0.9)_0%,transparent_70%)] rounded-full blur-[8px] animate-spirit-breathe z-20 mix-blend-screen"
      >
      </div>

      {/* Halo secondaire pour la profondeur */}
      <div
        class="absolute bottom-0 w-full h-1/2 bg-gradient-to-t from-white/10 to-transparent opacity-50 animate-pulse-glow"
      >
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-6 inset-x-0 flex flex-col items-center justify-center z-50 pointer-events-none"
  >
    <h2
      class="text-2xl md:text-4xl font-bold text-amber-300 tracking-wide mb-1 opacity-90"
    >
      Hounkpame
    </h2>
    <p
      class="text-sm md:text-base text-amber-200/80 italic tracking-wide opacity-80"
    >
      La Porte du Couvent et la Lueur de la Renaissance Spirituelle
    </p>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes spiritBreathe {
    0%,
    100% {
      transform: scale(0.9) translateY(10px);
      opacity: 0.6;
      filter: drop-shadow(0 0 5px rgba(253, 251, 247, 0.2));
    }
    50% {
      transform: scale(1.2) translateY(-15px);
      opacity: 1;
      filter: drop-shadow(0 0 20px rgba(253, 251, 247, 0.8));
    }
  }
  .animate-spirit-breathe {
    animation: spiritBreathe 5s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.6;
    }
  }
  .animate-pulse-glow {
    animation: pulseGlow 4s ease-in-out infinite alternate;
  }
</style>
