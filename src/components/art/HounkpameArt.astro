---
/*
  HounkpameArt.astro - CSS Art
  Représente la porte du couvent (Zogbé) et la lueur de la métamorphose spirituelle.
  Optimisé Tailwind v4 - Thème Sombre & Mystique
*/
---

<div
  class="w-full h-80 bg-gradient-to-b from-dark-bg to-[#0a140a] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-gold/5 opacity-0 animate-fade-up"
>
  <div class="relative w-full h-full flex justify-center items-end">
    {/* Arbres sacrés en arrière-plan */}
    <div
      class="absolute bottom-0 left-[10%] w-10 h-[280px] bg-[#1a2e1a] rounded-t-full blur-md z-0"
    >
    </div>
    <div
      class="absolute bottom-0 right-[15%] w-10 h-[260px] bg-[#1a2e1a] rounded-t-full blur-md z-0"
    >
    </div>

    {/* Le Mur d'Argile du Couvent */}
    <div
      class="relative w-[260px] h-[200px] bg-gradient-to-br from-[#8b5a2b] to-[#5c3a21] rounded-t-lg z-10 flex justify-center items-end shadow-[0_-10px_30px_rgba(0,0,0,0.5)]"
    >
      {/* Texture de l'argile (Grille superposée) */}
      <div
        class="absolute inset-0 bg-[radial-gradient(rgba(0,0,0,0.15)_1px,transparent_1px)] bg-[size:10px_10px] opacity-50 rounded-t-lg pointer-events-none"
      >
      </div>

      {/* Symboles de scarification sur le fronton de terre */}
      <div
        class="absolute top-5 text-[#3a2212] font-bold text-xl tracking-[8px] flex justify-center opacity-90 select-none drop-shadow-[0_1px_1px_rgba(255,255,255,0.1)]"
      >
        |||
      </div>

      {/* La Porte Initiatique */}
      <div
        class="relative w-[100px] h-[150px] bg-[#0a140a] rounded-t-[50px] border-[4px] border-[#3a2212] shadow-[inset_0_20px_50px_rgba(0,0,0,0.9)] flex flex-col items-center overflow-hidden z-20"
      >
        {/* La lueur du Kaolin (Renaissance) */}
        <div
          class="absolute -bottom-5 w-[80px] h-[80px] bg-[radial-gradient(circle,rgba(253,251,247,0.8)_0%,transparent_70%)] rounded-full blur-[5px] animate-spirit-breathe"
        >
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes spirit-breathe {
    0%,
    100% {
      transform: scale(1) translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.3) translateY(-10px);
      opacity: 1;
      filter: drop-shadow(0 0 10px rgba(253, 251, 247, 0.4));
    }
  }
  .animate-spirit-breathe {
    animation: spirit-breathe 5s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
