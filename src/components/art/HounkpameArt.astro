---
/*
  HounkpameArt.astro - CSS Art
  Représente la porte du couvent (Zogbé) et la lueur de la métamorphose spirituelle.
*/
---

<div class="hounkpame-art-canvas animate-enter">
  <div class="sacred-forest-bg">
    {/* Arbres sacrés en arrière-plan */}
    <div class="tree t1"></div>
    <div class="tree t2"></div>

    {/* Le Mur d&apos;Argile du Couvent */}
    <div class="clay-wall">
      {/* La Porte Initiatique */}
      <div class="sacred-doorway">
        {/* La lueur du Kaolin (Renaissance) */}
        <div class="kaolin-glow"></div>

        {/* Symboles de scarification sur le fronton */}
        <div class="scarification-marks">
          <span>|</span><span>|</span><span>|</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --clay-dark: #5c3a21;
    --clay-light: #8b5a2b;
    --forest-dark: #0a140a;
    --forest-green: #1a2e1a;
    --kaolin-white: #fdfbf7;
  }

  .hounkpame-art-canvas {
    width: 100%;
    height: 320px;
    background: linear-gradient(to bottom, #111 0%, var(--forest-dark) 100%);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    margin-bottom: 3rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
  }

  .sacred-forest-bg {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  /* --- LA FORÊT SACRÉE --- */
  .tree {
    position: absolute;
    bottom: 0;
    width: 40px;
    height: 250px;
    background: var(--forest-green);
    border-radius: 20px 20px 0 0;
    filter: blur(4px);
    z-index: 1;
  }
  .t1 {
    left: 10%;
    height: 280px;
  }
  .t2 {
    right: 15%;
    height: 260px;
  }

  /* --- LE MUR D'ARGILE --- */
  .clay-wall {
    position: relative;
    width: 260px;
    height: 200px;
    background: linear-gradient(135deg, var(--clay-light), var(--clay-dark));
    border-radius: 8px 8px 0 0;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.5);
  }

  /* Texture de l'argile */
  .clay-wall::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(rgba(0, 0, 0, 0.1) 1px, transparent 1px);
    background-size: 10px 10px;
    opacity: 0.5;
  }

  /* --- LA PORTE INITIATIQUE --- */
  .sacred-doorway {
    position: relative;
    width: 100px;
    height: 150px;
    background: var(--forest-dark);
    border-radius: 50px 50px 0 0;
    border: 4px solid #3a2212;
    box-shadow: inset 0 20px 50px rgba(0, 0, 0, 0.9);
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
  }

  /* --- LA LUEUR DU KAOLIN --- */
  .kaolin-glow {
    position: absolute;
    bottom: -20px;
    width: 80px;
    height: 80px;
    background: radial-gradient(
      circle,
      rgba(253, 251, 247, 0.8) 0%,
      transparent 70%
    );
    border-radius: 50%;
    animation: spirit-breathe 5s ease-in-out infinite;
    filter: blur(5px);
  }

  /* --- MARQUES DE SCARIFICATION --- */
  .scarification-marks {
    position: absolute;
    top: -25px;
    color: var(--clay-dark);
    font-weight: bold;
    font-size: 18px;
    letter-spacing: 5px;
    display: flex;
    justify-content: center;
    opacity: 0.8;
  }

  /* --- ANIMATIONS --- */
  @keyframes spirit-breathe {
    0%,
    100% {
      transform: scale(1) translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.3) translateY(-10px);
      opacity: 1;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-enter {
    animation: fadeInUp 1s ease forwards;
  }
</style>
