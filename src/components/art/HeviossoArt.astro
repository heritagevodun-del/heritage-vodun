---
// src/components/art/HeviossoArt.astro
---

<div
  class="heviosso-container relative w-full h-[400px] bg-dark-surface rounded-xl overflow-hidden border border-white/5 flex items-center justify-center select-none shadow-inner group"
>
  {/* --- EFFETS DE NUAGES INTERNES --- */}
  <div
    class="absolute inset-0 bg-radial-gradient from-transparent via-dark-bg/80 to-dark-surface z-10"
  >
  </div>
  <div
    class="absolute inset-0 opacity-20 mix-blend-color-dodge bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[var(--color-laterite)] via-transparent to-transparent pointer-events-none"
  >
  </div>

  {/* --- GRILLE ÉLECTRIQUE / FLASHES D'ORAGE ANIMÉS --- */}
  <div
    class="lightning-flash flash-1 absolute inset-0 bg-white/5 opacity-0 pointer-events-none z-20"
  >
  </div>
  <div
    class="lightning-flash flash-2 absolute inset-0 bg-gradient-to-b from-gold/10 to-transparent opacity-0 pointer-events-none z-20"
  >
  </div>

  {/* --- LE SOCLE SACRÉ / ÉMANATION DE PUISSANCE --- */}
  <div
    class="absolute bottom-0 w-full h-24 bg-gradient-to-t from-dark-bg to-transparent z-10"
  >
  </div>

  {/* --- SYMBOLE CENTRAL : LA DOUBLE HACHE DE HÊVIOSSO (SÔ-KPI) --- */}
  <div
    class="relative z-30 flex flex-col items-center justify-center transform group-hover:scale-105 transition-transform duration-700"
  >
    {/* Éclairs directionnels jaillissant du symbole */}
    <div
      class="bolt-line left-bolt absolute -left-20 top-0 w-24 h-[2px] bg-gradient-to-r from-transparent to-gold rotate-[35deg] opacity-70"
    >
    </div>
    <div
      class="bolt-line right-bolt absolute -right-20 top-0 w-24 h-[2px] bg-gradient-to-l from-transparent to-gold -rotate-[35deg] opacity-70"
    >
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 200 240"
      class="w-40 h-48 drop-shadow-[0_0_25px_rgba(212,175,55,0.4)] axe-svg"
    >
      {/* Halo d'énergie résiduelle */}
      <circle
        cx="100"
        cy="80"
        r="45"
        fill="none"
        stroke="var(--color-laterite)"
        stroke-width="1"
        stroke-dasharray="4 4"
        class="animate-spin-slow"></circle>

      {/* Lame double gauche (Symbole du double tranchant de la justice) */}
      <path
        d="M 100 80 Q 55 50 25 80 Q 55 110 100 80 Z"
        fill="url(#gold-gradient)"
        stroke="var(--color-laterite)"
        stroke-width="2"></path>

      {/* Lame double droite */}
      <path
        d="M 100 80 Q 145 50 175 80 Q 145 110 100 80 Z"
        fill="url(#gold-gradient)"
        stroke="var(--color-laterite)"
        stroke-width="2"></path>

      {/* Le Cœur de la foudre (Gemme de feu au centre de la hache) */}
      <circle
        cx="100"
        cy="80"
        r="12"
        fill="var(--color-laterite)"
        class="animate-pulse"></circle>
      <circle cx="100" cy="80" r="6" fill="var(--color-vodun-kaolin)"></circle>

      {/* Le Manche en bois sacré orné de lanières de cuivre */}
      <path
        d="M 96 80 L 96 220 C 96 225, 104 225, 104 220 L 104 80 Z"
        fill="var(--color-vodun-bg)"
        stroke="var(--color-gold)"
        stroke-width="1.5"></path>

      {/* Gravures rituelles sur le manche */}
      <line
        x1="96"
        y1="120"
        x2="104"
        y2="125"
        stroke="var(--color-laterite)"
        stroke-width="2"></line>
      <line
        x1="96"
        y1="150"
        x2="104"
        y2="155"
        stroke="var(--color-laterite)"
        stroke-width="2"></line>
      <line
        x1="96"
        y1="180"
        x2="104"
        y2="185"
        stroke="var(--color-laterite)"
        stroke-width="2"></line>

      {/* Définition des dégradés de métaux sacrés */}
      <defs>
        <linearGradient id="gold-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#fce79a"></stop>
          <stop offset="50%" stop-color="#d4af37"></stop>
          <stop offset="100%" stop-color="#b08d2b"></stop>
        </linearGradient>
      </defs>
    </svg>

    <span
      class="text-[10px] font-sans font-bold uppercase tracking-[0.3em] text-gold mt-4 bg-dark-bg/50 px-3 py-1 rounded-full border border-white/5 backdrop-blur-sm"
    >
      Sô-kpi Sacré
    </span>
  </div>
</div>

<style>
  /* --- KEYFRAMES CSS ART EXPERT POUR L'ORAGE ASYNCHRONE --- */
  @keyframes lightning-strike-1 {
    0%,
    94%,
    98%,
    100% {
      opacity: 0;
    }
    95%,
    97% {
      opacity: 1;
      filter: blur(2px);
    }
    96% {
      opacity: 0.3;
    }
  }

  @keyframes lightning-strike-2 {
    0%,
    88%,
    92%,
    100% {
      opacity: 0;
    }
    89%,
    91% {
      opacity: 0.8;
    }
    90% {
      opacity: 0.2;
    }
  }

  @keyframes axe-resonance {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-4px) rotate(0.5deg);
    }
  }

  @keyframes bolt-flicker {
    0%,
    94%,
    100% {
      opacity: 0;
      transform: scaleX(0.5);
    }
    95%,
    97% {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  /* Attachement des animations */
  .flash-1 {
    animation: lightning-strike-1 7s infinite ease-in-out;
  }

  .flash-2 {
    animation: lightning-strike-2 5.3s infinite ease-in-out;
  }

  .axe-svg {
    animation: axe-resonance 4s infinite ease-in-out;
  }

  .bolt-line {
    animation: bolt-flicker 7s infinite ease-in-out;
  }

  .left-bolt {
    transform-origin: right center;
  }

  .right-bolt {
    transform-origin: left center;
  }

  .animate-spin-slow {
    animation: spin 20s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
