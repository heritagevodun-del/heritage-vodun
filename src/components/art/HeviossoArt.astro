---
/*
  HeviossoArt.astro - CSS Art
  Allégorie de Hêviosso : Le Cataclysme et l&apos;Émanation du Sô-Kpè.
  Design : Tech-Sombre / Foudre Stroboscopique / Filigrane SVG Tranchant (100% CSS)
*/
---

<div
  class="heviosso-container relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#020000] rounded-3xl overflow-hidden border border-red-950/40 shadow-[0_30px_60px_rgba(220,38,38,0.15)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  {/* 1. LUEURS D'ARRIÈRE-PLAN (Ciel orageux / Flashs) */}
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#1a0505] to-[#020000] z-0"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-br from-red-600/15 via-transparent to-transparent pointer-events-none z-0"
  >
  </div>

  {/* Bruit visuel / Texture d&apos;orage */}
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.06%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* Masses nuageuses mouvantes */}
  <div
    class="absolute top-[20%] left-[10%] w-[80%] h-[80%] bg-red-800/15 rounded-full blur-[70px] animate-cloud-drift z-0"
  >
  </div>
  <div
    class="absolute bottom-[20%] right-[10%] w-[70%] h-[70%] bg-amber-600/10 rounded-full blur-[80px] animate-cloud-drift-reverse z-0"
  >
  </div>

  {/* 2. LE SYMBOLE SACRÉ EN FILIGRANE (Le Sô-Kpè Acéré - z-10) */}
  <div
    class="absolute inset-0 flex items-center justify-center z-10 mix-blend-screen opacity-40 pointer-events-none animate-axe-glow"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 200 240"
      class="w-64 h-80 md:w-80 md:h-96 opacity-90 drop-shadow-[0_0_15px_rgba(220,38,38,0.3)]"
    >
      {/* Halo d&apos;énergie rotatif */}
      <circle
        cx="100"
        cy="80"
        r="65"
        fill="none"
        stroke="#dc2626"
        stroke-width="1.5"
        stroke-dasharray="10 15"
        class="animate-spin-slow-filigrane"></circle>

      {/* Lames Tranchantes de la Hache (Acier/Fer forgé) */}
      {/* Lame Gauche : Pointes acérées et courbe agressive */}
      <path
        d="M 85 50 Q 30 20 10 10 Q 0 80 10 150 Q 30 140 85 110 Z"
        fill="url(#steel-gradient)"
        stroke="#f59e0b"
        stroke-width="1"></path>
      {/* Lame Droite : Pointes acérées et courbe agressive */}
      <path
        d="M 115 50 Q 170 20 190 10 Q 200 80 190 150 Q 170 140 115 110 Z"
        fill="url(#steel-gradient)"
        stroke="#f59e0b"
        stroke-width="1"></path>

      {/* Tête centrale blindée */}
      <path d="M 85 50 L 115 50 L 115 110 L 85 110 Z" fill="#2a1f1a"></path>
      <line x1="85" y1="50" x2="115" y2="50" stroke="#f59e0b" stroke-width="2"
      ></line>
      <line x1="85" y1="110" x2="115" y2="110" stroke="#f59e0b" stroke-width="2"
      ></line>

      {/* Cœur incandescent (Œil fendu de la foudre) */}
      <path
        d="M 100 65 Q 110 80 100 95 Q 90 80 100 65 Z"
        fill="#dc2626"
        class="animate-pulse"></path>
      <path d="M 100 70 Q 104 80 100 90 Q 96 80 100 70 Z" fill="#fce79a"></path>

      {/* Manche monumental (Bois sombre) */}
      <path
        d="M 90 110 L 90 230 C 90 240, 110 240, 110 230 L 110 110 Z"
        fill="#1a0d05"
        stroke="#f59e0b"
        stroke-width="1.5"></path>

      {/* Anneaux de puissance en cuir/laiton */}
      <line x1="90" y1="130" x2="110" y2="135" stroke="#d4af37" stroke-width="3"
      ></line>
      <line x1="90" y1="170" x2="110" y2="175" stroke="#d4af37" stroke-width="3"
      ></line>
      <line x1="90" y1="210" x2="110" y2="215" stroke="#d4af37" stroke-width="3"
      ></line>

      <defs>
        {/* Gradient d&apos;acier tranchant pour les lames */}
        <linearGradient id="steel-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#d1d5db"></stop>
          <stop offset="50%" stop-color="#6b7280"></stop>
          <stop offset="100%" stop-color="#1f2937"></stop>
        </linearGradient>
      </defs>
    </svg>
  </div>

  {/* Flash global du ciel */}
  <div
    class="absolute inset-0 bg-white z-15 mix-blend-overlay opacity-0 pointer-events-none animate-thunder-flash"
  >
  </div>

  {/* 3. TYPOGRAPHIE MONUMENTALE RÉDUITE (z-20) */}
  <div
    class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#fce79a] via-[#d4af37]/90 to-[#b08d2b]/40 uppercase tracking-[0.25em] drop-shadow-[0_4px_15px_rgba(0,0,0,0.9)] w-full text-center transition-transform duration-1000 group-hover:scale-105"
    >
      HÊVIOSSO
    </h1>
  </div>

  {/* 4. LE CATACLYSME (Foudre géométrique déchirant l&apos;écran - z-30) */}
  <div
    class="absolute inset-0 z-30 pointer-events-none flex items-center justify-center"
  >
    {/* La déchirure principale */}
    <div
      class="w-24 md:w-40 h-[120%] bg-white opacity-0 animate-thunder-strike shadow-[0_0_50px_#fff,0_0_100px_#d97706,0_0_150px_#dc2626]"
      style="clip-path: polygon(60% 0%, 75% 0%, 45% 45%, 65% 40%, 25% 100%, 40% 55%, 25% 55%, 55% 15%, 45% 15%);"
    >
    </div>

    {/* Ramifications secondaires */}
    <div
      class="absolute top-[10%] left-[20%] w-16 h-[50%] bg-white opacity-0 animate-thunder-branch shadow-[0_0_30px_#fff,0_0_60px_#f59e0b] origin-top rotate-[15deg]"
      style="clip-path: polygon(60% 0%, 80% 0%, 40% 45%, 60% 40%, 15% 100%, 35% 55%, 15% 55%, 55% 15%, 40% 15%);"
    >
    </div>
    <div
      class="absolute top-[35%] right-[20%] w-12 h-[45%] bg-white opacity-0 animate-thunder-branch-delayed shadow-[0_0_30px_#fff,0_0_50px_#dc2626] origin-top -rotate-[20deg]"
      style="clip-path: polygon(40% 0%, 60% 0%, 20% 50%, 40% 45%, 5% 100%, 25% 60%, 5% 60%, 45% 20%, 25% 20%);"
    >
    </div>
  </div>

  {/* 5. POINT D'IMPACT (Explosion au sol) */}
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-72 md:w-[32rem] h-16 bg-white/20 blur-[25px] rounded-[100%] opacity-0 animate-thunder-strike z-10 shadow-[0_0_60px_30px_#f59e0b]"
  >
  </div>
</div>

<style>
  /* --- Apparition Générale --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* --- Nuages --- */
  @keyframes cloudDrift {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(5%, 5%) scale(1.05);
    }
  }
  .animate-cloud-drift {
    animation: cloudDrift 10s infinite alternate ease-in-out;
  }

  @keyframes cloudDriftReverse {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-5%, -5%) scale(1.05);
    }
  }
  .animate-cloud-drift-reverse {
    animation: cloudDriftReverse 12s infinite alternate ease-in-out;
  }

  /* --- Incandescence du Sô-Kpè --- */
  @keyframes axeGlow {
    0%,
    100% {
      opacity: 0.3;
      filter: brightness(1);
    }
    50% {
      opacity: 0.6;
      filter: brightness(1.3) drop-shadow(0 0 15px #dc2626);
    }
  }
  .animate-axe-glow {
    animation: axeGlow 4s infinite alternate ease-in-out;
  }

  @keyframes spin-slow-filigrane {
    0% {
      transform: rotate(0deg) scale(0.95);
    }
    50% {
      transform: rotate(180deg) scale(1.05);
      stroke-dashoffset: 40px;
    }
    100% {
      transform: rotate(360deg) scale(0.95);
    }
  }
  .animate-spin-slow-filigrane {
    animation: spin-slow-filigrane 20s linear infinite;
    transform-origin: center;
  }

  /* --- Moteur de Foudre Asynchrone --- */
  @keyframes thunderFlash {
    0%,
    91%,
    95%,
    100% {
      opacity: 0;
    }
    92% {
      opacity: 0.2;
      filter: blur(2px);
    }
    93% {
      opacity: 0.05;
      filter: blur(1px);
    }
    94% {
      opacity: 0.3;
      filter: blur(4px);
    }
  }
  .animate-thunder-flash {
    animation: thunderFlash 6s infinite ease-in-out;
  }

  @keyframes thunderStrike {
    0%,
    91%,
    95%,
    100% {
      opacity: 0;
      transform: scaleY(0.95);
      filter: brightness(1);
    }
    92% {
      opacity: 1;
      transform: scaleY(1.05);
      filter: brightness(1.5);
    }
    93% {
      opacity: 0.3;
      transform: scaleY(1);
    }
    94% {
      opacity: 0.9;
      transform: scaleY(1.02);
    }
  }
  .animate-thunder-strike {
    animation: thunderStrike 6s infinite ease-out;
  }

  @keyframes thunderBranch {
    0%,
    82%,
    86%,
    100% {
      opacity: 0;
    }
    83% {
      opacity: 0.8;
    }
    84% {
      opacity: 0.1;
    }
    85% {
      opacity: 0.9;
    }
  }
  .animate-thunder-branch {
    animation: thunderBranch 6s infinite;
  }

  @keyframes thunderBranchDelayed {
    0%,
    75%,
    79%,
    100% {
      opacity: 0;
    }
    76% {
      opacity: 0.7;
    }
    77% {
      opacity: 0;
    }
    78% {
      opacity: 0.8;
    }
  }
  .animate-thunder-branch-delayed {
    animation: thunderBranchDelayed 8s infinite;
  }
</style>
