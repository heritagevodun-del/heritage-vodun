---
/*
  MamiWataArt.astro - CSS Art
  Représente le miroir sacré de la Reine des Océans, l&apos;eau et le serpent divin.
  Optimisé Tailwind v4 - Thème Sombre & Abyssal
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_top,#03396c_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-blue-900/30 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-center">
    {/* Ondulations de l'eau (Vagues rotatives) */}
    <div
      class="absolute -bottom-[50px] w-[400px] h-[400px] bg-[#6497b1]/10 rounded-[40%] animate-wave-spin z-0"
    >
    </div>
    <div
      class="absolute -bottom-[50px] w-[400px] h-[400px] bg-[#005b96]/20 rounded-[40%] animate-wave-spin [animation-duration:8s] z-0"
    >
    </div>
    <div
      class="absolute -bottom-[70px] w-[400px] h-[400px] bg-[#03396c]/30 rounded-[40%] animate-wave-spin-reverse [animation-duration:12s] z-0"
    >
    </div>

    {/* Le Miroir Sacré */}
    <div
      class="relative w-[100px] h-[140px] bg-[#d4af37] rounded-[50px_50px_10px_10px] p-[6px] shadow-[0_10px_20px_rgba(0,0,0,0.4)] z-20 animate-float-mirror"
    >
      {/* Verre du miroir */}
      <div
        class="w-full h-full bg-gradient-to-br from-[#b0bec5] via-[#eceff1] to-[#b0bec5] rounded-[44px_44px_6px_6px] relative overflow-hidden shadow-[inset_0_0_15px_rgba(0,0,0,0.2)]"
      >
        {/* Reflet magique */}
        <div
          class="absolute -top-[50px] -left-[50px] w-[50px] h-[200px] bg-white/40 rotate-45 animate-shine"
        >
        </div>
      </div>

      {/* Le Serpent divin qui s'enroule */}
      <div class="absolute top-[20px] -left-[20px] w-[140px] h-[140px] z-30">
        <div
          class="absolute -top-[5px] right-[15px] w-[20px] h-[15px] bg-[#2e7d32] rounded-full rotate-30 z-40"
        >
          {/* Oeil du serpent */}
          <div
            class="absolute top-[4px] right-[4px] w-[4px] h-[4px] bg-[#d4af37] rounded-full"
          >
          </div>
        </div>
        <div class="snake-body b1"></div>
        <div class="snake-body b2"></div>
      </div>
    </div>

    {/* Gouttes d'eau / Éclats de lumière */}
    <div
      class="absolute w-[8px] h-[8px] bg-[#6497b1] rounded-full shadow-[0_0_10px_#6497b1] z-30 animate-rise-drop opacity-0 bottom-[20px] left-[40px] [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute w-[8px] h-[8px] bg-[#6497b1] rounded-full shadow-[0_0_10px_#6497b1] z-30 animate-rise-drop opacity-0 bottom-[40px] right-[50px] [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute w-[8px] h-[8px] bg-[#6497b1] rounded-full shadow-[0_0_10px_#6497b1] z-30 animate-rise-drop opacity-0 bottom-[10px] left-[100px] [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- STYLES COMPLEXES --- */
  .snake-body {
    position: absolute;
    border: 8px solid #2e7d32;
    border-radius: 50%;
    border-top-color: transparent;
    border-left-color: transparent;
  }
  .b1 {
    width: 120px;
    height: 80px;
    top: 30px;
    left: 10px;
    transform: rotate(45deg);
  }
  .b2 {
    width: 100px;
    height: 60px;
    top: 10px;
    left: 20px;
    transform: rotate(-45deg);
    border-right-color: transparent;
    border-bottom-color: #2e7d32;
  }

  /* --- ANIMATIONS --- */
  @keyframes wave-spin {
    100% {
      transform: rotate(360deg);
    }
  }
  @keyframes wave-spin-reverse {
    100% {
      transform: rotate(-360deg);
    }
  }
  .animate-wave-spin {
    animation: wave-spin 10s infinite linear;
  }
  .animate-wave-spin-reverse {
    animation: wave-spin-reverse 10s infinite linear;
  }

  @keyframes float-mirror {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .animate-float-mirror {
    animation: float-mirror 4s ease-in-out infinite;
  }

  @keyframes shine {
    0% {
      left: -50px;
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      left: 150px;
      opacity: 0;
    }
  }
  .animate-shine {
    animation: shine 3s infinite;
  }

  @keyframes rise-drop {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-60px) scale(0.5);
      opacity: 0;
    }
  }
  .animate-rise-drop {
    animation: rise-drop 3s infinite ease-in;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
