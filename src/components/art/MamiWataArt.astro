---
/*
  MamiWataArt.astro - CSS Art
  Allégorie : La pureté et la puissance de l&apos;Océan.
  Design : Vagues CSS infinies, ambiance nocturne mystique, sans aucune surcharge textuelle.
  Optimisé Tailwind v4 - 100% CSS (Zéro JS)
*/
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#02040a] rounded-3xl overflow-hidden border border-teal-900/30 shadow-[0_25px_60px_rgba(0,0,0,0.95)] flex items-center justify-center opacity-0 animate-fade-up select-none"
>
  {/* 1. CIEL NOCTURNE ET LUNE MYSTIQUE */}
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#010a15] to-[#041a2f] z-0"
  >
  </div>

  {/* Astre lunaire rayonnant sur l&apos;eau */}
  <div
    class="absolute top-[15%] left-1/2 -translate-x-1/2 w-32 h-32 bg-teal-100/10 rounded-full blur-[40px] animate-pulse-moon z-0"
  >
  </div>
  <div
    class="absolute top-[20%] left-1/2 -translate-x-1/2 w-16 h-16 bg-white/90 rounded-full blur-[2px] shadow-[0_0_60px_rgba(20,184,166,0.6)] z-0"
  >
  </div>

  {/* 2. TYPOGRAPHIE FILIGRANE (Intégrée au ciel, presque invisible) */}
  <div
    class="absolute top-[25%] inset-x-0 text-center pointer-events-none z-0 mix-blend-overlay"
  >
    <span
      class="font-serif text-6xl md:text-8xl font-black text-white/5 tracking-[0.3em] uppercase drop-shadow-lg"
    >
      MAMI WATA
    </span>
  </div>

  {/* 3. OCÉAN ET VAGUES INFINIES (Technique CSS des cercles rotatifs) */}
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-10">
    {/* Vague de fond (Sombre et lente) */}
    <div
      class="absolute w-[250%] h-[250%] left-[-75%] top-[50%] bg-[#064e3b]/90 rounded-[43%] animate-wave-slow mix-blend-multiply"
    >
    </div>

    {/* Vague intermédiaire (Émeraude lumineuse) */}
    <div
      class="absolute w-[240%] h-[240%] left-[-70%] top-[55%] bg-[#0f766e]/80 rounded-[40%] animate-wave-med shadow-[0_-10px_30px_rgba(20,184,166,0.2)]"
    >
    </div>

    {/* Vague de premier plan (Bleu nuit profond, écume) */}
    <div
      class="absolute w-[230%] h-[230%] left-[-65%] top-[60%] bg-gradient-to-t from-[#020617] to-[#082f49] rounded-[38%] animate-wave-fast shadow-[0_-15px_40px_rgba(0,0,0,0.8)] border-t border-teal-500/20"
    >
    </div>
  </div>

  {/* 4. REFLETS ET PARTICULES SPIRITUELLES */}
  <div class="absolute inset-0 z-20 pointer-events-none overflow-hidden">
    {/* Reflet de la lune sur les vagues */}
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-48 h-1/2 bg-gradient-to-t from-transparent to-teal-300/10 blur-[20px]"
    >
    </div>

    {/* Gouttes d&apos;écume luminescentes */}
    <div
      class="absolute bottom-10 left-[25%] w-1.5 h-1.5 bg-white/60 rounded-full blur-[1px] animate-rise-fast [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute bottom-24 left-[50%] w-2 h-2 bg-teal-300/80 rounded-full blur-[1px] shadow-[0_0_10px_#2dd4bf] animate-rise-slow [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute bottom-16 left-[75%] w-1 h-1 bg-white/50 rounded-full blur-[1px] animate-rise-fast [animation-delay:0.5s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- Système d&apos;Apparition --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* --- Rayonnement de l&apos;Astre --- */
  @keyframes pulseMoon {
    0%,
    100% {
      opacity: 0.6;
      transform: translateX(-50%) scale(0.95);
    }
    50% {
      opacity: 1;
      transform: translateX(-50%) scale(1.05);
    }
  }
  .animate-pulse-moon {
    animation: pulseMoon 6s infinite alternate ease-in-out;
  }

  /* --- Mécanique des Vagues CSS Infinies --- */
  /* La rotation de div massifs avec un border-radius imparfait crée l&apos;illusion de houle */
  @keyframes waveRotate {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  .animate-wave-slow {
    animation: waveRotate 25s infinite linear;
  }
  .animate-wave-med {
    animation: waveRotate 18s infinite linear;
  }
  .animate-wave-fast {
    animation: waveRotate 12s infinite linear;
  }

  /* --- Particules / Gouttes d&apos;eau --- */
  @keyframes riseSlow {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      transform: translateY(-200px) scale(0);
      opacity: 0;
    }
  }
  .animate-rise-slow {
    animation: riseSlow 5s infinite ease-out;
  }

  @keyframes riseFast {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      transform: translateY(-150px) scale(0);
      opacity: 0;
    }
  }
  .animate-rise-fast {
    animation: riseFast 3s infinite ease-out;
  }
</style>
