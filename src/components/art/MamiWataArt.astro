---
/* MamiWataArt.astro 
  Composant CSS Art simulant l'aura de Mami Wata.
  Thème : Abysses, Vagues émeraude, Miroir divin et Or.
*/
---

<div
  class="relative w-full h-[350px] md:h-[450px] flex items-center justify-center overflow-hidden bg-[#020b14] rounded-3xl border border-teal-900/30 my-12 shadow-[0_20px_60px_rgba(0,0,0,0.9)]"
>
  {/* L'AURA AQUATIQUE (Glow sous-marin) */}
  <div
    class="absolute w-[300px] h-[300px] bg-teal-500/10 blur-[100px] rounded-full animate-[pulse-water_5s_ease-in-out_infinite]"
  >
  </div>

  {/* LES VAGUES (Ondulations CSS de fond) */}
  <div class="absolute inset-0 opacity-40">
    <div
      class="absolute top-[40%] left-[-20%] w-[140%] h-[200px] bg-teal-800/30 rounded-[100%] blur-[20px] animate-[wave-flow_8s_ease-in-out_infinite]"
    >
    </div>
    <div
      class="absolute top-[50%] left-[-20%] w-[150%] h-[200px] bg-blue-900/40 rounded-[100%] blur-[25px] animate-[wave-flow_10s_ease-in-out_infinite_reverse]"
    >
    </div>
  </div>

  {/* LE MIROIR SACRÉ DE MAMI WATA */}
  <div
    class="relative z-20 w-[140px] md:w-[180px] h-[200px] md:h-[260px] flex flex-col items-center justify-center animate-[float-mirror_6s_ease-in-out_infinite]"
  >
    {/* Cadre Doré Sculpté */}
    <div
      class="absolute inset-0 bg-gradient-to-br from-gold via-[#b8860b] to-[#8b6508] rounded-t-[50%] rounded-b-md shadow-[0_10px_30px_rgba(212,175,55,0.3)] flex items-center justify-center p-2"
    >
      {/* Verre du Miroir (Reflets aquatiques) */}
      <div
        class="relative w-full h-full bg-gradient-to-br from-teal-100/90 via-blue-200/80 to-white/90 rounded-t-[50%] rounded-b-sm overflow-hidden flex items-center justify-center"
      >
        {/* L'Ondulation dans le miroir */}
        <div
          class="absolute w-[200%] h-[200%] bg-gradient-to-t from-teal-400/40 to-transparent blur-[10px] animate-[spin-slow_12s_linear_infinite]"
        >
        </div>

        {/* L'éclat de lumière */}
        <div
          class="absolute -top-10 -left-10 w-[80px] h-[150px] bg-white/60 blur-[15px] rotate-45 animate-[shimmer_4s_infinite]"
        >
        </div>
      </div>
    </div>

    {/* Le Python Royal Enroulé (Symbole Dan / Mami Wata) */}
    <div
      class="absolute -bottom-6 w-[110%] h-[40px] bg-gradient-to-r from-emerald-800 via-teal-600 to-emerald-900 rounded-full blur-[1px] shadow-lg border-t-2 border-emerald-400/50"
    >
    </div>
    <div
      class="absolute -bottom-3 left-[-10px] w-[40px] h-[50px] bg-gradient-to-br from-teal-600 to-emerald-900 rounded-[50%] blur-[1px] rotate-[-20deg]"
    >
    </div>
  </div>

  {/* BULLES D'EAU (Lévitation) */}
  <div
    class="absolute bottom-0 w-full h-full flex justify-around px-10 z-30 pointer-events-none"
  >
    <div
      class="w-3 h-3 border border-white/40 rounded-full animate-[bubble-up_4s_ease-in_infinite]"
    >
    </div>
    <div
      class="w-2 h-2 border border-white/30 rounded-full animate-[bubble-up_5s_ease-in_infinite_1s]"
    >
    </div>
    <div
      class="w-4 h-4 border border-teal-200/40 rounded-full animate-[bubble-up_6s_ease-in_infinite_2s]"
    >
    </div>
    <div
      class="w-1.5 h-1.5 border border-white/50 rounded-full animate-[bubble-up_3.5s_ease-in_infinite_0.5s]"
    >
    </div>
  </div>
</div>

<style is:global>
  @keyframes float-mirror {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes wave-flow {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-30px) rotate(5deg);
    }
  }

  @keyframes bubble-up {
    0% {
      transform: translateY(100px) scale(0.5);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      transform: translateY(-400px) scale(1.5);
      opacity: 0;
    }
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-150px) rotate(45deg);
      opacity: 0;
    }
    50% {
      opacity: 0.8;
    }
    100% {
      transform: translateX(200px) rotate(45deg);
      opacity: 0;
    }
  }

  @keyframes pulse-water {
    0%,
    100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.1);
    }
  }
</style>
