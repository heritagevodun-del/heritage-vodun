---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#0a0510] rounded-3xl overflow-hidden border border-purple-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.8)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(88,28,135,0.15)_0%,transparent_70%)]"
    >
    </div>
    <div
      class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(255,255,255,0.02)_3px,rgba(255,255,255,0.02)_4px)] mix-blend-overlay"
    >
    </div>
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 md:w-[30rem] md:h-[30rem] bg-purple-900/20 rounded-full blur-[60px] z-0 animate-pulse-deep"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-10 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-6xl md:text-8xl lg:text-[9rem] font-black text-purple-100/5 uppercase tracking-[0.2em] w-full text-center transition-transform duration-1000 group-hover:scale-105"
    >
      AZÉ
    </h1>
  </div>

  <div
    class="relative z-30 flex items-center justify-center w-64 h-64 md:w-80 md:h-80 mt-8 animate-float"
  >
    <div
      class="absolute inset-0 rounded-full border border-purple-500/20 shadow-[0_0_40px_rgba(147,51,234,0.3)] animate-spin-very-slow"
    >
    </div>
    <div
      class="absolute inset-[-10%] rounded-full border border-dashed border-purple-400/10 animate-spin-slow-reverse"
    >
    </div>

    <div
      class="relative w-48 h-48 md:w-60 md:h-60 bg-gradient-to-br from-[#2e1065] to-[#0f0728] rounded-full shadow-[inset_0_0_30px_rgba(0,0,0,0.9),0_0_20px_rgba(147,51,234,0.4)] flex items-center justify-center overflow-hidden border border-purple-800/50"
    >
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-full h-1 bg-purple-500/20 blur-[2px] rotate-45"></div>
        <div class="absolute w-full h-1 bg-purple-500/20 blur-[2px] -rotate-45">
        </div>
      </div>

      <div
        class="relative w-20 h-20 md:w-28 md:h-28 bg-gradient-to-b from-[#7e22ce] to-[#4c1d95] rounded-full shadow-[0_0_40px_rgba(168,85,247,0.6)] flex items-center justify-center animate-core-breathe border-2 border-purple-300/30"
      >
        <div
          class="w-8 h-8 md:w-10 md:h-10 bg-[#f3e8ff] rounded-full shadow-[0_0_20px_#fff,inset_0_0_10px_rgba(0,0,0,0.5)] animate-pulse-core"
        >
        </div>
      </div>
    </div>

    <div class="absolute bottom-[-15%] flex flex-col items-center">
      <span
        class="font-sans text-xs md:text-sm font-bold text-purple-300 tracking-[0.5em] uppercase drop-shadow-[0_0_5px_rgba(216,180,254,0.5)]"
      >
        PUISSANCE BRUTE
      </span>
    </div>
  </div>

  <div
    class="absolute inset-0 z-40 pointer-events-none overflow-hidden mix-blend-screen"
  >
    <div
      class="absolute bottom-[20%] left-[25%] w-2 h-2 bg-purple-300 blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[30%] right-[30%] w-3 h-3 bg-purple-400 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] right-[20%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute top-[50%] left-[35%] w-1 h-1 bg-fuchsia-300 rounded-full animate-float-up [animation-delay:2.5s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes pulseDeep {
    0%,
    100% {
      opacity: 0.4;
      transform: translate(-50%, -50%) scale(0.9);
    }
    50% {
      opacity: 0.7;
      transform: translate(-50%, -50%) scale(1.1);
    }
  }
  .animate-pulse-deep {
    animation: pulseDeep 4s infinite alternate ease-in-out;
  }

  @keyframes spinVerySlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-very-slow {
    animation: spinVerySlow 30s linear infinite;
  }

  @keyframes spinSlowReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }
  .animate-spin-slow-reverse {
    animation: spinSlowReverse 25s linear infinite;
  }

  @keyframes coreBreathe {
    0%,
    100% {
      transform: scale(0.95);
      filter: brightness(1);
    }
    50% {
      transform: scale(1.05);
      filter: brightness(1.3);
    }
  }
  .animate-core-breathe {
    animation: coreBreathe 3s infinite ease-in-out;
  }

  @keyframes pulseCore {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }
  .animate-pulse-core {
    animation: pulseCore 1.5s infinite alternate ease-in-out;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-150px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 5s infinite ease-out;
  }
</style>
