---
/*
  ConvergenceArt.astro - CSS Art
  Allégorie des Trois Apparitions (Vodun Days) : Le Sanctuaire du Miroir.
  Fusion de la composition authentique (Zangbeto, Mami Wata, Egungun) avec l'architecture Tech-Sombre de Legba.
  Optimisé Tailwind v4 - 100% CSS (Zéro JS)
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-96 md:h-[32rem] bg-[#040101] rounded-2xl overflow-hidden border border-amber-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.9)] flex items-center justify-center group opacity-0 animate-fade-up select-none"
>
  {/* 1. LUEUR D'ARRIÈRE-PLAN (Réagit au hover) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(20,184,166,0.1)_0%,#040101_70%)] transition-colors duration-1000 group-hover:bg-[radial-gradient(circle_at_center,rgba(20,184,166,0.2)_0%,#040101_70%)]"
  >
  </div>

  {/* 2. BRUIT VISUEL (Texture) */}
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.06%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* 3. LE CARREFOUR / SOL 3D (Style Legba - z-10) */}
  <div
    class="absolute bottom-[-100px] w-[600px] h-[600px] flex items-center justify-center z-10 opacity-60 transition-all duration-700 group-hover:opacity-100 [transform:rotateX(75deg)_scale(1.2)]"
  >
    {/* Lignes de force axiales */}
    <div
      class="absolute w-1 h-full bg-gradient-to-b from-transparent via-amber-500/50 to-transparent shadow-[0_0_30px_rgba(245,158,11,0.5)]"
    >
    </div>
    <div
      class="absolute w-full h-1 bg-gradient-to-r from-transparent via-amber-500/50 to-transparent shadow-[0_0_30px_rgba(245,158,11,0.5)]"
    >
    </div>

    {/* Anneaux de résonance aquatique (Ondes de Mami Wata) */}
    <div
      class="absolute w-[40%] h-[40%] border border-teal-500/30 rounded-full animate-ping-slow shadow-[0_0_20px_rgba(20,184,166,0.2)]"
    >
    </div>
    <div
      class="absolute w-[60%] h-[60%] border border-teal-500/10 rounded-full"
    >
    </div>
  </div>

  {/* 4. LE TRIPTYQUE (Z-20) */}
  <div
    class="absolute bottom-16 md:bottom-20 z-20 flex items-end justify-center gap-8 md:gap-14 w-full"
  >
    {/* --- GAUCHE : ZANGBETO (Le Cône Noir et Or) --- */}
    <div
      class="relative w-20 h-32 md:w-28 md:h-44 flex flex-col items-center transition-transform duration-700 hover:-translate-y-3 cursor-pointer group/zang"
    >
      {/* Silhouette massive du Zangbeto */}
      <div
        class="w-full h-full bg-gradient-to-b from-[#1a0f0a] via-[#0d0703] to-[#040101] shadow-[0_20px_30px_rgba(0,0,0,0.9),inset_0_0_15px_rgba(245,158,11,0.1)] border-b border-amber-900/50 overflow-hidden"
        style="clip-path: polygon(50% 0%, 100% 100%, 0% 100%);"
      >
        {/* Texture abstraite du raphia (Lignes horizontales sombres) */}
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(to_bottom,transparent,transparent_4px,rgba(0,0,0,0.8)_5px,rgba(0,0,0,0.8)_6px)]"
        >
        </div>

        {/* Cœur énergétique (La magie qui anime le masque) */}
        <div
          class="absolute bottom-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-amber-500 rounded-full blur-[12px] opacity-70 animate-pulse-fast"
        >
        </div>
      </div>
    </div>

    {/* --- CENTRE : MAMI WATA (Le Grand Miroir Portail) --- */}
    {
      /* Représente le miroir sacré de la photo, mais à une échelle monumentale */
    }
    <div
      class="relative w-32 h-48 md:w-40 md:h-64 flex flex-col items-center transition-transform duration-700 hover:-translate-y-3 cursor-pointer z-30 group/mami"
    >
      {/* Le Cadre du Miroir (Bois sculpté / Laiton sombre) */}
      <div
        class="absolute inset-0 bg-gradient-to-br from-[#3e2723] via-[#1a0f0a] to-[#0a0502] rounded-[50%_50%_45%_45%] shadow-[0_30px_50px_rgba(0,0,0,0.9),inset_0_0_10px_rgba(245,158,11,0.2)] p-[4px] md:p-[6px]"
      >
        {/* La Surface du Miroir (Le Portail vers l'Océan) */}
        <div
          class="w-full h-full bg-[#020813] rounded-[50%_50%_45%_45%] overflow-hidden relative shadow-[inset_0_0_30px_#000]"
        >
          {/* Abysses et courants océaniques (Pur CSS) */}
          <div
            class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(20,184,166,0.4)_0%,transparent_80%)] animate-pulse-slow"
          >
          </div>

          {/* Le reflet biseauté (L'éclat du miroir) */}
          <div
            class="absolute -top-10 -left-10 w-20 h-full bg-white/10 blur-[4px] transform rotate-45 group-hover/mami:translate-x-48 transition-transform duration-1000 ease-in-out"
          >
          </div>

          {/* Singularité aquatique centrale */}
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-16 bg-teal-300 blur-[4px] shadow-[0_0_20px_#2dd4bf] rounded-full animate-flicker"
          >
          </div>
        </div>
      </div>

      {/* Halo du miroir projeté sur le sol */}
      <div
        class="absolute -bottom-4 w-24 h-4 bg-teal-500/40 rounded-full blur-[10px] opacity-0 group-hover/mami:opacity-100 transition-opacity"
      >
      </div>
    </div>

    {/* --- DROITE : EGUNGUN (Le Buste Drapé Rouge et Or) --- */}
    <div
      class="relative w-20 h-32 md:w-28 md:h-44 flex flex-col items-center transition-transform duration-700 hover:-translate-y-3 cursor-pointer group/egun"
    >
      {/* Silhouette massive du masque et des tissus */}
      <div
        class="w-full h-full bg-gradient-to-b from-[#2a0808] via-[#110303] to-[#040101] shadow-[0_20px_30px_rgba(0,0,0,0.9),inset_0_0_15px_rgba(220,38,38,0.1)] rounded-t-full border-b border-red-900/50 overflow-hidden relative"
      >
        {/* Lignes verticales simulant les bandes de tissu */}
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(to_right,transparent,transparent_6px,rgba(0,0,0,0.7)_8px,rgba(0,0,0,0.7)_10px)]"
        >
        </div>

        {/* Le Visage / Le Regard de l'Ancêtre */}
        <div class="absolute top-[30%] w-full flex justify-center gap-3">
          <div
            class="w-3 h-1.5 bg-yellow-500 rounded-full shadow-[0_0_10px_#eab308] animate-pulse"
          >
          </div>
          <div
            class="w-3 h-1.5 bg-yellow-500 rounded-full shadow-[0_0_10px_#eab308] animate-pulse"
          >
          </div>
        </div>

        {/* Ornement frontal (Rouge sang) */}
        <div
          class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[50%] bg-gradient-to-t from-red-600 to-transparent blur-[2px]"
        >
        </div>
      </div>
    </div>
  </div>

  {/* 5. TITRE TYPOGRAPHIQUE (Élevé au z-30 avec mix-blend, style Legba) */}
  <div
    class="absolute top-8 md:top-12 w-full text-center z-30 mix-blend-screen pointer-events-none transition-transform duration-1000 group-hover:scale-105"
  >
    <h1
      class="font-serif text-6xl md:text-8xl m-0 text-transparent bg-clip-text bg-gradient-to-b from-stone-400/30 to-transparent uppercase tracking-[0.25em] font-black drop-shadow-[0_4px_10px_rgba(0,0,0,0.8)]"
    >
      HWE DAHO
    </h1>
  </div>

  {/* 6. PARTICULES (Gérées en pur CSS - z-25) */}
  <div class="absolute inset-0 z-[25] overflow-hidden pointer-events-none">
    <div
      class="absolute bottom-0 left-[35%] w-1.5 h-1.5 bg-amber-400 rounded-full shadow-[0_0_10px_#f59e0b] animate-rise opacity-0 [animation-delay:0.2s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[50%] w-2 h-2 bg-teal-300 rounded-full shadow-[0_0_15px_#2dd4bf] animate-rise opacity-0 [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[65%] w-1 h-1 bg-red-500 rounded-full shadow-[0_0_10px_#ef4444] animate-rise opacity-0 [animation-delay:0.8s]"
    >
    </div>
  </div>

  {/* Décorations de coin HUD (z-40) */}
  <div
    class="absolute top-4 left-4 font-mono text-[0.55rem] md:text-[0.625rem] text-amber-500/50 tracking-[0.3em] uppercase z-40 pointer-events-none"
  >
    POSITION : OUIDAH
  </div>
  <div
    class="absolute bottom-4 right-4 font-mono text-[0.55rem] md:text-[0.625rem] text-teal-500/50 tracking-[0.3em] uppercase animate-pulse-slow z-40 pointer-events-none"
  >
    VODUN DAYS
  </div>
</div>

<style>
  /* --- Animations 100% CSS --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes flicker {
    0%,
    100% {
      opacity: 0.8;
      filter: brightness(1) blur(2px);
    }
    50% {
      opacity: 1;
      filter: brightness(1.3) blur(4px);
    }
  }
  .animate-flicker {
    animation: flicker 0.15s infinite alternate;
  }

  @keyframes pulseFast {
    0%,
    100% {
      transform: scale(0.9);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
      filter: brightness(1.2);
    }
  }
  .animate-pulse-fast {
    animation: pulseFast 1.5s infinite alternate ease-in-out;
  }

  @keyframes pulseSlow {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(0.98);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.02);
    }
  }
  .animate-pulse-slow {
    animation: pulseSlow 4s infinite alternate;
  }

  @keyframes pingSlow {
    0% {
      transform: scale(0.8);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }
  .animate-ping-slow {
    animation: pingSlow 4s infinite cubic-bezier(0, 0, 0.2, 1);
  }

  @keyframes rise {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    80% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(-350px) scale(0);
      opacity: 0;
    }
  }
  .animate-rise {
    animation: rise 3.5s infinite ease-in;
  }
</style>
