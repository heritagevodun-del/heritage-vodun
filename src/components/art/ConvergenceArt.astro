---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fdfbf7] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[32rem] h-80 md:h-[32rem] bg-white rounded-full blur-[60px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-30 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-6xl md:text-8xl lg:text-9xl font-black text-amber-900/70 uppercase tracking-[0.15em] w-full text-center drop-shadow-[0_2px_4px_rgba(217,119,6,0.3)] transition-transform duration-1000 group-hover:scale-105"
    >
      VODUN DAYS
    </h1>
  </div>

  <div
    class="absolute bottom-0 w-full h-[30%] bg-gradient-to-t from-[#d97706]/10 to-transparent z-10"
  >
  </div>
  <div
    class="absolute bottom-[15%] w-[80%] h-12 bg-amber-900/10 blur-[15px] rounded-[100%] z-15"
  >
  </div>

  <div
    class="relative z-20 flex items-end justify-center gap-6 md:gap-12 mt-16 h-[55%]"
  >
    <div
      class="relative w-20 md:w-28 flex flex-col items-center animate-float [animation-delay:0s]"
    >
      <div
        class="w-full h-8 md:h-12 bg-gradient-to-b from-[#8a4224] to-[#5c2813] rounded-t-full shadow-[inset_0_-4px_10px_rgba(0,0,0,0.4)] z-30"
      >
      </div>
      <div
        class="w-[110%] h-12 md:h-16 bg-gradient-to-b from-[#b85a30] to-[#8a4224] -mt-4 shadow-[0_4px_10px_rgba(0,0,0,0.3)] z-20"
        style="clip-path: polygon(20% 0%, 80% 0%, 100% 100%, 0% 100%);"
      >
      </div>
      <div
        class="w-[120%] h-16 md:h-24 bg-gradient-to-b from-[#a64d24] to-[#5c2813] -mt-4 shadow-[0_4px_10px_rgba(0,0,0,0.4)] z-10"
        style="clip-path: polygon(10% 0%, 90% 0%, 100% 100%, 0% 100%);"
      >
      </div>
      <div
        class="absolute bottom-0 w-[120%] h-4 bg-[repeating-linear-gradient(90deg,transparent,transparent_2px,rgba(255,255,255,0.2)_3px,rgba(255,255,255,0.2)_4px)] z-40"
      >
      </div>
    </div>

    <div
      class="relative w-24 md:w-32 flex flex-col items-center animate-float [animation-delay:1s] mb-4 md:mb-8"
    >
      <div
        class="w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-[#e11d48] to-[#9f1239] rounded-[40%_40%_10px_10px] shadow-[inset_0_-4px_10px_rgba(0,0,0,0.5)] z-40 border-b-4 border-[#fbbf24]"
      >
      </div>
      <div
        class="w-16 h-8 md:w-20 md:h-10 bg-[#fbbf24] -mt-2 z-30 shadow-[0_4px_10px_rgba(0,0,0,0.3)] flex justify-center items-center gap-1 md:gap-1.5"
      >
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_2px_rgba(0,0,0,0.3)]"
        >
        </div>
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_2px_rgba(0,0,0,0.3)]"
        >
        </div>
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_2px_rgba(0,0,0,0.3)]"
        >
        </div>
      </div>
      <div
        class="w-full h-24 md:h-36 bg-gradient-to-b from-[#be123c] via-[#881337] to-[#4c0519] -mt-2 z-20 shadow-[0_4px_15px_rgba(0,0,0,0.5)] rounded-[5px_5px_0_0] overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(180deg,transparent,transparent_8px,rgba(251,191,36,0.3)_9px,rgba(251,191,36,0.3)_12px)]"
        >
        </div>
      </div>
    </div>

    <div
      class="relative w-16 md:w-24 flex flex-col items-center animate-float [animation-delay:2s]"
    >
      <div
        class="w-20 md:w-28 h-12 md:h-16 bg-gradient-to-b from-[#d97706] to-[#b45309] rounded-t-full shadow-[inset_0_-4px_10px_rgba(0,0,0,0.3)] z-30 flex items-end justify-center pb-2"
      >
        <div
          class="w-8 md:w-12 h-4 md:h-6 bg-white rounded-t-full opacity-80 shadow-[0_-2px_4px_rgba(255,255,255,0.5)]"
        >
        </div>
      </div>
      <div
        class="w-14 md:w-20 h-16 md:h-24 bg-gradient-to-b from-[#78350f] to-[#451a03] -mt-2 shadow-[0_4px_10px_rgba(0,0,0,0.4)] z-20 rounded-[0_0_40%_40%] flex flex-col items-center pt-4"
      >
        <div class="flex gap-2 md:gap-3">
          <div
            class="w-2 h-2 md:w-2.5 md:h-2.5 bg-[#f8fafc] rounded-full shadow-[0_0_4px_#fff]"
          >
          </div>
          <div
            class="w-2 h-2 md:w-2.5 md:h-2.5 bg-[#f8fafc] rounded-full shadow-[0_0_4px_#fff]"
          >
          </div>
        </div>
        <div
          class="w-4 md:w-6 h-1 md:h-1.5 bg-[#d4b58e] mt-4 rounded-full shadow-[inset_0_1px_1px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[20%] w-2 h-2 bg-white blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[30%] right-[30%] w-3 h-3 bg-amber-200 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] right-[15%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 6s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-150px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 6s infinite ease-out;
  }
</style>
