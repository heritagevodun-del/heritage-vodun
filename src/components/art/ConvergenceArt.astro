---
/* ConvergenceArt.astro 
   Composant CSS Art représentant la fusion des trois forces (Zangbeto, Egungun, Mami Wata).
   Un vortex mystique tourbillonnant au-dessus de l'horizon de Ouidah.
*/
---

<div
  class="relative w-full h-[350px] md:h-[450px] flex items-center justify-center overflow-hidden bg-[#050505] rounded-3xl border border-white/5 my-12 shadow-[0_20px_60px_rgba(0,0,0,0.8)]"
>
  {/* L'HORIZON DE OUIDAH (Sable, Mer, Ciel de nuit) */}
  <div class="absolute inset-0 z-0">
    <div
      class="absolute bottom-0 w-full h-[35%] bg-gradient-to-t from-[#2a1b0a] to-[#050505] shadow-inner"
    >
    </div>
    {/* Sable */}
    <div
      class="absolute bottom-[35%] w-full h-1 bg-gradient-to-r from-transparent via-teal-800 to-transparent"
    >
    </div>
    {/* Ligne d'eau émeraude */}
  </div>

  {/* L'AURA SPIRITUELLE (Glow de fond) */}
  <div
    class="absolute w-[250px] h-[250px] bg-white/5 blur-[80px] rounded-full animate-[pulse-glow_4s_infinite]"
  >
  </div>

  {/* LE VORTEX DE CONVERGENCE (Les 3 Forces) */}
  <div
    class="relative z-10 w-[200px] md:w-[260px] h-[200px] md:h-[260px] animate-[float-convergence_5s_ease-in-out_infinite]"
  >
    {/* La Porte Invisible (Le centre vide) */}
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-white rounded-full blur-[8px] z-50 animate-[pulse-gate_2s_infinite]"
    >
    </div>

    {/* FORCE 1 : Le Raphia du Zangbeto (Ocres et Bruns) */}
    <div
      class="absolute inset-0 border-[6px] border-dashed border-[#8b4513]/50 rounded-full animate-[spin-vortex_6s_linear_infinite] blur-[1px]"
    >
    </div>

    {/* FORCE 2 : Les Étoffes de l'Egungun (Rouges, Or, Pourpres) */}
    <div
      class="absolute inset-2 border-[5px] border-dotted border-red-700/60 rounded-full animate-[spin-vortex_4s_linear_infinite_reverse] blur-[1px]"
    >
    </div>
    <div
      class="absolute inset-4 border-[3px] border-dashed border-gold/40 rounded-full animate-[spin-vortex_8s_linear_infinite_0.5s]"
    >
    </div>

    {/* FORCE 3 : L'Eau de Mami Wata (Émeraudes, Teals, Bleus) */}
    <div
      class="absolute inset-8 rounded-full bg-gradient-to-br from-teal-500/20 via-blue-900/10 to-transparent blur-[5px] animate-[pulse_3s_infinite_alternate]"
    >
    </div>
    <div
      class="absolute inset-10 border-[4px] border-solid border-teal-200/30 rounded-full animate-[spin-vortex_10s_linear_infinite] mix-blend-screen"
    >
    </div>
  </div>

  {/* PARTICULES DE FUSION (Étincelles) */}
  <div class="absolute top-1/4 flex gap-16 z-20">
    <div
      class="w-1.5 h-1.5 bg-gold rounded-full blur-[1px] animate-[float-up_2.5s_ease-in_infinite]"
    >
    </div>
    <div
      class="w-2.5 h-2.5 bg-red-600 rounded-full blur-[2px] animate-[float-up_3s_ease-in_infinite_0.7s]"
    >
    </div>
    <div
      class="w-2 h-2 bg-teal-300 rounded-full blur-[1px] animate-[float-up_2s_ease-in_infinite_1.3s]"
    >
    </div>
  </div>

  {/* OMBRE PORTÉE */}
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 w-[180px] md:w-[220px] h-6 bg-black/90 rounded-full blur-[10px]"
  >
  </div>
</div>

<style is:global>
  @keyframes spin-vortex {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes float-convergence {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-15px) scale(1.03);
    }
  }

  @keyframes pulse-gate {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.8;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0.3;
    }
  }

  @keyframes float-up {
    0% {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translateY(-150px) scale(0);
      opacity: 0;
    }
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.2;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.1);
    }
  }
</style>
