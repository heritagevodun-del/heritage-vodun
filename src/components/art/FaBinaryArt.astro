---
/*
  FaBinaryArt.astro - CSS Art
  Illustre le pont entre le code binaire informatique et le système du Fâ.
  Optimisé Tailwind v4 - Thème Tech/Sombre - 100% Responsive
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 min-h-[26rem] sm:min-h-[24rem] md:h-84 bg-[#030712] rounded-2xl overflow-hidden border border-cyan-800/40 shadow-[0_0_40px_rgba(6,182,212,0.15)] flex items-center justify-center group opacity-0 animate-fade-up p-8"
>
  {/* Lueur d&apos;arrière-plan (Réagit au hover) */}
  <div
    class="absolute w-64 h-64 bg-cyan-700/20 rounded-full blur-[80px] transition-all duration-700 pointer-events-none group-hover:bg-cyan-500/30 group-hover:scale-125"
  >
  </div>

  {/* Grille de fond (Matrix style) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:20px_20px] opacity-20 mix-blend-overlay pointer-events-none"
  >
  </div>

  {/* Effet de balayage holographique (Scanner) */}
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-cyan-500/10 to-transparent h-[200%] animate-scan pointer-events-none opacity-50"
  >
  </div>

  {/* Conteneur principal adaptatif */}
  <div
    class="relative z-10 flex flex-col md:flex-row items-center justify-center gap-8 md:gap-14 w-full mt-2 md:mt-0"
  >
    {/* Côté Gauche : Les traces du Fâ (Amber) */}
    <div
      class="flex flex-col gap-2.5 md:gap-3 opacity-90 transition-transform duration-700 md:group-hover:-translate-x-4 group-hover:-translate-y-2 md:group-hover:translate-y-0"
    >
      {/* Ligne 1 : Fermé (Deux traits) */}
      <div class="flex gap-3 md:gap-4 justify-center">
        <div
          class="w-5 h-2 md:w-6 md:h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-5 h-2 md:w-6 md:h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>

      {/* Ligne 2 : Ouvert (Un trait) */}
      <div
        class="w-12 h-2 md:w-16 md:h-3 bg-amber-500 rounded-full shadow-[0_0_15px_rgba(245,158,11,0.6)] mx-auto"
      >
      </div>

      {/* Ligne 3 : Fermé (Deux traits) */}
      <div class="flex gap-3 md:gap-4 justify-center">
        <div
          class="w-5 h-2 md:w-6 md:h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-5 h-2 md:w-6 md:h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>

      {/* Ligne 4 : Ouvert (Un trait) */}
      <div
        class="w-12 h-2 md:w-16 md:h-3 bg-amber-500 rounded-full shadow-[0_0_15px_rgba(245,158,11,0.6)] mx-auto"
      >
      </div>
    </div>

    {/* Centre : Transition (Pivote sur mobile) */}
    <div
      class="text-cyan-500/40 font-mono text-xl md:text-2xl animate-pulse rotate-90 md:rotate-0 tracking-widest transition-transform duration-700 group-hover:text-cyan-400/80"
    >
      =&gt;
    </div>

    {/* Côté Droit : Code Binaire (Cyan) */}
    <div
      class="flex flex-col gap-2 font-mono text-xl md:text-2xl font-bold tracking-[0.2em] md:tracking-[0.25em] text-cyan-400 text-center transition-transform duration-700 md:group-hover:translate-x-4 group-hover:translate-y-2 md:group-hover:translate-y-0 drop-shadow-[0_0_10px_rgba(34,211,238,0.6)]"
    >
      <div>0 0</div>
      <div class="text-cyan-300">1</div>
      <div>0 0</div>
      <div class="text-cyan-300">1</div>
    </div>
  </div>

  {/* Textes HUD / Cyberpunk */}
  <div
    class="absolute bottom-4 sm:bottom-5 left-4 sm:left-6 font-mono text-[0.55rem] sm:text-[0.625rem] text-cyan-500/60 tracking-[0.2em] sm:tracking-[0.3em] uppercase select-none pointer-events-none"
  >
    <span class="hidden sm:inline">PROCESSOR: </span>8-BIT // <span
      class="hidden sm:inline"
      >ALGORITHM:
    </span>FÂ
  </div>

  <div
    class="absolute top-4 sm:top-5 right-4 sm:right-6 font-mono text-[0.55rem] sm:text-[0.625rem] text-amber-500/60 tracking-[0.2em] sm:tracking-[0.3em] uppercase animate-pulse-slow select-none pointer-events-none flex items-center gap-2"
  >
    <span
      class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-ping hidden sm:block"
    ></span>
    SYSTEM.DECODE()
  </div>
</div>

<style>
  /* Animation d&apos;entrée */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Pulsation douce pour le texte HUD */
  @keyframes pulseSlow {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.8;
    }
  }
  .animate-pulse-slow {
    animation: pulseSlow 3s infinite alternate;
  }

  /* Balayage holographique (Scanner) */
  @keyframes scan {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0%);
    }
  }
  .animate-scan {
    animation: scan 8s linear infinite;
  }
</style>
