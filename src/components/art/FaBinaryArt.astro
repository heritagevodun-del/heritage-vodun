---
/*
  FaBinaryArt.astro - CSS Art
  Illustre le pont entre le code binaire informatique et le système du Fâ.
  Optimisé Tailwind v4 - Thème Tech/Sombre
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-80 bg-dark-bg rounded-2xl overflow-hidden border border-cyan-700/30 shadow-[0_0_40px_rgba(6,182,212,0.1)] flex items-center justify-center group opacity-0 animate-fade-up"
>
  {/* Lueur d'arrière-plan (Réagit au hover) */}
  <div
    class="absolute w-64 h-64 bg-cyan-700/20 rounded-full blur-[80px] transition-all duration-700 pointer-events-none group-hover:bg-cyan-500/30 group-hover:scale-110"
  >
  </div>

  {/* Grille de fond (Matrix style) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:20px_20px] opacity-20 mix-blend-overlay"
  >
  </div>

  <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
    {/* Côté Gauche : Les traces du Fâ (Amber) */}
    <div
      class="flex flex-col gap-3 opacity-90 transition-transform duration-500 group-hover:-translate-x-2"
    >
      <div
        class="w-16 h-3 bg-amber-500 rounded-full shadow-[0_0_15px_rgba(245,158,11,0.6)]"
      >
      </div>
      <div class="flex gap-4 justify-center">
        <div
          class="w-6 h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-6 h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>
      <div
        class="w-16 h-3 bg-amber-500 rounded-full shadow-[0_0_15px_rgba(245,158,11,0.6)]"
      >
      </div>
      <div class="flex gap-4 justify-center">
        <div
          class="w-6 h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-6 h-3 bg-amber-700 rounded-full shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>
    </div>

    {/* Centre : Transition */}
    <div class="text-white/30 font-mono text-2xl animate-pulse">=></div>

    {/* Côté Droit : Code Binaire (Cyan) */}
    <div
      class="flex flex-col gap-2 font-mono text-2xl font-bold tracking-[0.2em] text-cyan-400 text-center transition-transform duration-500 group-hover:translate-x-2 drop-shadow-[0_0_8px_rgba(34,211,238,0.5)]"
    >
      <div>1</div>
      <div>0 0</div>
      <div>1</div>
      <div>0 0</div>
    </div>
  </div>

  {/* Textes HUD / Cyberpunk */}
  <div
    class="absolute bottom-4 left-4 font-mono text-[0.625rem] text-cyan-500/50 tracking-[0.3em] uppercase select-none"
  >
    PROCESSOR: 8-BIT // ALGORITHM: FÂ
  </div>
  <div
    class="absolute top-4 right-4 font-mono text-[0.625rem] text-amber-500/50 tracking-[0.3em] uppercase animate-pulse select-none"
  >
    SYSTEM.DECODE()
  </div>
</div>

<style>
  /* Animation d'entrée */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
