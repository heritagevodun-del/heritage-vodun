---
/*
  FaBinaryArt.astro - CSS Art
  Allégorie du Fâ : De la Géomancie à l&apos;Algorithme (MINDOGUESITO).
  Optimisé Tailwind v4 - 100% CSS (Zéro JS) - 100% Responsive
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 min-h-[24rem] md:min-h-[36rem] bg-[#030712] rounded-2xl overflow-hidden border border-emerald-900/40 shadow-[0_20px_50px_rgba(0,0,0,0.9)] flex flex-col items-center justify-center group opacity-0 animate-fade-up select-none p-4"
>
  {/* Matrice d'arrière-plan (Binaire) */}
  <div
    class="absolute inset-0 overflow-hidden opacity-20 transition-opacity duration-1000 group-hover:opacity-40 pointer-events-none"
  >
    <div
      class="absolute top-[-20%] left-[10%] text-emerald-500/50 font-mono text-xs animate-rain-slow [writing-mode:vertical-rl]"
    >
      01000110 01000001
    </div>
    <div
      class="absolute top-[-30%] left-[30%] text-emerald-400/50 font-mono text-sm animate-rain-fast [writing-mode:vertical-rl]"
    >
      10110101 00101010
    </div>
    <div
      class="absolute top-[-10%] left-[50%] text-emerald-600/50 font-mono text-xs animate-rain-medium [writing-mode:vertical-rl]"
    >
      01110110 01101111
    </div>
    <div
      class="absolute top-[-25%] left-[70%] text-emerald-500/50 font-mono text-sm animate-rain-slow [writing-mode:vertical-rl]"
    >
      01100100 01110101
    </div>
    <div
      class="absolute top-[-15%] left-[90%] text-emerald-300/50 font-mono text-xs animate-rain-fast [writing-mode:vertical-rl]"
    >
      01101110 11010011
    </div>
  </div>

  {/* Lueur Centrale (Opele énergétique) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.15)_0%,#030712_80%)] transition-colors duration-1000 group-hover:bg-[radial-gradient(circle_at_center,rgba(52,211,153,0.25)_0%,#030712_80%)] pointer-events-none"
  >
  </div>

  {/* Titre Arrière-plan (Typographie Fluide) */}
  <div
    class="absolute top-10 sm:top-12 md:top-16 w-full text-center z-0 transition-transform duration-1000 group-hover:scale-105 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-6xl sm:text-8xl md:text-9xl m-0 text-transparent bg-clip-text bg-gradient-to-b from-emerald-800/60 to-transparent uppercase tracking-[0.15em] sm:tracking-[0.2em] md:tracking-[0.3em] font-black"
    >
      LE FÂ
    </h1>
  </div>

  {/* Conteneur de la Carte Centrale (Centrage Flexbox dynamique) */}
  <div
    class="relative z-10 w-full flex items-center justify-center mt-12 sm:mt-16 md:mt-20"
  >
    <div
      class="flex flex-col items-center gap-3 sm:gap-4 md:gap-6 p-6 sm:p-8 bg-[#022c22]/40 backdrop-blur-md border border-emerald-500/30 rounded-xl shadow-[0_20px_40px_rgba(0,0,0,0.5),0_0_30px_rgba(16,185,129,0.15)] transition-transform duration-700 group-hover:scale-110 group-hover:-translate-y-2"
    >
      {/* Ligne 1 : Deux traits (Fermé / 0) */}
      <div class="flex gap-6 sm:gap-8 md:gap-12 w-full justify-center">
        <div
          class="w-6 h-1.5 sm:h-2 md:w-8 md:h-3 bg-emerald-400 rounded-sm shadow-[0_0_10px_#34d399] animate-pulse-glow"
        >
        </div>
        <div
          class="w-6 h-1.5 sm:h-2 md:w-8 md:h-3 bg-emerald-400 rounded-sm shadow-[0_0_10px_#34d399] animate-pulse-glow"
        >
        </div>
      </div>

      {/* Ligne 2 : Un trait (Ouvert / 1) */}
      <div class="flex w-full justify-center">
        <div
          class="w-16 sm:w-20 h-1.5 sm:h-2 md:w-28 md:h-3 bg-emerald-300 rounded-sm shadow-[0_0_15px_#6ee7b7] animate-pulse-glow [animation-delay:0.2s]"
        >
        </div>
      </div>

      {/* Ligne 3 : Deux traits (Fermé / 0) */}
      <div class="flex gap-6 sm:gap-8 md:gap-12 w-full justify-center">
        <div
          class="w-6 h-1.5 sm:h-2 md:w-8 md:h-3 bg-emerald-400 rounded-sm shadow-[0_0_10px_#34d399] animate-pulse-glow [animation-delay:0.4s]"
        >
        </div>
        <div
          class="w-6 h-1.5 sm:h-2 md:w-8 md:h-3 bg-emerald-400 rounded-sm shadow-[0_0_10px_#34d399] animate-pulse-glow [animation-delay:0.4s]"
        >
        </div>
      </div>

      {/* Ligne 4 : Un trait (Ouvert / 1) */}
      <div class="flex w-full justify-center">
        <div
          class="w-16 sm:w-20 h-1.5 sm:h-2 md:w-28 md:h-3 bg-emerald-300 rounded-sm shadow-[0_0_15px_#6ee7b7] animate-pulse-glow [animation-delay:0.6s]"
        >
        </div>
      </div>
    </div>
  </div>

  {/* Textes HUD / Informations Numériques */}
  <div
    class="absolute bottom-6 w-full text-center z-30 transition-transform duration-700 group-hover:-translate-y-1 px-4"
  >
    <h2
      class="font-sans text-xs sm:text-sm md:text-base font-bold text-white tracking-[0.2em] sm:tracking-[0.4em] uppercase drop-shadow-[0_4px_10px_rgba(0,0,0,1)] truncate"
    >
      Code Source Universel
    </h2>
    <div
      class="text-[0.55rem] sm:text-[0.6rem] md:text-[0.65rem] text-emerald-400/80 tracking-[0.1em] sm:tracking-[0.3em] mt-2 uppercase font-mono"
    >
      ALGORITHM.GEOMANCY(256) :: INIT
    </div>
  </div>

  {/* Décorations de coin */}
  <div
    class="absolute top-4 left-4 font-mono text-[0.55rem] sm:text-[0.625rem] text-emerald-500/50 tracking-[0.2em] sm:tracking-[0.3em] uppercase select-none pointer-events-none"
  >
    ODU: ACTIVE
  </div>
  <div
    class="absolute bottom-4 right-4 font-mono text-[0.55rem] sm:text-[0.625rem] text-emerald-400/50 tracking-[0.2em] sm:tracking-[0.3em] uppercase animate-pulse-slow select-none flex items-center gap-1.5 sm:gap-2 pointer-events-none"
  >
    <span
      class="w-1 h-1 sm:w-1.5 sm:h-1.5 bg-emerald-500 rounded-full animate-ping"
    ></span>
    <span class="hidden sm:inline">MINDOGUESITO_SYNC</span>
    <span class="sm:hidden">SYNC</span>
  </div>
</div>

<style>
  /* --- Animations 100% CSS --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseGlow {
    0%,
    100% {
      opacity: 0.8;
      box-shadow: 0 0 10px #047857;
    }
    50% {
      opacity: 1;
      box-shadow:
        0 0 20px #34d399,
        0 0 40px rgba(52, 211, 153, 0.4);
    }
  }
  .animate-pulse-glow {
    animation: pulseGlow 2.5s infinite alternate ease-in-out;
  }

  @keyframes rain {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    to {
      transform: translateY(
        40rem
      ); /* Adapté pour toujours couvrir la hauteur du composant */
      opacity: 0;
    }
  }
  .animate-rain-slow {
    animation: rain 8s linear infinite;
  }
  .animate-rain-medium {
    animation: rain 5s linear infinite;
  }
  .animate-rain-fast {
    animation: rain 3.5s linear infinite;
  }

  @keyframes pulseSlow {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }
  .animate-pulse-slow {
    animation: pulseSlow 3s infinite alternate;
  }
</style>
