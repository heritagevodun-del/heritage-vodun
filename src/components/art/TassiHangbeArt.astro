---
// src/components/art/TassiHangbeArt.astro
// Un CSS Art premium représentant la puissance militaire et royale de Tassi Hangbé.
// Optimisé Tailwind v4 - Thème Sombre & Or
---

<div
  class="w-full h-[350px] bg-[radial-gradient(circle_at_center,#1a0505_0%,#050505_100%)] flex justify-center items-center rounded-xl overflow-hidden relative border border-[#d4af37]/10 shadow-[inset_0_0_50px_rgba(0,0,0,0.8)] opacity-0 animate-fade-up"
  aria-hidden="true"
>
  <div class="relative w-[200px] h-[200px] flex justify-center items-center">
    {/* LE HALO : Respiration de la mémoire */}
    <div
      class="absolute w-[150%] h-[150%] rounded-full bg-[radial-gradient(circle,rgba(139,0,0,0.2)_0%,transparent_70%)] animate-pulse-halo"
    >
    </div>

    {/* LE BOUCLIER */}
    <div
      class="relative w-[120px] h-[140px] bg-gradient-to-br from-[#1a1a1a] to-[#0a0a0a] [clip-path:polygon(50%_0%,100%_20%,100%_70%,50%_100%,0%_70%,0%_20%)] flex flex-col items-center justify-center shadow-[0_0_30px_rgba(212,175,55,0.2)] z-10 overflow-hidden"
    >
      {/* Reflet interne du bouclier */}
      <div
        class="absolute inset-0 bg-gradient-to-b from-[#d4af37]/10 to-transparent pointer-events-none"
      >
      </div>

      {/* LES LANCES (Croisées) */}
      <div
        class="absolute w-1 h-[180px] bg-gradient-to-b from-[#a0a0a0] to-[#404040] z-0 rotate-45"
      >
        {/* Pointe de la lance */}
        <div
          class="absolute -top-2.5 -left-[3px] w-2.5 h-5 bg-[#d4af37] [clip-path:polygon(50%_0%,100%_100%,50%_80%,0%_100%)]"
        >
        </div>
      </div>

      <div
        class="absolute w-1 h-[180px] bg-gradient-to-b from-[#a0a0a0] to-[#404040] z-0 -rotate-45"
      >
        {/* Pointe de la lance */}
        <div
          class="absolute -top-2.5 -left-[3px] w-2.5 h-5 bg-[#d4af37] [clip-path:polygon(50%_0%,100%_100%,50%_80%,0%_100%)]"
        >
        </div>
      </div>

      {/* LA COURONNE */}
      <div class="absolute top-[25px] w-[60px] h-[40px] z-20">
        <div
          class="absolute bottom-[5px] left-[2px] w-[16px] h-[20px] bg-gradient-to-t from-[#d4af37] to-[#ffdf73] [clip-path:polygon(50%_0%,100%_100%,0%_100%)] -rotate-15"
        >
        </div>
        <div
          class="absolute bottom-[5px] left-[22px] w-[16px] h-[30px] bg-gradient-to-t from-[#d4af37] to-[#ffdf73] [clip-path:polygon(50%_0%,100%_100%,0%_100%)]"
        >
        </div>
        <div
          class="absolute bottom-[5px] right-[2px] w-[16px] h-[20px] bg-gradient-to-t from-[#d4af37] to-[#ffdf73] [clip-path:polygon(50%_0%,100%_100%,0%_100%)] rotate-15"
        >
        </div>
        <div
          class="absolute bottom-0 w-full h-[8px] bg-gradient-to-r from-[#b8860b] via-[#d4af37] to-[#b8860b] rounded shadow-[0_2px_5px_rgba(0,0,0,0.8)]"
        >
        </div>
      </div>

      {/* L'ŒIL (L'esprit de Tassi Hangbé) */}
      <div
        class="absolute bottom-[35px] w-[30px] h-[15px] bg-[#0a0a0a] border-2 border-[#d4af37] rounded-[50%_50%_50%_50%/100%_100%_0%_0%] rotate-180 flex justify-center items-start pt-[2px] z-20 shadow-[0_0_15px_rgba(139,0,0,0.8)]"
      >
        <div
          class="w-[6px] h-[6px] bg-[#ff2a2a] rounded-full shadow-[0_0_8px_#ff0000] animate-eye-glow"
        >
        </div>
      </div>
    </div>

    {/* PARTICULES (Embers) */}
    <div
      class="absolute w-1 h-1 bg-[#ffdf73] rounded-full blur-[1px] opacity-0 animate-float-up bottom-[-10px] left-[30%] [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute w-1 h-1 bg-[#ffdf73] rounded-full blur-[1px] opacity-0 animate-float-up bottom-[-20px] right-[20%] [animation-duration:4s] [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute w-1 h-1 bg-[#ffdf73] rounded-full blur-[1px] opacity-0 animate-float-up bottom-[-5px] left-[60%] [animation-duration:3.5s] [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes pulseHalo {
    0% {
      transform: scale(0.9);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.1);
      opacity: 0.8;
    }
  }
  .animate-pulse-halo {
    animation: pulseHalo 4s ease-in-out infinite alternate;
  }

  @keyframes eyeGlow {
    0% {
      transform: scale(1);
      box-shadow: 0 0 5px #ff0000;
    }
    100% {
      transform: scale(1.3);
      box-shadow: 0 0 15px #ff4d4d;
    }
  }
  .animate-eye-glow {
    animation: eyeGlow 3s infinite alternate;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(-100px) scale(0);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 3s linear infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
