---
/*
  TassiHangbeArt.astro - CSS Art
  Allégorie de Tassi Hangbé : Les Machettes Croisées des Mino et la Couronne de Sang.
  Design : Militaire / Acier et Or (100% CSS, Zéro JS)
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-96 md:h-[32rem] bg-[#030101] rounded-2xl overflow-hidden border border-red-950/50 shadow-[0_25px_60px_rgba(0,0,0,0.95)] flex items-center justify-center group opacity-0 animate-fade-up select-none"
>
  {/* 1. ATMOSPHÈRE MARTIALE (Rouge Sang et Obscurité) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(153,27,27,0.2)_0%,#030101_70%)] transition-colors duration-1000 group-hover:bg-[radial-gradient(circle_at_center,rgba(220,38,38,0.3)_0%,#030101_70%)]"
  >
  </div>
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.05%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* 2. LE HALO DE GUERRE (Aura derrière les armes) */}
  <div
    class="absolute w-[200px] h-[200px] md:w-[280px] md:h-[280px] rounded-full bg-red-600/10 blur-2xl animate-pulse-aura z-10"
  >
  </div>

  {/* 3. LA COURONNE SOUVERAINE DE DANXOMÈ */}
  <div
    class="absolute top-12 md:top-16 z-40 flex flex-col items-center transition-transform duration-1000 group-hover:-translate-y-3"
  >
    {/* Éclat divin derrière la couronne */}
    <div
      class="absolute -top-4 w-20 h-20 bg-amber-500/20 blur-xl rounded-full animate-pulse"
    >
    </div>

    <div
      class="w-24 md:w-32 h-14 md:h-16 bg-gradient-to-b from-yellow-300 via-amber-500 to-amber-900 shadow-[0_15px_30px_rgba(0,0,0,0.9)] relative"
      style="clip-path: polygon(0% 0%, 25% 40%, 50% -10%, 75% 40%, 100% 0%, 90% 100%, 10% 100%);"
    >
      {/* Joyau Central (Rubis / Sang) */}
      <div
        class="absolute bottom-2 left-1/2 -translate-x-1/2 w-3 h-4 bg-red-600 rounded-full shadow-[0_0_10px_#dc2626] border border-red-400"
      >
      </div>
    </div>
    {/* Base de la couronne */}
    <div
      class="w-20 md:w-28 h-2 bg-gradient-to-r from-amber-900 via-amber-400 to-amber-900 rounded-b-sm shadow-xl -mt-1"
    >
    </div>
  </div>

  {/* 4. LES MACHETTES DES MINO (Lames Dahoméennes massives) */}
  <div
    class="relative w-full h-full flex items-center justify-center z-20 mt-8"
  >
    {/* MACHETTE GAUCHE (Tranchant vers l'extérieur) */}
    <div
      class="absolute w-12 md:w-16 h-[260px] md:h-[320px] flex flex-col items-center rotate-45 transform origin-center transition-transform duration-700 group-hover:rotate-[48deg] shadow-[0_10px_20px_rgba(0,0,0,0.5)]"
    >
      {/* La Lame Incurvée */}
      <div
        class="w-10 md:w-12 h-[180px] md:h-[220px] bg-gradient-to-b from-white via-stone-400 to-[#111] rounded-tl-[100%] rounded-tr-md rounded-b-md border-l-[3px] md:border-l-[4px] border-white/80 shadow-[0_0_15px_rgba(255,255,255,0.2)] relative overflow-hidden z-20"
      >
        {/* Reflet sur le fil de la lame */}
        <div
          class="absolute inset-y-0 left-0 w-1/2 bg-gradient-to-r from-white/30 to-transparent"
        >
        </div>
      </div>
      {/* La Garde (Laiton/Or) */}
      <div
        class="w-16 md:w-20 h-3 md:h-4 bg-gradient-to-r from-amber-700 via-amber-400 to-amber-700 rounded-sm shadow-md z-30 -mt-2"
      >
      </div>
      {/* Le Manche (Bois noirci / Cuir) */}
      <div
        class="w-5 md:w-6 h-16 md:h-20 bg-gradient-to-b from-[#111] to-[#222] border-x border-stone-800 z-10"
      >
      </div>
      {/* Le Pommeau */}
      <div
        class="w-8 md:w-10 h-3 bg-stone-700 rounded-b-md border border-stone-500 shadow-md"
      >
      </div>
    </div>

    {/* MACHETTE DROITE (Tranchant vers l'extérieur) */}
    <div
      class="absolute w-12 md:w-16 h-[260px] md:h-[320px] flex flex-col items-center -rotate-45 transform origin-center transition-transform duration-700 group-hover:-rotate-[48deg] shadow-[0_10px_20px_rgba(0,0,0,0.5)]"
    >
      {/* La Lame Incurvée */}
      <div
        class="w-10 md:w-12 h-[180px] md:h-[220px] bg-gradient-to-b from-white via-stone-400 to-[#111] rounded-tr-[100%] rounded-tl-md rounded-b-md border-r-[3px] md:border-r-[4px] border-white/80 shadow-[0_0_15px_rgba(255,255,255,0.2)] relative overflow-hidden z-20"
      >
        {/* Reflet sur le fil de la lame */}
        <div
          class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-white/30 to-transparent"
        >
        </div>
      </div>
      {/* La Garde */}
      <div
        class="w-16 md:w-20 h-3 md:h-4 bg-gradient-to-r from-amber-700 via-amber-400 to-amber-700 rounded-sm shadow-md z-30 -mt-2"
      >
      </div>
      {/* Le Manche */}
      <div
        class="w-5 md:w-6 h-16 md:h-20 bg-gradient-to-b from-[#111] to-[#222] border-x border-stone-800 z-10"
      >
      </div>
      {/* Le Pommeau */}
      <div
        class="w-8 md:w-10 h-3 bg-stone-700 rounded-b-md border border-stone-500 shadow-md"
      >
      </div>
    </div>

    {/* POINT D'INTERSECTION (Le Sceau de Fer) */}
    <div
      class="absolute z-40 w-8 h-8 md:w-10 md:h-10 bg-stone-900 rounded-full border-2 border-amber-500 shadow-[0_5px_15px_rgba(0,0,0,0.9)] flex items-center justify-center"
    >
      <div
        class="w-3 h-3 bg-red-600 rounded-full shadow-[0_0_10px_#ef4444] animate-pulse"
      >
      </div>
    </div>
  </div>

  {/* 5. GOUTTES DE SANG / ÉNERGIE (Tombant des lames) */}
  <div class="absolute inset-0 z-25 pointer-events-none overflow-hidden">
    <div
      class="absolute top-[40%] left-[35%] w-1.5 h-1.5 bg-red-500 rounded-full shadow-[0_0_8px_#dc2626] animate-drip-blood opacity-0"
    >
    </div>
    <div
      class="absolute top-[50%] right-[35%] w-2 h-2 bg-red-600 rounded-full shadow-[0_0_12px_#b91c1c] animate-drip-blood opacity-0 [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute top-[60%] left-[50%] w-1 h-1 bg-red-400 rounded-full shadow-[0_0_8px_#ef4444] animate-drip-blood opacity-0 [animation-delay:0.8s]"
    >
    </div>
  </div>

  {/* 6. TYPOGRAPHIE MILITAIRE HUD */}
  <div
    class="absolute top-6 left-6 font-mono text-[0.6rem] md:text-xs text-red-500/60 tracking-[0.2em] uppercase z-40"
  >
    <span
      class="block text-white/90 drop-shadow-[0_0_5px_rgba(255,255,255,0.5)]"
      >LEGION_MINO</span
    >
  </div>

  <div
    class="absolute bottom-6 right-6 font-mono text-[0.6rem] md:text-xs text-amber-500/50 tracking-[0.2em] uppercase text-right z-40 flex items-center gap-2"
  >
    <div class="flex flex-col gap-1 items-end">
      <span
        >COMMANDEMENT DE LA REINE: <span
          class="text-white/80 animate-flicker-text">TASSI_HANGBE</span
        ></span
      >
    </div>
    <span
      class="w-1.5 h-1.5 bg-red-600 rounded-full shadow-[0_0_8px_#ef4444] animate-ping"
    ></span>
  </div>

  {/* 7. TYPOGRAPHIE D'ARRIÈRE-PLAN (Majesté de la Reine) */}
  <div
    class="absolute inset-x-0 top-[25%] text-center pointer-events-none z-0 transition-transform duration-1000 group-hover:scale-105"
  >
    <span
      class="font-serif text-7xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-b from-red-900/30 to-transparent tracking-[0.1em] uppercase"
      >HANGBE</span
    >
  </div>
</div>

<style>
  /* --- Apparition Générale --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* --- Pulsation de l'Aura Sanguine --- */
  @keyframes pulseAura {
    0%,
    100% {
      opacity: 0.4;
      transform: scale(0.9);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
      filter: brightness(1.2);
    }
  }
  .animate-pulse-aura {
    animation: pulseAura 4s infinite alternate ease-in-out;
  }

  /* --- Chute d'Énergie / Sang (Gravité) --- */
  @keyframes dripBlood {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    80% {
      transform: translateY(120px) scale(0.6);
      opacity: 1;
    }
    100% {
      transform: translateY(150px) scale(0);
      opacity: 0;
    }
  }
  .animate-drip-blood {
    animation: dripBlood 3s infinite cubic-bezier(0.5, 0, 1, 1);
  }

  /* --- Scintillement du Statut --- */
  @keyframes flickerText {
    0%,
    100% {
      opacity: 0.8;
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 5px #dc2626);
    }
  }
  .animate-flicker-text {
    animation: flickerText 1s infinite alternate;
  }
</style>
