---
/*
  TofaLossoSaArt.astro - CSS Art
  Représente le plateau du Fâ, le signe Losso Sa, les noix de palme et le bec en métal.
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2d241e_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-[#d4af37]/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-center">
    {/* Le Plateau de Divination (Opon Ifa) */}
    <div
      class="absolute w-[180px] h-[180px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-full border-[8px] border-[#2a1a14] shadow-[inset_0_0_20px_rgba(0,0,0,0.8),0_10px_20px_rgba(0,0,0,0.5)] flex justify-center items-center animate-mystic-spin z-10"
    >
      {/* La poudre sacrée (Iyerosun) au centre */}
      <div
        class="absolute w-[120px] h-[120px] bg-[#d7ccc8]/10 rounded-full blur-[5px]"
      >
      </div>

      {/* Les traces du signe Losso Sa (Binaire) */}
      <div class="flex flex-col gap-2 z-20">
        <div class="flex justify-center gap-[15px]">
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
        </div>
        <div class="flex justify-center gap-[15px]">
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
        </div>
        <div class="flex justify-center gap-[15px]">
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
        </div>
        <div class="flex justify-center gap-[15px]">
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
          <span
            class="w-[15px] h-[5px] bg-[#d7ccc8] rounded-[2px] shadow-[0_0_8px_rgba(215,204,200,0.6)] animate-glow-pulse"
          ></span>
        </div>
      </div>
    </div>

    {/* Le "Bec en Métal" de la prophétie */}
    <div
      class="absolute -bottom-[10px] right-[20px] w-0 h-0 border-l-[30px] border-r-[20px] border-b-[90px] border-l-transparent border-r-transparent border-b-[#455a64] rotate-[35deg] drop-shadow-[-5px_5px_10px_rgba(0,0,0,0.7)] z-20 animate-strike"
    >
      {/* Brillance du métal */}
      <div
        class="absolute top-[10px] -left-[10px] w-[4px] h-[60px] bg-[#90a4ae] rotate-[5deg] opacity-80"
      >
      </div>
    </div>

    {/* Les Noix de Palme sacrées (Ikin) */}
    <div
      class="absolute w-[16px] h-[20px] bg-[#111] rounded-[40%_60%_50%_50%] shadow-[inset_-3px_-3px_5px_rgba(255,255,255,0.2),0_5px_10px_rgba(0,0,0,0.6)] z-30 top-[20px] left-[80px] rotate-[15deg]"
    >
    </div>
    <div
      class="absolute w-[16px] h-[20px] bg-[#111] rounded-[40%_60%_50%_50%] shadow-[inset_-3px_-3px_5px_rgba(255,255,255,0.2),0_5px_10px_rgba(0,0,0,0.6)] z-30 top-[60px] right-[10px] -rotate-[45deg]"
    >
    </div>
    <div
      class="absolute w-[16px] h-[20px] bg-[#111] rounded-[40%_60%_50%_50%] shadow-[inset_-3px_-3px_5px_rgba(255,255,255,0.2),0_5px_10px_rgba(0,0,0,0.6)] z-30 bottom-[40px] left-[15px] rotate-[70deg]"
    >
    </div>
    <div
      class="absolute w-[16px] h-[20px] bg-[#111] rounded-[40%_60%_50%_50%] shadow-[inset_-3px_-3px_5px_rgba(255,255,255,0.2),0_5px_10px_rgba(0,0,0,0.6)] z-30 bottom-[10px] right-[60px] -rotate-[20deg]"
    >
    </div>
    <div
      class="absolute w-[16px] h-[20px] bg-[#111] rounded-[40%_60%_50%_50%] shadow-[inset_-3px_-3px_5px_rgba(255,255,255,0.2),0_5px_10px_rgba(0,0,0,0.6)] z-30 top-[110px] -left-[10px] rotate-[85deg]"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes mystic-spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  .animate-mystic-spin {
    animation: mystic-spin 20s linear infinite;
  }

  @keyframes glow-pulse {
    0% {
      opacity: 0.6;
      box-shadow: 0 0 5px rgba(215, 204, 200, 0.3);
    }
    100% {
      opacity: 1;
      box-shadow: 0 0 15px rgba(215, 204, 200, 0.8);
    }
  }
  .animate-glow-pulse {
    animation: glow-pulse 3s infinite alternate;
  }

  @keyframes strike {
    0%,
    100% {
      transform: rotate(35deg) translate(0, 0);
    }
    50% {
      transform: rotate(35deg) translate(-10px, -10px);
    }
  }
  .animate-strike {
    animation: strike 4s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
