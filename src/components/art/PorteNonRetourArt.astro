---
/*
  PorteNonRetourArt.astro - CSS Art
  Représente l&apos;arche monumentale de Djègbadji face à l&apos;océan Atlantique.
  Optimisé Tailwind v4 - Thème Nuit Éternelle
*/
---

<div
  class="w-full h-80 bg-gradient-to-b from-[#2a2025] to-dark-bg flex justify-center items-end relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-white/5 opacity-0 animate-fade-up"
>
  {/* L'Océan Atlantique en arrière-plan */}
  <div
    class="absolute bottom-0 w-full h-[140px] bg-[#0f3c5b] z-0 overflow-hidden"
  >
    <div
      class="absolute top-[20px] -left-1/2 w-[200%] h-full bg-[#216a99]/40 rounded-[50%] animate-wave-roll [animation-duration:12s]"
    >
    </div>
    <div
      class="absolute top-[40px] -left-[30%] w-[200%] h-full bg-[#216a99]/20 rounded-[50%] animate-wave-roll-reverse [animation-duration:8s]"
    >
    </div>
    <div
      class="absolute top-[60px] -left-[70%] w-[200%] h-full bg-[#0f3c5b]/80 rounded-[50%] animate-wave-roll [animation-duration:15s]"
    >
    </div>
  </div>

  <div class="relative w-[300px] h-[250px] flex justify-center items-end z-10">
    {/* La plage / La terre de Ouidah */}
    <div
      class="absolute -bottom-[20px] w-[400px] h-[60px] bg-[#dcb383]/80 rounded-[50%] shadow-[inset_0_10px_20px_rgba(0,0,0,0.4)] z-10"
    >
    </div>

    {/* L'Arche de la Porte du Non-Retour */}
    <div
      class="relative w-[180px] h-[160px] z-20 flex justify-between items-end"
    >
      {/* Fronton (Linteau) */}
      <div
        class="absolute top-0 -left-[10px] w-[200px] h-[40px] bg-gradient-to-b from-[#d4af37] to-[#8a3a19] rounded-[4px] shadow-[0_10px_15px_rgba(0,0,0,0.6)] flex justify-center items-center z-30"
      >
        {/* Décors en bas-relief (Frise) */}
        <div
          class="w-[160px] h-[15px] bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.3)_0px,rgba(0,0,0,0.3)_5px,transparent_5px,transparent_10px)]"
        >
        </div>
      </div>

      {/* Pilier Gauche */}
      <div
        class="w-[30px] h-[140px] bg-gradient-to-r from-[#8a3a19] to-[#b75d32] rounded-[2px_2px_0_0] shadow-[5px_0_15px_rgba(0,0,0,0.5)] flex flex-col justify-evenly items-center pt-[20px]"
      >
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
      </div>

      {/* Pilier Droit */}
      <div
        class="w-[30px] h-[140px] bg-gradient-to-r from-[#8a3a19] to-[#b75d32] rounded-[2px_2px_0_0] shadow-[5px_0_15px_rgba(0,0,0,0.5)] flex flex-col justify-evenly items-center pt-[20px]"
      >
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
        <div
          class="w-[20px] h-[20px] bg-black/20 rounded-[2px] shadow-[inset_1px_1px_3px_rgba(0,0,0,0.5),1px_1px_1px_rgba(255,255,255,0.1)]"
        >
        </div>
      </div>
    </div>

    {/* Esprits des Ancêtres (Égoungoun / Présence spirituelle) */}
    <div
      class="absolute bottom-[20px] left-[20px] w-[15px] h-[40px] bg-white/10 rounded-[50%_50%_10px_10px] shadow-[0_0_10px_rgba(255,255,255,0.2)] z-30 animate-spirit-hover [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute bottom-[20px] right-[20px] w-[15px] h-[40px] bg-white/10 rounded-[50%_50%_10px_10px] shadow-[0_0_10px_rgba(255,255,255,0.2)] z-30 animate-spirit-hover [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes wave-roll {
    100% {
      transform: rotate(360deg);
    }
  }
  @keyframes wave-roll-reverse {
    100% {
      transform: rotate(-360deg);
    }
  }
  .animate-wave-roll {
    animation: wave-roll 10s infinite linear;
  }
  .animate-wave-roll-reverse {
    animation: wave-roll-reverse 10s infinite linear;
  }

  @keyframes spirit-hover {
    0% {
      transform: translateY(0);
      opacity: 0.5;
    }
    100% {
      transform: translateY(-10px);
      opacity: 0.8;
    }
  }
  .animate-spirit-hover {
    animation: spirit-hover 4s ease-in-out infinite alternate;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1.2s ease forwards;
  }
</style>
