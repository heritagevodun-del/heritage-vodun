---
// Composant CSS Art : Miroir des Mondes (Vodun vs Vaudou)
---

<div class="visual-container">
  <div class="world-mirror-art">
    <div class="visible-world"></div>
    <div class="axis-mundi"></div>
    <div class="invisible-world"></div>
    <div class="energy-particles"></div>
  </div>
</div>

<style>
  .visual-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 350px;
    background: linear-gradient(180deg, #111827 0%, #030712 100%);
    border-radius: 12px;
    margin-bottom: 3rem;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(218, 165, 32, 0.15);
  }
  .world-mirror-art {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    animation: cosmicBreath 8s ease-in-out infinite;
  }
  .visible-world {
    width: 120px;
    height: 60px;
    background: radial-gradient(ellipse at bottom, #daa520 0%, transparent 70%);
    border-top-left-radius: 120px;
    border-top-right-radius: 120px;
    opacity: 0.9;
    box-shadow: 0 -10px 30px rgba(218, 165, 32, 0.2);
  }
  .axis-mundi {
    width: 100%;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #daa520 50%,
      transparent 100%
    );
    position: relative;
    z-index: 10;
    box-shadow: 0 0 15px #daa520;
  }
  .invisible-world {
    width: 120px;
    height: 60px;
    background: radial-gradient(ellipse at top, #3b82f6 0%, transparent 70%);
    border-bottom-left-radius: 120px;
    border-bottom-right-radius: 120px;
    opacity: 0.6;
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
  }
  @keyframes cosmicBreath {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.05);
      opacity: 1;
    }
  }
</style>
