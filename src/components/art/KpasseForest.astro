---
// KpasseForest.astro
// Visuel UI HTML/CSS pur : Ambiance "Magazine" pour la Forêt Sacrée
---

<div
  class="relative w-full h-[32rem] rounded-2xl overflow-hidden mb-12 shadow-2xl border border-emerald-900/50 group"
>
  {/* Arrière-plan : Dégradés évoquant la profondeur de la forêt (CSS pur) */}
  <div
    class="absolute inset-0 bg-gradient-to-br from-emerald-950 via-gray-900 to-black z-0"
  >
  </div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(6,78,59,0.4),transparent_60%)] z-0"
  >
  </div>

  {/* Lignes verticales stylisées (Troncs d'arbres abstraits) */}
  <div class="absolute inset-0 flex justify-around opacity-10 z-0">
    <div class="w-px h-full bg-emerald-500"></div>
    <div class="w-px h-full bg-emerald-400"></div>
    <div class="w-px h-full bg-emerald-600"></div>
    <div class="w-px h-full bg-emerald-300"></div>
    <div class="w-px h-full bg-emerald-500"></div>
  </div>

  {/* Contenu principal de l'UI (Glassmorphism) */}
  <div
    class="relative z-10 w-full h-full flex flex-col justify-center items-center p-8"
  >
    {/* Cadre central */}
    <div
      class="relative w-full max-w-2xl backdrop-blur-md bg-black/40 border border-emerald-500/30 p-10 md:p-14 rounded-xl text-center transform transition-transform duration-700 group-hover:scale-[1.02] shadow-[0_0_50px_rgba(6,78,59,0.3)]"
    >
      {/* Ornement haut */}
      <div class="flex justify-center mb-6">
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-gold opacity-80"
        >
          <path d="M12 2v20"></path>
          <path d="M12 10a6 6 0 0 0-6-6h12a6 6 0 0 0-6 6Z"></path>
          <path d="M12 14a6 6 0 0 1-6 6h12a6 6 0 0 1-6-6Z"></path>
          <path d="M12 2v10"></path>
        </svg>
      </div>

      {/* Typographie Hero */}
      <h2
        class="font-serif text-3xl md:text-5xl font-bold text-white mb-4 tracking-wide uppercase leading-tight"
      >
        L&apos;Héritage de <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-gold"
          >Kpassè</span
        >
      </h2>

      <p
        class="font-sans text-emerald-100/70 text-sm md:text-base tracking-widest uppercase mb-8"
      >
        La racine de Ouidah • L&apos;esprit dans l&apos;arbre
      </p>

      {/* Ligne séparatrice */}
      <div
        class="w-24 h-px bg-gradient-to-r from-transparent via-gold/50 to-transparent mx-auto mb-8"
      >
      </div>

      {/* Citation élégante */}
      <p class="font-serif italic text-lg md:text-xl text-gray-300">
        "Où l&apos;homme s&apos;efface, le sacré s&apos;enracine."
      </p>
    </div>
  </div>

  {/* Effet de lueur en survol */}
  <div
    class="absolute -top-24 -left-24 w-48 h-48 bg-emerald-500/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-1000 z-0"
  >
  </div>
</div>
