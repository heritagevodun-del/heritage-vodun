---
/*
  BocheArt.astro - CSS Art
  Allégorie du Bochio (Boche) : Le Gardien Protecteur et Guérisseur.
  Détruit le mythe hollywoodien. Restaure l'ancrage, le bois sculpté et la charge sacrée.
  Design : Tech-Sombre / Bois Brut / Émanation Dorée (100% CSS)
*/
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#030101] rounded-3xl overflow-hidden border border-amber-950/30 shadow-[0_30px_60px_rgba(245,158,11,0.1)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  {/* 1. LE SANCTUAIRE (Ambiance Terre/Nuit) */}
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#1a0803] via-[#0a0301] to-[#030101] z-0"
  >
  </div>

  {/* Texture tellurique (Bois/Terre) */}
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.08%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* 2. TYPOGRAPHIE MONUMENTALE (En arrière-plan - z-10) */}
  <div
    class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#fce79a]/15 via-[#d4af37]/5 to-transparent uppercase tracking-[0.25em] drop-shadow-[0_2px_10px_rgba(0,0,0,0.9)] w-full text-center transition-transform duration-1000 group-hover:scale-105"
    >
      BOCHIO
    </h1>
  </div>

  {/* 3. L'AUTEL TERRESTRE (Sol d'ancrage - z-15) */}
  <div
    class="absolute bottom-10 md:bottom-16 flex flex-col items-center justify-center z-15 pointer-events-none"
  >
    {/* Base mystique (Le socle d'énergie) */}
    <div
      class="w-48 md:w-64 h-12 bg-amber-700/20 blur-[25px] rounded-[100%] animate-pulse-slow"
    >
    </div>
    <div
      class="absolute w-32 md:w-48 h-6 bg-[#d4af37]/40 blur-[15px] rounded-[100%] shadow-[0_0_30px_#f59e0b]"
    >
    </div>
    <div
      class="absolute w-64 md:w-96 h-1 bg-gradient-to-r from-transparent via-amber-900/50 to-transparent blur-[2px]"
    >
    </div>
  </div>

  {/* 4. LE BOCHIO (La Statuette Sculptée - z-20) */}
  <div
    class="relative z-20 flex flex-col items-center justify-end h-[65%] mt-12 transition-transform duration-1000 group-hover:-translate-y-2"
  >
    {/* Aura de Guérison (Kaolin blanc et Or, irradiant de la statue) */}
    <div
      class="absolute top-1/4 w-40 h-64 bg-gradient-to-b from-white/10 via-amber-400/20 to-transparent blur-[30px] rounded-full animate-healing-breathe pointer-events-none"
    >
    </div>

    {/* LA TÊTE (Bois sculpté à la serpe) */}
    <div
      class="relative w-16 h-20 md:w-20 md:h-24 bg-gradient-to-br from-[#4a2511] via-[#2a1208] to-[#120703] shadow-[inset_-5px_-5px_15px_rgba(0,0,0,0.9),inset_2px_2px_5px_rgba(255,255,255,0.1)] z-30"
      style="clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 90% 100%, 10% 100%, 0% 30%);"
    >
      {/* Texture du bois brut */}
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(85deg,rgba(0,0,0,0.5),rgba(0,0,0,0.5)_2px,transparent_3px,transparent_6px)] opacity-60"
      >
      </div>

      {/* Traces de Kaolin (Argile sacrée blanche sur le visage) */}
      <div
        class="absolute top-[30%] left-1/2 -translate-x-1/2 w-8 h-4 bg-white/30 blur-[3px] rounded-full"
      >
      </div>
    </div>

    {/* LE COU (Cordes superposées) */}
    <div
      class="relative w-12 md:w-14 h-6 bg-[#2a1208] -mt-2 z-20 shadow-[inset_0_5px_10px_rgba(0,0,0,0.8)] flex flex-col justify-evenly"
    >
      <div
        class="w-full h-1 bg-[#d7ccc8] shadow-[0_2px_2px_rgba(0,0,0,0.8)] opacity-80"
      >
      </div>
      <div
        class="w-full h-1 bg-[#d7ccc8] shadow-[0_2px_2px_rgba(0,0,0,0.8)] opacity-80"
      >
      </div>
    </div>

    {/* LE CORPS (Le Monolithe Protecteur) */}
    <div
      class="relative w-24 h-40 md:w-32 md:h-52 bg-gradient-to-br from-[#3d1d0c] via-[#240e05] to-[#0a0301] shadow-[inset_-8px_-8px_20px_rgba(0,0,0,0.9),0_20px_30px_rgba(0,0,0,0.9)] -mt-2 z-10 overflow-hidden"
      style="clip-path: polygon(15% 0%, 85% 0%, 100% 100%, 0% 100%);"
    >
      {/* Texture du bois massif */}
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(88deg,rgba(0,0,0,0.6),rgba(0,0,0,0.6)_3px,transparent_4px,transparent_8px)] opacity-50"
      >
      </div>
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(to_bottom,rgba(0,0,0,0.4),rgba(0,0,0,0.4)_1px,transparent_2px,transparent_10px)] opacity-30"
      >
      </div>

      {/* LA CHARGE SACRÉE (Le Cœur / Le "Zon" de guérison) */}
      <div
        class="absolute top-[30%] left-1/2 -translate-x-1/2 w-8 h-10 md:w-10 md:h-14 bg-[#0a0301] shadow-[inset_0_0_10px_rgba(0,0,0,1)] flex items-center justify-center rounded-[50%_50%_40%_40%]"
      >
        <div
          class="w-3 h-5 bg-[#fce79a] blur-[2px] rounded-full shadow-[0_0_15px_#fde047,0_0_30px_#f59e0b] animate-core-beat"
        >
        </div>
      </div>

      {/* LES LIGATURES DE PROTECTION (Cordes croisées bloquant le mal) */}
      <div
        class="absolute top-[20%] -left-[10%] w-[120%] h-2 bg-[#bcaaa4] shadow-[0_3px_5px_rgba(0,0,0,0.9),inset_0_1px_1px_rgba(255,255,255,0.4)] rotate-[15deg]"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.4),rgba(0,0,0,0.4)_1px,transparent_2px,transparent_3px)]"
        >
        </div>
      </div>
      <div
        class="absolute top-[45%] -left-[10%] w-[120%] h-2.5 bg-[#a1887f] shadow-[0_3px_5px_rgba(0,0,0,0.9),inset_0_1px_1px_rgba(255,255,255,0.4)] -rotate-[10deg]"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.4),rgba(0,0,0,0.4)_1px,transparent_2px,transparent_3px)]"
        >
        </div>
      </div>
      <div
        class="absolute top-[70%] -left-[10%] w-[120%] h-2 bg-[#bcaaa4] shadow-[0_3px_5px_rgba(0,0,0,0.9),inset_0_1px_1px_rgba(255,255,255,0.4)] rotate-[5deg]"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.4),rgba(0,0,0,0.4)_1px,transparent_2px,transparent_3px)]"
        >
        </div>
      </div>
    </div>
  </div>

  {
    /* 5. ÉMANATIONS DE GUÉRISON (Particules pures montant vers le ciel - z-30) */
  }
  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-screen"
  >
    <div
      class="absolute bottom-[20%] left-[40%] w-2 h-2 bg-white blur-[1px] rounded-full shadow-[0_0_10px_#fff] animate-rise-glow [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute bottom-[25%] right-[42%] w-1.5 h-1.5 bg-[#fce79a] blur-[1px] rounded-full shadow-[0_0_10px_#f59e0b] animate-rise-glow [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[15%] left-[48%] w-1 h-1 bg-white rounded-full animate-rise-glow [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute bottom-[18%] right-[48%] w-2 h-2 bg-[#d4af37] blur-[1px] rounded-full animate-rise-glow [animation-delay:2.5s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- Apparition Générale --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* --- Respiration de l'Aura de Guérison --- */
  @keyframes healingBreathe {
    0%,
    100% {
      transform: scale(0.95);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.8;
      filter: brightness(1.2);
    }
  }
  .animate-healing-breathe {
    animation: healingBreathe 5s infinite alternate ease-in-out;
  }

  /* --- Pulsation du Cœur Sacré --- */
  @keyframes coreBeat {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(0.9);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
      filter: brightness(1.3);
    }
  }
  .animate-core-beat {
    animation: coreBeat 3s infinite alternate ease-in-out;
  }

  /* --- Pulsation de l'Autel --- */
  @keyframes pulseSlow {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.7;
    }
  }
  .animate-pulse-slow {
    animation: pulseSlow 4s infinite alternate ease-in-out;
  }

  /* --- Élévation des Particules Pures --- */
  @keyframes riseGlow {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(-200px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-rise-glow {
    animation: riseGlow 4s infinite ease-out;
  }
</style>
