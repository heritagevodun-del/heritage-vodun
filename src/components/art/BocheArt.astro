---
/*
  BocheArt.astro - CSS Art
  Représente la statuette protectrice authentique (Boche) irradiant la guérison, 
  loin du mythe hollywoodien de la poupée vaudou.
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2d241e_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-white/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-end">
    {/* Aura de guérison et de protection (Lumière dorée/blanche) */}
    <div
      class="absolute bottom-[30px] w-[160px] h-[200px] bg-[radial-gradient(ellipse,rgba(212,175,55,0.4)_0%,transparent_70%)] rounded-full animate-spirit-breathe z-10"
    >
    </div>

    {/* Le socle sacré */}
    <div
      class="absolute bottom-[20px] w-[120px] h-[15px] bg-gradient-to-r from-[#111] via-[#333] to-[#111] rounded-[5px] shadow-[0_10px_15px_rgba(0,0,0,0.8)] z-20"
    >
    </div>

    {/* La statuette Boche (Bois sculpté) */}
    <div
      class="absolute bottom-[35px] flex flex-col items-center z-30 animate-mystic-float group"
    >
      {/* Tête abstraite */}
      <div
        class="w-[40px] h-[50px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-[40%_40%_50%_50%] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.6)] -mb-1 z-40 transition-colors duration-500 group-hover:from-[#795548] group-hover:to-[#4e342e]"
      >
      </div>

      {/* Corps */}
      <div
        class="w-[35px] h-[90px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-[10px] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.6),0_5px_10px_rgba(0,0,0,0.5)] relative overflow-hidden transition-colors duration-500 group-hover:from-[#795548] group-hover:to-[#4e342e]"
      >
        {/* Cordes protectrices (Pour "lier" le mal) */}
        <div
          class="absolute w-[120%] h-[6px] bg-[#d7ccc8] -left-[10%] shadow-[0_2px_4px_rgba(0,0,0,0.5),inset_0_1px_2px_rgba(255,255,255,0.5)] top-[20px] rotate-[15deg]"
        >
        </div>
        <div
          class="absolute w-[120%] h-[6px] bg-[#d7ccc8] -left-[10%] shadow-[0_2px_4px_rgba(0,0,0,0.5),inset_0_1px_2px_rgba(255,255,255,0.5)] top-[45px] -rotate-[10deg]"
        >
        </div>
        <div
          class="absolute w-[120%] h-[6px] bg-[#d7ccc8] -left-[10%] shadow-[0_2px_4px_rgba(0,0,0,0.5),inset_0_1px_2px_rgba(255,255,255,0.5)] top-[70px] rotate-[5deg]"
        >
        </div>
      </div>
    </div>

    {/* Particules de lumière (Énergie bienveillante) */}
    <div
      class="absolute w-[6px] h-[6px] bg-[#fdfbf7] rounded-full shadow-[0_0_10px_#fdfbf7] z-40 animate-rise-glow opacity-0 bottom-[40px] left-[50px] [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute w-[6px] h-[6px] bg-[#fdfbf7] rounded-full shadow-[0_0_10px_#fdfbf7] z-40 animate-rise-glow opacity-0 bottom-[60px] right-[40px] [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute w-[6px] h-[6px] bg-[#fdfbf7] rounded-full shadow-[0_0_10px_#fdfbf7] z-40 animate-rise-glow opacity-0 bottom-[30px] left-[90px] [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  /* Animations complexes conservées en CSS */
  @keyframes spirit-breathe {
    0% {
      transform: scale(0.9);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.1);
      opacity: 1;
    }
  }
  .animate-spirit-breathe {
    animation: spirit-breathe 4s ease-in-out infinite alternate;
  }

  @keyframes mystic-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }
  .animate-mystic-float {
    animation: mystic-float 6s ease-in-out infinite;
  }

  @keyframes rise-glow {
    0% {
      transform: translateY(0) scale(0.5);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-50px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-rise-glow {
    animation: rise-glow 3s infinite ease-in;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
