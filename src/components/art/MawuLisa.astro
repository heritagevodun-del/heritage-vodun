---
// src/components/MawuLisaArt.astro - CSS Art
// Représente l&apos;équilibre cosmique entre Mawu (Lune/Mère) et Lisa (Soleil/Père).
// Optimisé Tailwind v4 - Thème Sombre
---

<div
  class="w-full h-[350px] bg-gradient-to-br from-[#050505] to-[#1a110e] rounded-xl mb-8 overflow-hidden shadow-[0_15px_40px_rgba(0,0,0,0.6)] flex justify-center items-center border border-white/5 opacity-0 animate-fade-up"
>
  {/* Art Mawu-Lisa : La dualité */}
  <div
    class="relative w-[200px] h-[200px] rounded-full bg-[conic-gradient(from_45deg,#fbbf24_0deg_180deg,#e2e8f0_180deg_360deg)] animate-spin-slow"
  >
    {/* Lisa (Le Soleil) */}
    <div
      class="absolute top-1/2 left-1/4 w-5 h-5 bg-[#fbbf24] rounded-full -translate-x-1/2 -translate-y-1/2 shadow-[0_0_15px_#fbbf24]"
    >
    </div>

    {/* Mawu (La Lune) */}
    <div
      class="absolute top-1/2 left-[75%] w-5 h-5 bg-[#e2e8f0] rounded-full -translate-x-1/2 -translate-y-1/2 shadow-[0_0_15px_#e2e8f0]"
    >
    </div>

    {/* Cercle cosmique intérieur */}
    <div
      class="absolute top-1/2 left-1/2 w-[190px] h-[190px] bg-transparent border-2 border-white/10 rounded-full -translate-x-1/2 -translate-y-1/2"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */

  /* L'animation native animate-spin de Tailwind est trop rapide (1s).
     Nous créons une rotation cosmique très lente. */
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
