---
// Composant CSS Art : Divinités Mawu-Lisa
// Ce composant est isolé, son CSS n'impactera pas le reste du site.
---

<div class="visual-container">
  <div class="mawu-lisa-art">
    <div class="lisa-sun"></div>
    <div class="mawu-moon"></div>
    <div class="cosmic-center"></div>
  </div>
</div>

<style>
  .visual-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 350px;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    border-radius: 12px;
    margin-bottom: 2rem;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }
  .mawu-lisa-art {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: conic-gradient(
      from 45deg,
      #fbbf24 0deg 180deg,
      #e2e8f0 180deg 360deg
    );
    animation: rotateSlowly 20s linear infinite;
  }
  .lisa-sun {
    position: absolute;
    top: 50%;
    left: 25%;
    width: 20px;
    height: 20px;
    background-color: #fbbf24;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 15px #fbbf24;
  }
  .mawu-moon {
    position: absolute;
    top: 50%;
    left: 75%;
    width: 20px;
    height: 20px;
    background-color: #e2e8f0;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 15px #e2e8f0;
  }
  .cosmic-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 190px;
    height: 190px;
    background-color: transparent;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  @keyframes rotateSlowly {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
</style>
