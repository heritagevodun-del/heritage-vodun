---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[36rem] bg-[#090a0f] rounded-3xl overflow-hidden border border-amber-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.9)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div class="absolute inset-0 z-0">
    <div
      class="absolute top-[10%] left-[15%] w-64 md:w-96 h-64 md:h-96 bg-red-900/10 blur-[60px] animate-pulse-chaos"
    >
    </div>
    <div
      class="absolute bottom-[10%] right-[15%] w-64 md:w-96 h-64 md:h-96 bg-indigo-900/10 blur-[60px] animate-pulse-chaos [animation-delay:2s]"
    >
    </div>

    <div
      class="absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(255,255,255,0.015)_3px,rgba(255,255,255,0.015)_4px)] z-0 mix-blend-screen animate-glitch-static"
    >
    </div>
  </div>

  <div
    class="relative z-10 w-72 md:w-[26rem] h-[24rem] md:h-[30rem] bg-gradient-to-t from-[#140d08] to-[#24170f] rounded-t-full border-[6px] md:border-[8px] border-[#d4af37]/90 shadow-[0_0_80px_rgba(217,119,6,0.3),inset_0_0_50px_rgba(0,0,0,0.9)] flex flex-col items-center justify-end overflow-hidden animate-portal-radiance"
  >
    <div
      class="absolute bottom-0 w-full h-[70%] bg-gradient-to-t from-amber-500/30 to-transparent"
    >
    </div>
    <div
      class="absolute top-0 w-full h-full bg-[radial-gradient(ellipse_at_top,rgba(212,175,55,0.15)_0%,transparent_70%)]"
    >
    </div>

    <div
      class="absolute inset-0 bg-[repeating-radial-gradient(circle_at_bottom_center,transparent,transparent_12px,rgba(212,175,55,0.06)_13px,rgba(212,175,55,0.06)_24px)] mix-blend-screen"
    >
    </div>

    <div
      class="relative flex flex-col items-center justify-end h-full w-full pb-8 md:pb-12 animate-float"
    >
      <div class="relative flex flex-col items-center z-20">
        <div
          class="w-1.5 md:w-2 h-8 md:h-10 bg-[#d4af37] shadow-[0_0_12px_#f59e0b]"
        >
        </div>

        <div
          class="w-24 md:w-32 h-6 md:h-8 -mt-1 flex justify-center items-end"
        >
          <div
            class="w-full h-full border-b-[8px] md:border-b-[10px] border-b-[#d4af37] border-x-[16px] md:border-x-[20px] border-x-transparent drop-shadow-[0_0_10px_rgba(217,119,6,0.8)]"
          >
          </div>
        </div>

        <div class="flex justify-between w-16 md:w-24 mt-1 z-10">
          <div
            class="w-1.5 h-8 md:h-12 bg-gradient-to-b from-[#d4af37] to-transparent"
          >
          </div>
          <div
            class="w-1.5 h-5 md:h-7 bg-gradient-to-b from-[#d4af37] to-transparent"
          >
          </div>
          <div
            class="w-1.5 h-10 md:h-14 bg-gradient-to-b from-[#d4af37] to-transparent"
          >
          </div>
          <div
            class="w-1.5 h-5 md:h-7 bg-gradient-to-b from-[#d4af37] to-transparent"
          >
          </div>
          <div
            class="w-1.5 h-8 md:h-12 bg-gradient-to-b from-[#d4af37] to-transparent"
          >
          </div>
        </div>

        <div
          class="absolute top-[20%] w-4 h-4 md:w-5 md:h-5 bg-[#fdfcf9] rounded-full shadow-[0_0_20px_#fff] border-2 border-[#d4af37] z-30"
        >
        </div>
      </div>

      <div
        class="w-2 md:w-2.5 h-36 md:h-48 bg-gradient-to-b from-[#d4af37] via-[#b45309] to-[#451a03] shadow-[0_0_20px_rgba(217,119,6,0.5)] z-10 -mt-2"
      >
      </div>

      <div
        class="w-20 md:w-28 h-5 md:h-6 bg-gradient-to-b from-[#d4af37] to-[#78350f] rounded-t-xl shadow-[0_10px_20px_rgba(0,0,0,1)] border-t-2 border-[#fdfcf9]/40 z-0 -mt-2"
      >
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-6 md:bottom-8 inset-x-0 flex flex-col items-center justify-center z-50 pointer-events-none"
  >
    <span
      class="font-sans text-xs md:text-sm font-bold text-amber-500/90 tracking-[0.6em] uppercase drop-shadow-[0_2px_8px_rgba(0,0,0,0.9)]"
    >
      VODUN YEHOUE
    </span>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseChaos {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(0.9) translate(-10px, 10px);
    }
    50% {
      opacity: 0.6;
      transform: scale(1.1) translate(10px, -10px);
    }
  }
  .animate-pulse-chaos {
    animation: pulseChaos 8s ease-in-out infinite alternate;
  }

  @keyframes glitchStatic {
    0%,
    100% {
      opacity: 0.4;
      transform: translateY(0);
    }
    50% {
      opacity: 0.7;
      transform: translateY(2px);
    }
  }
  .animate-glitch-static {
    animation: glitchStatic 0.2s linear infinite;
  }

  @keyframes portalRadiance {
    0%,
    100% {
      box-shadow:
        0 0 60px rgba(217, 119, 6, 0.2),
        inset 0 0 40px rgba(0, 0, 0, 0.9);
      border-color: rgba(212, 175, 55, 0.7);
    }
    50% {
      box-shadow:
        0 0 90px rgba(217, 119, 6, 0.5),
        inset 0 0 60px rgba(0, 0, 0, 0.7);
      border-color: rgba(212, 175, 55, 1);
    }
  }
  .animate-portal-radiance {
    animation: portalRadiance 6s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
