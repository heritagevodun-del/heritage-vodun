---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[34rem] md:h-[42rem] bg-[#f8f5e9] rounded-3xl overflow-hidden border-[12px] border-[#5d4037] shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-60"
    style="background-image: radial-gradient(circle, transparent 60%, rgba(0, 0, 0, 0.15) 100%), url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E&quot;);"
  >
  </div>

  <div
    class="absolute inset-0 z-0 opacity-90 overflow-hidden pointer-events-none"
  >
    <div
      class="absolute top-12 right-[15%] md:right-[25%] w-24 h-24 md:w-[130px] md:h-[130px] rounded-full border-[5px] border-[#121212] bg-[radial-gradient(circle,#f8f5e9_15%,transparent_15%),radial-gradient(circle,#121212_15%,#121212_25%,transparent_25%),radial-gradient(circle,#f8f5e9_25%,#f8f5e9_35%,transparent_35%),radial-gradient(circle,#121212_35%,#121212_45%,transparent_45%),radial-gradient(circle,#f8f5e9_45%,#f8f5e9_55%,transparent_55%),radial-gradient(circle,#121212_55%,#121212_65%,transparent_65%)] animate-spin-slow"
    >
    </div>
    <div
      class="absolute bottom-24 right-4 md:right-[10%] w-20 h-20 md:w-[130px] md:h-[130px] rounded-full border-[5px] border-[#121212] bg-[radial-gradient(circle,#f8f5e9_15%,transparent_15%),radial-gradient(circle,#121212_15%,#121212_25%,transparent_25%),radial-gradient(circle,#f8f5e9_25%,#f8f5e9_35%,transparent_35%),radial-gradient(circle,#121212_35%,#121212_45%,transparent_45%),radial-gradient(circle,#f8f5e9_45%,#f8f5e9_55%,transparent_55%),radial-gradient(circle,#121212_55%,#121212_65%,transparent_65%)] scale-125 rotate-90 animate-spin-slow-reverse"
    >
    </div>
  </div>

  <div
    class="relative z-10 w-[450px] h-[650px] scale-[0.65] md:scale-90 lg:scale-100 -rotate-[15deg] translate-y-12 drop-shadow-[10px_10px_0px_rgba(0,0,0,0.2)] transition-transform duration-700 group-hover:-rotate-6 origin-center flex items-end justify-center"
  >
    <div
      class="absolute bottom-[530px] right-[180px] w-[320px] h-[200px] z-[5] drop-shadow-[0_0_0_5px_#121212]"
    >
      <div
        class="absolute -top-[30px] left-[100px] w-[80px] h-[40px] bg-[#ffc800] border-[5px] border-[#121212]"
        style="clip-path: polygon(20% 100%, 0 50%, 20% 0, 80% 0, 100% 50%, 80% 100%);"
      >
      </div>
      <div
        class="w-full h-full bg-[#ffc800] bg-[linear-gradient(to_bottom_right,#ffc800_50%,#dca300)]"
        style="clip-path: path('M 280,180 L 280,150 C 280,150 50,150 30,150 C 10,150 0,130 0,100 C 0,70 20,50 50,40 L 180,10 C 220,0 250,30 260,60 C 270,90 300,100 320,110 L 320,180 L 280,180 M 60,120 L 240,120 C 250,120 250,100 240,90 L 200,70 C 180,60 160,70 150,80 L 60,100 C 50,105 50,120 60,120 Z');"
      >
      </div>
      <div
        class="absolute bottom-[40px] left-[50px] w-[170px] h-[50px] bg-[#121212] rounded-[10px] border-[4px] border-[#ffc800] bg-[radial-gradient(#fffce0_2px,transparent_2px)] bg-[size:10px_10px]"
      >
      </div>
    </div>

    <div
      class="absolute bottom-[445px] right-[125px] w-[110px] h-[140px] bg-[#c42929] border-[5px] border-[#121212] border-b-0 rounded-[30%_60%_0_0] bg-[radial-gradient(circle_at_30%_30%,#c42929,#9c1e1e)] z-[2]"
    >
      <div
        class="absolute top-[40px] right-[20px] w-[45px] h-[25px] bg-[#fffce0] border-[4px] border-[#121212] rounded-full overflow-hidden"
      >
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[18px] h-[18px] bg-[#121212] rounded-full"
        >
        </div>
      </div>
    </div>

    <div
      class="absolute bottom-0 right-[130px] w-[65px] h-[450px] border-[5px] border-[#121212] border-t-0 rounded-[0_0_10px_10px] overflow-hidden bg-[#c42929]"
    >
      <div
        class="w-full h-full bg-[linear-gradient(to_top,#1b5e20_20%,#c42929_20%)] bg-[linear-gradient(to_right,rgba(0,0,0,0.2),transparent_30%,transparent_70%,rgba(0,0,0,0.2)),linear-gradient(to_top,#1b5e20_20%,#c42929_20%)]"
      >
      </div>
    </div>

    <div class="absolute top-[180px] right-[110px] flex flex-col gap-[10px]">
      <div
        class="w-[20px] h-[20px] bg-[#f8f5e9] border-[4px] border-[#121212] rounded-full"
      >
      </div>
      <div
        class="w-[20px] h-[20px] bg-[#f8f5e9] border-[4px] border-[#121212] rounded-full"
      >
      </div>
      <div
        class="w-[20px] h-[20px] bg-[#f8f5e9] border-[4px] border-[#121212] rounded-full"
      >
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-10 inset-x-0 flex flex-col items-center z-50 pointer-events-none"
  >
    <h1
      class="font-serif text-6xl md:text-[80px] text-[#c42929] m-0 tracking-[15px] md:tracking-[20px] drop-shadow-[3px_3px_0_#121212,-3px_-3px_0_#121212,3px_-3px_0_#121212,-3px_3px_0_#121212,10px_10px_0_rgba(0,0,0,0.2)]"
    >
      MAKPO
    </h1>
    <div
      class="font-serif text-lg md:text-2xl text-[#121212] mt-2 md:mt-3 tracking-[6px] md:tracking-[8px] font-bold uppercase"
    >
      Autorité Sacrée
    </div>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Cinzel:wght@900&display=swap");

  h1 {
    font-family: "Cinzel", serif;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes spinSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spinSlow 20s linear infinite;
  }

  @keyframes spinSlowReverse {
    from {
      transform: rotate(90deg) scale(1.25);
    }
    to {
      transform: rotate(-270deg) scale(1.25);
    }
  }
  .animate-spin-slow-reverse {
    animation: spinSlowReverse 25s linear infinite;
  }
</style>
