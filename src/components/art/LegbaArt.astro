---
/*
  LegbaArt.astro - CSS Art
  Allégorie du Gardien du Seuil et Maître des Carrefours.
  Optimisé Tailwind v4 - 100% CSS (Zéro JS) - Thème Feu/Sombre
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-96 md:h-[32rem] bg-[#050101] rounded-2xl overflow-hidden border border-red-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.8)] flex items-center justify-center group opacity-0 animate-fade-up select-none"
>
  {/* Lueur d'arrière-plan (Réagit au hover) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(139,0,0,0.15)_0%,#050101_80%)] transition-colors duration-1000 group-hover:bg-[radial-gradient(circle_at_center,rgba(255,69,0,0.2)_0%,#050101_80%)]"
  >
  </div>

  {/* Bruit visuel (Texture) */}
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.06%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none"
  >
  </div>

  {/* Titre Arrière-plan (Cinematic) */}
  <div
    class="absolute top-[20%] w-full text-center z-0 transition-transform duration-1000 group-hover:scale-105"
  >
    <h1
      class="font-serif text-7xl md:text-9xl m-0 text-transparent bg-clip-text bg-gradient-to-b from-red-900/40 to-transparent uppercase tracking-[0.2em] font-black"
    >
      LEGBA
    </h1>
  </div>

  {/* Le Carrefour (Lignes croisées en perspective 3D au sol) */}
  <div
    class="absolute bottom-[-100px] w-[600px] h-[600px] flex items-center justify-center z-10 opacity-60 transition-all duration-700 group-hover:opacity-100 [transform:rotateX(75deg)_scale(1.2)]"
  >
    {/* Ligne Verticale */}
    <div
      class="absolute w-1 h-full bg-gradient-to-b from-transparent via-amber-500 to-transparent shadow-[0_0_30px_rgba(255,69,0,0.8)]"
    >
    </div>
    {/* Ligne Horizontale */}
    <div
      class="absolute w-full h-1 bg-gradient-to-r from-transparent via-amber-500 to-transparent shadow-[0_0_30px_rgba(255,69,0,0.8)]"
    >
    </div>
    {/* Noyau palpitant au centre du carrefour */}
    <div
      class="absolute w-6 h-6 bg-amber-400 rounded-full blur-[4px] animate-pulse-fast shadow-[0_0_50px_20px_#ff4500]"
    >
    </div>
  </div>

  {/* Le Monolithe (La Porte de l'Invisible) */}
  <div
    class="relative z-20 w-32 h-56 md:w-36 md:h-64 bg-gradient-to-b from-[#1a1111] to-[#0a0505] shadow-[0_30px_50px_rgba(0,0,0,0.9),inset_0_0_15px_rgba(255,255,255,0.03)] border border-red-500/20 flex justify-center overflow-hidden transition-all duration-700 transform group-hover:-translate-y-4 group-hover:shadow-[0_40px_70px_rgba(255,69,0,0.15)]"
  >
    {/* La Faille lumineuse (Crack) */}
    <div
      class="absolute top-[10%] w-1 h-[80%] bg-amber-400 blur-[1px] shadow-[0_0_20px_rgba(255,215,0,0.8),0_0_40px_rgba(255,69,0,0.8)] animate-flicker"
      style="clip-path: polygon(40% 0%, 60% 0%, 50% 15%, 80% 25%, 20% 45%, 60% 60%, 30% 80%, 70% 90%, 50% 100%, 30% 100%, 10% 90%, 50% 80%, 20% 60%, 80% 45%, 30% 25%, 50% 15%);"
    >
    </div>
  </div>

  {/* Particules (Gérées en pur CSS) */}
  <div class="absolute inset-0 z-15 overflow-hidden pointer-events-none">
    <div
      class="absolute bottom-0 left-[40%] w-1.5 h-1.5 bg-amber-400 rounded-full shadow-[0_0_10px_#ff4500] animate-rise opacity-0 [animation-delay:0.2s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[55%] w-2 h-2 bg-amber-500 rounded-full shadow-[0_0_10px_#ff4500] animate-rise opacity-0 [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[65%] w-1 h-1 bg-amber-300 rounded-full shadow-[0_0_10px_#ff4500] animate-rise opacity-0 [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[45%] w-2 h-2 bg-red-500 rounded-full shadow-[0_0_10px_#ff0000] animate-rise opacity-0 [animation-delay:2.1s]"
    >
    </div>
    <div
      class="absolute bottom-0 left-[50%] w-1.5 h-1.5 bg-amber-400 rounded-full shadow-[0_0_10px_#ff4500] animate-rise opacity-0 [animation-delay:3s]"
    >
    </div>
  </div>

  {/* Textes HUD / Informations */}
  <div
    class="absolute bottom-8 w-full text-center z-30 transition-transform duration-700 group-hover:-translate-y-2"
  >
    <h2
      class="font-sans text-sm md:text-base font-bold text-white tracking-[0.4em] uppercase drop-shadow-[0_4px_10px_rgba(0,0,0,1)]"
    >
      Maître des Portes
    </h2>
    <div
      class="text-[0.55rem] md:text-[0.65rem] text-red-400/80 tracking-[0.3em] mt-2 uppercase font-light"
    >
      NI DIABLE, NI SAINT. L&apos;ÉQUILIBRE.
    </div>
  </div>

  {/* Décorations de coin */}
  <div
    class="absolute top-4 left-4 font-mono text-[0.625rem] text-red-500/50 tracking-[0.3em] uppercase select-none"
  >
    AXIS: CROSSROADS
  </div>
  <div
    class="absolute bottom-4 right-4 font-mono text-[0.625rem] text-amber-500/50 tracking-[0.3em] uppercase animate-pulse-slow select-none"
  >
    ACCESS.GRANTED()
  </div>
</div>

<style>
  /* --- Animations 100% CSS --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes flicker {
    0%,
    100% {
      opacity: 0.8;
      filter: brightness(1) blur(0.5px);
    }
    50% {
      opacity: 1;
      filter: brightness(1.3) blur(1.5px);
    }
  }
  .animate-flicker {
    animation: flicker 0.15s infinite alternate;
  }

  @keyframes pulseFast {
    0%,
    100% {
      transform: scale(0.9);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
      box-shadow: 0 0 60px 25px #ff4500;
    }
  }
  .animate-pulse-fast {
    animation: pulseFast 1.5s infinite alternate ease-in-out;
  }

  @keyframes pulseSlow {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }
  .animate-pulse-slow {
    animation: pulseSlow 3s infinite alternate;
  }

  @keyframes rise {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    80% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(-350px) scale(0);
      opacity: 0;
    }
  }
  .animate-rise {
    animation: rise 3.5s infinite ease-in;
  }
</style>
