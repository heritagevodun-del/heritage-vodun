---
/*
  PythonArt.astro - Œuvre d&apos;art CSS animée
  Représente le Python Royal sacrée (Dangbé) dans son temple de Ouidah.
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#1a110e_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-gold/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] overflow-hidden">
    {/* La structure du temple (sol, colonnes) */}
    {/* Le sol en damier (stylisé Or et Noir) */}
    <div
      class="absolute bottom-[10px] left-[25px] w-[200px] h-[20px] bg-[repeating-linear-gradient(45deg,#d4af37,#d4af37_5px,#1a110e_5px,#1a110e_10px)] rounded-[4px] opacity-60"
    >
    </div>

    {/* Les colonnes */}
    <div
      class="absolute left-[10px] top-[30px] w-[15px] h-[180px] bg-[#1a2e2e] rounded-[4px] shadow-[inset_2px_0_5px_rgba(0,0,0,0.8),2px_0_5px_rgba(0,0,0,0.5)] z-0"
    >
    </div>
    <div
      class="absolute right-[10px] top-[30px] w-[15px] h-[180px] bg-[#1a2e2e] rounded-[4px] shadow-[inset_-2px_0_5px_rgba(0,0,0,0.8),-2px_0_5px_rgba(0,0,0,0.5)] z-0"
    >
    </div>

    {/* Le Python Royal stylisé (Dangbé) */}
    <div
      class="absolute top-1/2 left-1/2 w-[160px] h-[160px] bg-[radial-gradient(circle_at_70%_30%,#a0522d_0%,#d4af37_100%)] rounded-full border-[5px] border-[#d4af37] shadow-[0_10px_30px_rgba(212,175,55,0.15)] animate-serpent-coiled z-10"
    >
      {/* Anneaux (enroulés) */}
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[140px] h-[140px] border-[4px] border-[#a0522d] top-[5px] left-[5px]"
      >
      </div>
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[120px] h-[120px] border-[4px] border-[#d4af37] top-[15px] left-[15px]"
      >
      </div>
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[100px] h-[100px] border-[4px] border-[#a0522d] top-[25px] left-[25px]"
      >
      </div>
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[80px] h-[80px] border-[4px] border-[#d4af37] top-[35px] left-[35px]"
      >
      </div>
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[60px] h-[60px] border-[4px] border-[#a0522d] top-[45px] left-[45px]"
      >
      </div>
      <div
        class="absolute rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.5)] w-[40px] h-[40px] border-[4px] border-[#d4af37] top-[55px] left-[55px]"
      >
      </div>

      {/* Tête */}
      <div
        class="absolute -bottom-[10px] right-[30px] w-[35px] h-[35px] bg-[#1a2e2e] rounded-full border-[4px] border-[#050505] z-20 animate-serpent-head-scan shadow-[0_5px_10px_rgba(0,0,0,0.6)]"
      >
        {/* Oeil brillant */}
        <div
          class="absolute top-[8px] right-[6px] w-[8px] h-[8px] bg-[#ffd700] rounded-full shadow-[0_0_8px_rgba(255,215,0,0.8)]"
        >
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes serpent-coiled {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.03);
    }
  }
  .animate-serpent-coiled {
    animation: serpent-coiled 6s ease-in-out infinite;
  }

  @keyframes serpent-head-scan {
    0%,
    100% {
      transform: rotate(-10deg) translateX(0);
    }
    50% {
      transform: rotate(10deg) translateX(-5px);
    }
  }
  .animate-serpent-head-scan {
    animation: serpent-head-scan 6s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
