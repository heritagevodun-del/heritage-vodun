      >
      </div>
      <div
        class="absolute left-0 w-16 h-px bg-gradient-to-r from-transparent to-amber-300"
      >
      </div>
      <div
        class="absolute right-0 w-16 h-px bg-gradient-to-l from-transparent to-amber-300"
