              class="w-6 h-4 md:w-8 md:h-5 bg-gradient-to-b from-[#78350f] to-[#451a03] rounded-sm shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-bit-flip [animation-delay:0.2s]"
            >
            </div>
          </div>
          <div class="flex gap-2 justify-center">
            <div
              class="w-2 h-4 md:w-3 md:h-5 bg-gradient-to-b from-amber-500 to-amber-600 rounded-sm shadow-[0_0_10px_rgba(245,158,11,0.5)] animate-bit-glow [animation-delay:0.7s]"
            >
            </div>
            <div
              class="w-2 h-4 md:w-3 md:h-5 bg-gradient-to-b from-amber-500 to-amber-600 rounded-sm shadow-[0_0_10px_rgba(245,158,11,0.5)] animate-bit-glow [animation-delay:0.7s]"
            >
            </div>
          </div>
          <div class="flex justify-center">
            <div
              class="w-6 h-4 md:w-8 md:h-5 bg-gradient-to-b from-[#78350f] to-[#451a03] rounded-sm shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-bit-flip [animation-delay:1.2s]"
            >
            </div>
          </div>
          <div class="flex gap-2 justify-center">
            <div
              class="w-2 h-4 md:w-3 md:h-5 bg-gradient-to-b from-amber-500 to-amber-600 rounded-sm shadow-[0_0_10px_rgba(245,158,11,0.5)] animate-bit-glow [animation-delay:1.7s]"
            >
            </div>
            <div
              class="w-2 h-4 md:w-3 md:h-5 bg-gradient-to-b from-amber-500 to-amber-600 rounded-sm shadow-[0_0_10px_rgba(245,158,11,0.5)] animate-bit-glow [animation-delay:1.7s]"
            >
