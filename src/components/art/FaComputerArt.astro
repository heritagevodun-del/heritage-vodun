  </div>

  <div class="absolute inset-0 z-30 pointer-events-none overflow-hidden">
    <div
      class="absolute top-[20%] left-[30%] w-1.5 h-1.5 bg-amber-400 rounded-full shadow-[0_0_5px_#fbbf24] animate-data-stream [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[30%] w-2 h-2 bg-amber-500 rounded-full shadow-[0_0_8px_#f59e0b] animate-data-stream-reverse [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute top-[40%] left-[20%] w-1 h-1 bg-amber-300 rounded-full shadow-[0_0_4px_#fcd34d] animate-data-stream [animation-delay:0.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] right-[20%] w-1.5 h-1.5 bg-amber-400 rounded-full shadow-[0_0_6px_#fbbf24] animate-data-stream-reverse [animation-delay:1.5s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 5s infinite alternate ease-in-out;
  }

  @keyframes spinSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spinSlow 15s linear infinite;
  }

  @keyframes spinSlowReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }
  .animate-spin-slow-reverse {
    animation: spinSlowReverse 20s linear infinite;
  }

  @keyframes bitFlip {
    0%,
    45% {
      transform: scaleX(1);
      opacity: 1;
    }
    50% {
      transform: scaleX(0);
      opacity: 0.5;
    }
    55%,
    100% {
      transform: scaleX(1);
      opacity: 1;
    }
  }
  .animate-bit-flip {
    animation: bitFlip 6s infinite ease-in-out;
  }

  @keyframes bitGlow {
    0%,
    100% {
      filter: brightness(1);
      transform: scale(1);
    }
    50% {
      filter: brightness(1.3);
      transform: scale(1.05);
    }
  }
  .animate-bit-glow {
    animation: bitGlow 3s infinite alternate ease-in-out;
  }

  @keyframes dataStream {
    0% {
      transform: translateX(0) translateY(0);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      transform: translateX(100px) translateY(100px);
      opacity: 0;
    }
  }
  .animate-data-stream {
    animation: dataStream 4s infinite linear;
  }

  @keyframes dataStreamReverse {
    0% {
      transform: translateX(0) translateY(0);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      transform: translateX(-100px) translateY(-100px);
      opacity: 0;
    }
  }
  .animate-data-stream-reverse {
    animation: dataStreamReverse 5s infinite linear;
  }
</style>
