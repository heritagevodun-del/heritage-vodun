---
// ZangbetoArt.astro
// Animation CSS Art représentant la transe et le mystère du vide
---

<div
  class="relative w-full h-96 md:h-[30rem] bg-gray-950 rounded-2xl overflow-hidden flex items-center justify-center border border-white/10 shadow-2xl mb-12 group cursor-crosshair"
>
  {/* Décor nocturne et brume */}
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gray-900 via-gray-950 to-black z-0"
  >
  </div>
  <div
    class="absolute bottom-0 w-full h-1/3 bg-gradient-to-t from-black to-transparent z-10"
  >
  </div>

  {/* Halo magique au sol (Le mystère) */}
  <div
    class="absolute bottom-12 w-64 md:w-96 h-12 bg-gold/20 blur-2xl rounded-[100%] animate-pulse z-10"
  >
  </div>

  {/* Le Zangbéto (Structure en lévitation) */}
  <div
    class="relative z-20 flex flex-col items-center animate-[bounce_3s_ease-in-out_infinite]"
  >
    {/* Sommet / Corne */}
    <div
      class="w-4 h-16 bg-gradient-to-b from-amber-900 to-black rounded-t-full mb-[-10px] z-40 border border-black/50"
    >
    </div>

    {/* Étages de Raphia (Superpositions de CSS) */}
    <div
      class="relative w-32 h-20 bg-gradient-to-b from-amber-800 to-amber-950 rounded-t-[40%] z-30 border-b-8 border-black shadow-inner"
    >
      <div
        class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_2px,#000_2px,#000_4px)]"
      >
      </div>
    </div>

    <div
      class="relative w-48 h-24 bg-gradient-to-b from-amber-700 to-amber-900 rounded-t-[40%] mt-[-20px] z-20 border-b-8 border-black shadow-[0_10px_20px_rgba(0,0,0,0.8)]"
    >
      <div
        class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_2px,#000_2px,#000_4px)]"
      >
      </div>
    </div>

    <div
      class="relative w-64 h-32 bg-gradient-to-b from-amber-600 to-amber-800 rounded-t-[30%] mt-[-30px] z-10 border-b-8 border-black shadow-[0_20px_40px_rgba(0,0,0,0.9)] transform group-hover:rotate-3 transition-transform duration-500"
    >
      <div
        class="absolute inset-0 opacity-30 bg-[repeating-linear-gradient(90deg,transparent,transparent_2px,#000_2px,#000_4px)]"
      >
      </div>

      {/* Lueur interne (le vide habité) */}
      <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-48 h-10 bg-gold/40 blur-xl rounded-full animate-pulse"
      >
      </div>
    </div>
  </div>

  {/* Particules magiques flottantes */}
  <div
    class="absolute inset-0 z-30 pointer-events-none mix-blend-screen opacity-30"
  >
    <div
      class="absolute top-1/4 left-1/4 w-2 h-2 bg-gold rounded-full animate-[ping_4s_infinite]"
    >
    </div>
    <div
      class="absolute top-1/2 right-1/3 w-1.5 h-1.5 bg-white rounded-full animate-[ping_3s_infinite_1s]"
    >
    </div>
    <div
      class="absolute bottom-1/3 left-1/3 w-2 h-2 bg-gold rounded-full animate-[ping_5s_infinite_2s]"
    >
    </div>
  </div>

  {/* Étiquette d'interface */}
  <div
    class="absolute top-4 right-4 z-40 bg-black/50 backdrop-blur-md border border-white/10 px-3 py-1 rounded-full flex items-center space-x-2"
  >
    <div class="w-2 h-2 rounded-full bg-gold animate-pulse"></div>
    <span class="text-xs font-mono text-gray-300 uppercase tracking-widest"
      >Transe Active</span
    >
  </div>
</div>
