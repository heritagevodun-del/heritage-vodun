---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fdfbf7] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[32rem] h-80 md:h-[32rem] bg-indigo-900/5 rounded-full blur-[60px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-30 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-indigo-950/60 uppercase tracking-[0.15em] w-full text-center drop-shadow-[0_2px_4px_rgba(30,27,75,0.25)] transition-transform duration-1000 group-hover:scale-105"
    >
      ZANGBÉTO
    </h1>
  </div>

  <div
    class="absolute bottom-0 w-full h-[30%] bg-gradient-to-t from-[#1e1b4b]/10 to-transparent z-10"
  >
  </div>
  <div
    class="absolute bottom-[10%] w-[60%] h-8 bg-indigo-950/20 blur-[12px] rounded-[100%] z-15 animate-shadow-breathe"
  >
  </div>

  <div class="relative z-20 flex flex-col items-center mt-12 animate-float">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 md:w-80 md:h-80 bg-[conic-gradient(from_0deg,transparent,rgba(30,27,75,0.1)_90deg,transparent_180deg,rgba(217,119,6,0.15)_270deg)] rounded-full blur-[20px] animate-spin-fast -z-10"
    >
    </div>

    <div
      class="relative w-8 h-8 md:w-10 md:h-10 bg-gradient-to-b from-[#1e1b4b] to-[#312e81] rounded-t-full shadow-[0_5px_10px_rgba(0,0,0,0.4)] z-50 flex justify-center items-end pb-1 border-b-2 border-amber-500"
    >
      <div class="w-3 h-3 bg-amber-400 rounded-full shadow-[0_0_8px_#fbbf24]">
      </div>
    </div>

    <div
      class="relative w-20 h-12 md:w-28 md:h-16 bg-gradient-to-b from-[#312e81] to-[#4338ca] -mt-2 z-40 shadow-[0_8px_15px_rgba(0,0,0,0.5)] flex flex-col justify-end overflow-hidden"
      style="clip-path: polygon(25% 0, 75% 0, 100% 100%, 0 100%);"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_2px,rgba(255,255,255,0.15)_3px,rgba(255,255,255,0.15)_4px)]"
      >
      </div>
      <div
        class="w-full h-2 bg-gradient-to-r from-amber-600 via-amber-400 to-amber-600"
      >
      </div>
    </div>

    <div
      class="relative w-36 h-20 md:w-48 md:h-28 bg-gradient-to-b from-[#4338ca] to-[#3730a3] -mt-4 z-30 shadow-[0_10px_20px_rgba(0,0,0,0.6)] flex flex-col justify-end overflow-hidden animate-layer-twist-left"
      style="clip-path: polygon(20% 0, 80% 0, 100% 100%, 0 100%);"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_3px,rgba(0,0,0,0.2)_4px,rgba(0,0,0,0.2)_6px)]"
      >
      </div>
      <div
        class="w-full h-3 bg-gradient-to-r from-amber-700 via-amber-500 to-amber-700"
      >
      </div>
    </div>

    <div
      class="relative w-52 h-24 md:w-72 md:h-36 bg-gradient-to-b from-[#b45309] to-[#78350f] -mt-6 z-20 shadow-[0_15px_25px_rgba(0,0,0,0.7)] flex flex-col justify-end overflow-hidden animate-layer-twist-right"
      style="clip-path: polygon(15% 0, 85% 0, 100% 100%, 0 100%);"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_4px,rgba(0,0,0,0.3)_5px,rgba(0,0,0,0.3)_8px)]"
      >
      </div>
      <div
        class="w-full h-4 bg-gradient-to-r from-[#1e1b4b] via-[#312e81] to-[#1e1b4b]"
      >
      </div>
    </div>

    <div
      class="relative w-72 h-28 md:w-96 md:h-44 bg-gradient-to-b from-[#78350f] to-[#451a03] -mt-8 z-10 shadow-[0_20px_35px_rgba(0,0,0,0.8)] flex flex-col justify-end overflow-hidden animate-layer-twist-base"
      style="clip-path: polygon(10% 0, 90% 0, 100% 100%, 0 100%);"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_5px,rgba(0,0,0,0.4)_6px,rgba(0,0,0,0.4)_10px)]"
      >
      </div>
      <div
        class="w-full h-6 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(255,255,255,0.2)_10px,rgba(255,255,255,0.2)_16px)]"
      >
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 z-40 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[25%] w-2 h-2 bg-indigo-400 blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[30%] right-[25%] w-3 h-3 bg-amber-200 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] right-[15%] w-1.5 h-1.5 bg-indigo-300 rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute bottom-[25%] left-[45%] w-2.5 h-2.5 bg-amber-400 blur-[1px] rounded-full animate-float-up [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 6s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  @keyframes shadowBreathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(0.8);
      opacity: 0.4;
    }
  }
  .animate-shadow-breathe {
    animation: shadowBreathe 4s ease-in-out infinite;
  }

  @keyframes spinFast {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
  .animate-spin-fast {
    animation: spinFast 2s linear infinite;
  }

  @keyframes layerTwistLeft {
    0%,
    100% {
      transform: skewX(-2deg);
    }
    50% {
      transform: skewX(2deg);
    }
  }
  .animate-layer-twist-left {
    animation: layerTwistLeft 2.5s infinite ease-in-out;
  }

  @keyframes layerTwistRight {
    0%,
    100% {
      transform: skewX(2deg);
    }
    50% {
      transform: skewX(-2deg);
    }
  }
  .animate-layer-twist-right {
    animation: layerTwistRight 2.5s infinite ease-in-out;
  }

  @keyframes layerTwistBase {
    0%,
    100% {
      transform: skewX(-1deg) scaleX(1);
    }
    50% {
      transform: skewX(1deg) scaleX(1.02);
    }
  }
  .animate-layer-twist-base {
    animation: layerTwistBase 2.5s infinite ease-in-out;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-150px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 5s infinite ease-out;
  }
</style>
