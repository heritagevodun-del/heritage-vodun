---
/*
  ZangbetoArt.astro - Œuvre d&apos;art CSS animée
  Représente la rotation mystique du Gardien de la Nuit (Zangbeto).
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_bottom,#4a3b32_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-gold/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[200px] h-[250px] flex justify-center items-end pb-8">
    {/* Particules de poussière / Énergie de rotation */}
    <div
      class="absolute bottom-10 left-[-10px] w-5 h-1.5 bg-[#d2b48c]/40 rounded-full blur-[2px] animate-dust-fly"
    >
    </div>
    <div
      class="absolute bottom-12 right-[-10px] w-5 h-1.5 bg-[#d4af37]/30 rounded-full blur-[2px] animate-dust-fly [animation-delay:0.2s]"
    >
    </div>
    <div
      class="absolute bottom-8 left-1/4 w-5 h-1.5 bg-[#d2b48c]/20 rounded-full blur-[2px] animate-dust-fly [animation-delay:0.4s]"
    >
    </div>
    <div
      class="absolute bottom-14 right-1/4 w-5 h-1.5 bg-[#d4af37]/40 rounded-full blur-[2px] animate-dust-fly [animation-delay:0.6s]"
    >
    </div>

    {/* Le Zangbeto (Cône de Raphia) */}
    <div
      class="relative w-[160px] h-[180px] flex flex-col items-center justify-end animate-zangbeto-spin z-10"
    >
      {/* Cornes au sommet */}
      <div
        class="absolute -top-4 left-[50px] w-2.5 h-7 bg-[#2c1e16] rounded-t-full -rotate-30"
      >
      </div>
      <div
        class="absolute -top-4 right-[50px] w-2.5 h-7 bg-[#2c1e16] rounded-t-full rotate-30"
      >
      </div>

      {/* Couches de Raphia (Utilisation de dégradés pour simuler la paille) */}
      <div
        class="w-[60px] h-[50px] bg-[repeating-linear-gradient(90deg,#d2b48c_0%,#d2b48c_5px,#8b5a2b_5px,#8b5a2b_10px)] rounded-[50%_50%_10%_10%] shadow-[inset_0_-5px_10px_rgba(0,0,0,0.5)] border-t-4 border-[#800000] z-30"
      >
      </div>

      <div
        class="w-[110px] h-[70px] -mt-5 bg-[repeating-linear-gradient(90deg,#d2b48c_0%,#d2b48c_5px,#8b5a2b_5px,#8b5a2b_10px)] rounded-[50%_50%_10%_10%] shadow-[inset_0_-10px_15px_rgba(0,0,0,0.5)] border-b-4 border-[#2c1e16] z-20"
      >
      </div>

      <div
        class="w-[160px] h-[90px] -mt-8 bg-[repeating-linear-gradient(90deg,#d2b48c_0%,#d2b48c_5px,#8b5a2b_5px,#8b5a2b_10px)] rounded-[50%_50%_10%_10%] shadow-[inset_0_-15px_20px_rgba(0,0,0,0.6)] border-b-8 border-[#2c1e16] z-10"
      >
      </div>
    </div>

    {/* Ombre portée au sol */}
    <div
      class="absolute bottom-6 w-[140px] h-4 bg-black/40 rounded-full blur-md -z-10"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS --- */

  /* Rotation mystique : combine mise à l'échelle et balancement */
  @keyframes zangbeto-spin {
    0%,
    100% {
      transform: scaleX(1) translateY(0);
    }
    25% {
      transform: scaleX(0.85) translateY(-3px);
    }
    50% {
      transform: scaleX(-1) translateY(0);
    }
    75% {
      transform: scaleX(-0.85) translateY(-3px);
    }
  }
  .animate-zangbeto-spin {
    animation: zangbeto-spin 0.7s linear infinite;
  }

  /* Poussière éjectée par la force centrifuge */
  @keyframes dust-fly {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 0.8;
    }
    100% {
      transform: translate(-30px, -40px) scale(2);
      opacity: 0;
    }
  }
  .animate-dust-fly {
    animation: dust-fly 1s ease-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
