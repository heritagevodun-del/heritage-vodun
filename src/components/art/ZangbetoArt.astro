---
/* ZangbetoArt.astro 
  Composant CSS Art simulant la rotation mystérieuse du Gardien de la Nuit.
  Utilise Tailwind v4 et des animations CSS natives optimisées.
*/
---

<div
  class="zangbeto-container relative w-full h-[350px] md:h-[450px] flex items-center justify-center overflow-hidden bg-[#050505] rounded-3xl border border-white/5 my-12 shadow-[0_20px_60px_rgba(0,0,0,0.8)]"
>
  {/* L'AURA SPIRITUELLE (EFFET DE FOND) */}
  <div
    class="absolute w-[200px] h-[200px] rounded-full bg-gold/10 blur-[80px] animate-[pulse-glow_4s_infinite]"
  >
  </div>

  {/* LE ZANGBÉTO EN ROTATION */}
  <div
    class="zangbeto-masque relative w-[180px] md:w-[240px] h-[280px] md:h-[350px] animate-[float_6s_ease-in-out_infinite]"
  >
    {/* STRUCTURE DU CÔNE (Calques de raphia simulés par des gradients) */}
    <div
      class="absolute inset-0 bg-gradient-to-b from-[#8b4513] via-[#cd853f] to-[#deb887] clip-path-zangbeto shadow-inner opacity-90"
    >
    </div>

    {/* EFFET DE TEXTURE ROTATIVE (Lignes CSS pour simuler le mouvement) */}
    <div
      class="absolute inset-0 z-10 animate-[spin-slow_2s_linear_infinite] opacity-30"
    >
      <div
        class="w-full h-full bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.2)_0px,rgba(0,0,0,0.2)_1px,transparent_1px,transparent_10px)]"
      >
      </div>
    </div>

    {/* LES YEUX MYSTÉRIEUX (Cachés au centre) */}
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex gap-10 z-20"
    >
      <div
        class="w-4 h-4 bg-gold rounded-full blur-[3px] animate-[pulse_1.5s_infinite]"
      >
      </div>
      <div
        class="w-4 h-4 bg-gold rounded-full blur-[3px] animate-[pulse_1.5s_infinite]"
      >
      </div>
    </div>

    {/* BASE DU CÔNE (Bordure dorée protectrice) */}
    <div
      class="absolute -bottom-1 left-0 w-full h-3 bg-gold rounded-full blur-[2px] z-10 opacity-70"
    >
    </div>
  </div>

  {/* L'OMBRE PORTÉE LÉVITANTE */}
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 w-[150px] md:w-[200px] h-6 bg-black/70 rounded-full blur-[10px] animate-[shadow-scale_6s_ease-in-out_infinite]"
  >
  </div>
</div>

<style is:global>
  /* Définition des animations spécifiques au Zangbéto */

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) rotate(-1deg);
    }
    50% {
      transform: translateY(-20px) rotate(1deg);
    }
  }

  @keyframes shadow-scale {
    0%,
    100% {
      transform: translateX(-100%) scale(1);
      opacity: 0.7;
    }
    50% {
      transform: translateX(-100%) scale(0.85);
      opacity: 0.4;
    }
  }

  @keyframes spin-slow {
    from {
      transform: rotateY(0deg);
    }
    to {
      transform: rotateY(360deg);
    }
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.2;
      transform: scale(1.1);
    }
  }

  /* Forme conique du Zangbéto */
  .clip-path-zangbeto {
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
  }
</style>
