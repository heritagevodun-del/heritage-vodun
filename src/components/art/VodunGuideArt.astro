---
/*
  VodunGuideArt.astro - CSS Art
  Représente l&apos;harmonie, le code vestimentaire blanc (lumière) et le respect des énergies.
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2c2520_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-[#d4af37]/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-center">
    {/* Énergie du visiteur (Le Blanc pur / La Paix) */}
    <div
      class="absolute w-[60px] h-[60px] bg-[radial-gradient(circle,#fdfbf7_0%,rgba(253,251,247,0.2)_80%,transparent_100%)] rounded-full shadow-[0_0_30px_rgba(253,251,247,0.6)] z-30 animate-breathe-light"
    >
    </div>

    {/* Anneaux de protection / Distances sacrées */}
    <div
      class="absolute w-[100px] h-[100px] rounded-full border-t-2 border-b-2 border-[#d4af37] border-l-transparent border-r-transparent z-20 animate-spin-slow"
    >
    </div>

    <div
      class="absolute w-[150px] h-[150px] rounded-full border-l-2 border-r-2 border-dashed border-[#8b5a2b] border-t-transparent border-b-transparent z-20 animate-spin-slow-reverse"
    >
    </div>

    <div
      class="absolute w-[200px] h-[200px] rounded-full border-t border-b border-[#d4af37]/30 border-l-transparent border-r-transparent z-20 animate-spin-slow-outer"
    >
    </div>

    {/* Particules d'énergie (La ferveur de Ouidah) */}
    <div
      class="absolute w-[4px] h-[4px] bg-[#d4af37] rounded-full blur-[1px] animate-float-spark top-[40px] left-[60px] [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-[#fdfbf7] rounded-full blur-[1px] animate-float-spark bottom-[50px] right-[40px] [animation-delay:0.5s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-[#d4af37] rounded-full blur-[1px] animate-float-spark top-[70px] right-[50px] [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-[#d4af37] rounded-full blur-[1px] animate-float-spark bottom-[60px] left-[50px] [animation-delay:1.5s]"
    >
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes breathe-light {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.3);
      opacity: 1;
    }
  }
  .animate-breathe-light {
    animation: breathe-light 4s ease-in-out infinite;
  }

  @keyframes spin-slow {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }

  @keyframes spin-slow-reverse {
    0% {
      transform: rotate(360deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }
  .animate-spin-slow-reverse {
    animation: spin-slow-reverse 12s linear infinite;
  }

  /* Rotation encore plus lente pour l'anneau externe */
  .animate-spin-slow-outer {
    animation: spin-slow 15s linear infinite;
  }

  @keyframes float-spark {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0.5;
    }
    100% {
      transform: translateY(-20px) scale(1.5);
      opacity: 1;
    }
  }
  .animate-float-spark {
    animation: float-spark 3s ease-in-out infinite alternate;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
