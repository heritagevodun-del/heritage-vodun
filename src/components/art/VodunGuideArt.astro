---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fdfbf7] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[32rem] h-80 md:h-[32rem] bg-amber-100/50 rounded-full blur-[60px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute inset-0 flex items-center justify-center z-0 pointer-events-none px-4"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-30 pointer-events-none px-4"
  >
    <h1
      class="font-sans text-5xl md:text-7xl lg:text-8xl font-black text-amber-900/70 uppercase tracking-[0.15em] w-full text-center drop-shadow-[0_2px_4px_rgba(217,119,6,0.25)] transition-transform duration-1000 group-hover:scale-105"
    >
      GUIDE VOYAGEUR
    </h1>
  </div>

  <div
    class="relative z-20 flex flex-col items-center justify-center w-64 h-64 md:w-80 md:h-80 mt-12 bg-white rounded-full shadow-[0_25px_60px_rgba(217,119,6,0.15)] transition-transform duration-1000 hover:-translate-y-2 animate-float p-2 md:p-3"
  >
    <div
      class="relative w-full h-full rounded-full overflow-hidden bg-gradient-to-b from-amber-100 via-amber-200 to-sky-400 border border-amber-50"
    >
      <div
        class="absolute top-[25%] left-1/2 -translate-x-1/2 w-16 h-16 md:w-20 md:h-20 bg-white rounded-full shadow-[0_0_30px_#fff,0_0_50px_#fde047] animate-pulse-sun"
      >
      </div>

      <div
        class="absolute top-[15%] right-[25%] w-4 h-1 border-b-2 border-r-2 border-amber-700/40 rounded-br-full -rotate-45"
      >
      </div>
      <div
        class="absolute top-[17%] right-[15%] w-3 h-1 border-b-2 border-r-2 border-amber-700/40 rounded-br-full -rotate-45"
      >
      </div>

      <div
        class="absolute bottom-[10%] w-full h-[45%] bg-gradient-to-b from-sky-500 to-sky-800"
      >
        <div
          class="absolute top-2 w-[200%] h-0.5 bg-white/20 blur-[1px] animate-wave"
        >
        </div>
        <div
          class="absolute top-6 w-[200%] h-0.5 bg-white/10 blur-[1px] animate-wave-reverse"
        >
        </div>
      </div>

      <div
        class="absolute bottom-0 w-[150%] h-[35%] bg-gradient-to-t from-amber-700 to-amber-500 rounded-t-[100%] -ml-[25%] shadow-[0_-5px_15px_rgba(0,0,0,0.3)]"
      >
      </div>
      <div
        class="absolute bottom-[-10%] w-[120%] h-[25%] bg-gradient-to-t from-amber-800 to-amber-600 rounded-t-[100%] -ml-[10%] shadow-[0_-5px_15px_rgba(0,0,0,0.4)]"
      >
      </div>

      <div
        class="absolute bottom-[18%] left-1/2 -translate-x-1/2 w-24 md:w-32 h-20 md:h-28 flex flex-col items-center justify-end z-20"
      >
        <div
          class="w-full h-4 md:h-6 bg-gradient-to-b from-[#5c2813] to-[#3a1005] shadow-[0_2px_5px_rgba(0,0,0,0.8)] z-20 rounded-sm border-b border-amber-900"
        >
        </div>

        <div class="flex justify-between w-[85%] h-16 md:h-22 z-10">
          <div
            class="w-4 md:w-6 h-full bg-gradient-to-b from-[#78350f] to-[#3a1005] shadow-[2px_0_5px_rgba(0,0,0,0.6)]"
          >
          </div>
          <div
            class="w-4 md:w-6 h-full bg-gradient-to-b from-[#78350f] to-[#3a1005] shadow-[-2px_0_5px_rgba(0,0,0,0.6)]"
          >
          </div>
        </div>
      </div>
    </div>

    <div
      class="absolute inset-0 rounded-full border-[8px] md:border-[12px] border-[#fdfbf7] shadow-[inset_0_0_10px_rgba(0,0,0,0.1)] pointer-events-none"
    >
    </div>
  </div>

  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[25%] w-2 h-2 bg-white blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[25%] right-[25%] w-3 h-3 bg-amber-200 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[35%] left-[45%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 5s infinite alternate ease-in-out;
  }

  @keyframes pulseSun {
    0%,
    100% {
      transform: translateX(-50%) scale(0.95);
      opacity: 0.9;
    }
    50% {
      transform: translateX(-50%) scale(1.05);
      opacity: 1;
    }
  }
  .animate-pulse-sun {
    animation: pulseSun 4s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes wave {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-wave {
    animation: wave 10s linear infinite;
  }

  @keyframes waveReverse {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }
  .animate-wave-reverse {
    animation: waveReverse 15s linear infinite;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-160px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 6s infinite ease-out;
  }
</style>
