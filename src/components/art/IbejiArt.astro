---
/*
  IbejiArt.astro - Œuvre d&apos;art CSS animée
  Représente les statuettes jumelles sacrées Venavi/Ibeji avec une âme partagée.
  Optimisé Tailwind v4 - Thème Sombre & Or
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2a221d_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-gold/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-end">
    {/* Le Halo d'âme partagée (Or) */}
    <div
      class="absolute top-[20px] w-[180px] h-[180px] bg-[radial-gradient(circle,rgba(212,175,55,0.4)_0%,transparent_70%)] rounded-full animate-soul-breathe z-10"
    >
    </div>

    {/* Le socle sacré */}
    <div
      class="absolute bottom-[20px] w-[180px] h-[15px] bg-[#2c1e16] rounded-[4px] border-b-[4px] border-[#110b08] z-20 shadow-[0_10px_15px_rgba(0,0,0,0.8)]"
    >
    </div>

    {/* Statuette Gauche */}
    <div
      class="absolute bottom-[35px] left-[65px] w-[40px] h-[130px] flex flex-col items-center z-30 animate-gentle-sway [animation-delay:0s]"
    >
      {/* Tête */}
      <div
        class="w-[35px] h-[45px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-[40%_40%_50%_50%] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.5)]"
      >
      </div>

      {/* Cou et perles */}
      <div class="w-[15px] h-[15px] bg-[#3e2723] relative">
        <div
          class="absolute top-[5px] -left-[5px] w-[25px] h-[8px] bg-[repeating-linear-gradient(90deg,#8e0000_0%,#8e0000_4px,#fdfbf7_4px,#fdfbf7_8px)] rounded-[4px] shadow-[0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>

      {/* Corps */}
      <div
        class="w-[30px] h-[70px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-t-[10px] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.5)] relative"
      >
        {/* Patine d'usure */}
        <div
          class="absolute top-[10px] left-[10px] w-[10px] h-[50px] bg-white/5 rounded-[10px]"
        >
        </div>
      </div>
    </div>

    {/* Statuette Droite */}
    <div
      class="absolute bottom-[35px] right-[65px] w-[40px] h-[130px] flex flex-col items-center z-30 animate-gentle-sway [animation-delay:-3s]"
    >
      {/* Tête */}
      <div
        class="w-[35px] h-[45px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-[40%_40%_50%_50%] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.5)]"
      >
      </div>

      {/* Cou et perles */}
      <div class="w-[15px] h-[15px] bg-[#3e2723] relative">
        <div
          class="absolute top-[5px] -left-[5px] w-[25px] h-[8px] bg-[repeating-linear-gradient(90deg,#8e0000_0%,#8e0000_4px,#fdfbf7_4px,#fdfbf7_8px)] rounded-[4px] shadow-[0_2px_4px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>

      {/* Corps */}
      <div
        class="w-[30px] h-[70px] bg-gradient-to-br from-[#5d4037] to-[#3e2723] rounded-t-[10px] shadow-[inset_-5px_-5px_10px_rgba(0,0,0,0.5)] relative"
      >
        {/* Patine d'usure */}
        <div
          class="absolute top-[10px] left-[10px] w-[10px] h-[50px] bg-white/5 rounded-[10px]"
        >
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS COMPLEXES --- */
  @keyframes soul-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
    }
  }
  .animate-soul-breathe {
    animation: soul-breathe 4s ease-in-out infinite;
  }

  @keyframes gentle-sway {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }
  .animate-gentle-sway {
    animation: gentle-sway 6s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1.2s ease forwards;
  }
</style>
