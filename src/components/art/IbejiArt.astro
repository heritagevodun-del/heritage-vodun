    >
    </div>
    <div
      class="absolute bottom-[25%] right-[35%] w-2 h-2 bg-amber-200 rounded-full shadow-[0_0_12px_#fde68a] animate-sparkle-rise [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] left-[48%] w-1.5 h-1.5 bg-white rounded-full shadow-[0_0_10px_#fff] animate-sparkle-rise [animation-delay:0.8s]"
    >
    </div>
