---
/*
  PurificationArt.astro - CSS Art
  Représente la calebasse sacrée contenant l&apos;eau lustrale, le sel et les feuilles de basilic.
  Optimisé Tailwind v4 - Thème Sombre & Pur
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_bottom,#1a202c_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-cyan-900/30 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[200px] flex justify-center items-center">
    {/* Aura spirituelle de purification */}
    <div
      class="absolute w-[180px] h-[180px] bg-[radial-gradient(circle,rgba(224,247,250,0.15)_0%,transparent_70%)] rounded-full animate-breathe z-10"
    >
    </div>

    {/* Grains de sel marin flottants / Énergie */}
    <div
      class="absolute w-[4px] h-[4px] bg-white rounded-full shadow-[0_0_8px_white] z-30 animate-sparkle-rise opacity-0 left-[60px] bottom-[80px] [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-white rounded-full shadow-[0_0_8px_white] z-30 animate-sparkle-rise opacity-0 right-[70px] bottom-[90px] [animation-delay:0.5s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-white rounded-full shadow-[0_0_8px_white] z-30 animate-sparkle-rise opacity-0 left-[110px] bottom-[75px] [animation-delay:1s]"
    >
    </div>
    <div
      class="absolute w-[4px] h-[4px] bg-white rounded-full shadow-[0_0_8px_white] z-30 animate-sparkle-rise opacity-0 right-[100px] bottom-[85px] [animation-delay:1.5s]"
    >
    </div>

    {/* La Calebasse */}
    <div
      class="relative w-[160px] h-[80px] bg-gradient-to-br from-[#8d6e63] to-[#3e2723] rounded-[10px_10px_80px_80px] shadow-[inset_-10px_-10px_20px_rgba(0,0,0,0.6),0_15px_25px_rgba(0,0,0,0.5)] z-20 flex justify-center border-t-[4px] border-[#2a1a17]"
    >
      {/* L'eau sacrée à l'intérieur */}
      <div
        class="absolute -top-[5px] w-[140px] h-[20px] bg-[radial-gradient(ellipse_at_center,#e0f7fa_0%,#00acc1_100%)] rounded-full shadow-[0_0_15px_rgba(0,172,193,0.6),inset_0_0_5px_rgba(255,255,255,0.8)] opacity-90 animate-ripple"
      >
        {
          /* Feuilles de basilic/hysope à la surface (Conteneurs pour rotation isolée) */
        }
        <div class="absolute top-[2px] left-[30px] rotate-[15deg]">
          <div
            class="w-[25px] h-[12px] bg-[#2e7d32] rounded-[12px_0_12px_0] shadow-[inset_2px_2px_4px_rgba(255,255,255,0.3)] animate-float"
          >
          </div>
        </div>

        <div class="absolute top-[5px] right-[40px] -rotate-[45deg]">
          <div
            class="w-[25px] h-[12px] bg-[#2e7d32] rounded-[12px_0_12px_0] shadow-[inset_2px_2px_4px_rgba(255,255,255,0.3)] animate-float [animation-delay:0.5s]"
          >
          </div>
        </div>

        <div class="absolute top-[8px] left-[60px] rotate-[70deg]">
          <div
            class="w-[18px] h-[9px] bg-[#2e7d32] rounded-[12px_0_12px_0] shadow-[inset_2px_2px_4px_rgba(255,255,255,0.3)] animate-float [animation-delay:1s]"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- ANIMATIONS --- */
  @keyframes breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }
  .animate-breathe {
    animation: breathe 4s ease-in-out infinite;
  }

  @keyframes ripple {
    0% {
      transform: scaleX(1);
    }
    100% {
      transform: scaleX(1.02);
    }
  }
  .animate-ripple {
    animation: ripple 3s infinite alternate;
  }

  /* Animation isolée de la flottaison (n'écrase plus la rotation) */
  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-2px);
    }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  @keyframes sparkle-rise {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-40px);
      opacity: 0;
    }
  }
  .animate-sparkle-rise {
    animation: sparkle-rise 2s linear infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
