---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#1a2225] rounded-3xl overflow-hidden border border-teal-900/50 shadow-[0_20px_50px_rgba(0,0,0,0.4)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(45,212,191,0.1)_0%,transparent_70%)] z-0"
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(20,184,166,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(20,184,166,0.05)_1px,transparent_1px)] bg-[size:40px_40px] z-0 pointer-events-none"
  >
  </div>

  <div
    class="relative z-20 flex flex-col items-center justify-center animate-float mt-8"
  >
    <div
      class="absolute top-[-20%] w-72 md:w-96 h-72 md:h-96 bg-teal-500/10 rounded-full blur-[40px] animate-pulse-radiance z-0 pointer-events-none"
    >
    </div>

    <div
      class="relative w-64 md:w-80 h-24 md:h-32 bg-gradient-to-br from-cyan-100 via-teal-300 to-cyan-500 rounded-[50%] shadow-[inset_0_0_20px_rgba(255,255,255,0.8),0_15px_30px_rgba(20,184,166,0.2)] z-30 flex items-center justify-center overflow-hidden border-[6px] border-[#a1c4c0]/30 backdrop-blur-sm"
    >
      <div
        class="absolute inset-0 bg-[repeating-radial-gradient(circle_at_center,transparent,transparent_10px,rgba(255,255,255,0.5)_11px,rgba(255,255,255,0.5)_15px)] animate-ripple-slow opacity-60"
      >
      </div>

      <div
        class="absolute top-[-50%] left-[-20%] w-full h-full bg-white/40 rounded-full blur-[15px] transform rotate-12"
      >
      </div>

      <div
        class="absolute top-[30%] left-[25%] rotate-[20deg] animate-float-leaf-1 shadow-[0_4px_10px_rgba(0,0,0,0.2)]"
      >
        <div
          class="w-10 h-5 md:w-12 md:h-6 bg-gradient-to-br from-emerald-300 to-green-500 rounded-[15px_0_15px_0] border border-white/40"
        >
        </div>
      </div>

      <div
        class="absolute bottom-[35%] right-[30%] -rotate-[40deg] animate-float-leaf-2 shadow-[0_4px_10px_rgba(0,0,0,0.2)]"
      >
        <div
          class="w-8 h-4 md:w-10 md:h-5 bg-gradient-to-br from-emerald-400 to-green-600 rounded-[12px_0_12px_0] border border-white/40"
        >
        </div>
      </div>

      <div
        class="absolute top-[50%] right-[45%] rotate-[80deg] animate-float-leaf-3 shadow-[0_4px_10px_rgba(0,0,0,0.2)]"
      >
        <div
          class="w-6 h-3 md:w-8 md:h-4 bg-gradient-to-br from-green-300 to-emerald-500 rounded-[10px_0_10px_0] border border-white/40"
        >
        </div>
      </div>
    </div>

    <div
      class="relative w-64 md:w-80 h-32 md:h-40 bg-gradient-to-br from-[#e6c29a] via-[#c69a6b] to-[#8b5a2b] rounded-[0_0_150px_150px] shadow-[inset_-10px_-10px_30px_rgba(0,0,0,0.4),0_25px_50px_rgba(0,0,0,0.5)] z-20 -mt-12 md:-mt-16 border-[6px] border-t-0 border-[#a1c4c0]/30"
    >
      <div
        class="absolute inset-0 rounded-[0_0_150px_150px] bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.2)_0%,transparent_60%)]"
      >
      </div>
      <div
        class="absolute inset-0 rounded-[0_0_150px_150px] bg-[repeating-linear-gradient(45deg,transparent,transparent_4px,rgba(0,0,0,0.1)_5px,rgba(0,0,0,0.1)_8px)] mix-blend-overlay"
      >
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-8 inset-x-0 flex flex-col items-center justify-center z-50 pointer-events-none"
  >
    <span
      class="font-sans text-xs md:text-sm font-bold text-teal-300 tracking-[0.5em] uppercase drop-shadow-[0_2px_8px_rgba(45,212,191,0.4)]"
    >
      PURIFICATION LUSTRALE
    </span>
  </div>

  <div
    class="absolute inset-0 z-40 pointer-events-none overflow-hidden mix-blend-screen"
  >
    <div
      class="absolute bottom-[35%] left-[38%] w-2 h-2 bg-white rounded-full shadow-[0_0_10px_rgba(255,255,255,0.8)] animate-sparkle-rise [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute bottom-[30%] right-[35%] w-1.5 h-1.5 bg-teal-200 rounded-full shadow-[0_0_8px_rgba(45,212,191,0.8)] animate-sparkle-rise [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute bottom-[45%] left-[48%] w-2.5 h-2.5 bg-white rounded-full shadow-[0_0_12px_rgba(255,255,255,0.8)] animate-sparkle-rise [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[25%] right-[45%] w-2 h-2 bg-cyan-100 rounded-full shadow-[0_0_10px_rgba(45,212,191,0.6)] animate-sparkle-rise [animation-delay:2.2s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes pulseRadiance {
    0%,
    100% {
      transform: scale(0.95);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.8;
    }
  }
  .animate-pulse-radiance {
    animation: pulseRadiance 4s ease-in-out infinite alternate;
  }

  @keyframes rippleSlow {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  .animate-ripple-slow {
    animation: rippleSlow 3s linear infinite;
  }

  @keyframes floatLeaf1 {
    0%,
    100% {
      transform: translate(0, 0) rotate(20deg);
    }
    50% {
      transform: translate(-4px, -2px) rotate(23deg);
    }
  }
  .animate-float-leaf-1 {
    animation: floatLeaf1 4s infinite ease-in-out;
  }

  @keyframes floatLeaf2 {
    0%,
    100% {
      transform: translate(0, 0) rotate(-40deg);
    }
    50% {
      transform: translate(3px, -4px) rotate(-37deg);
    }
  }
  .animate-float-leaf-2 {
    animation: floatLeaf2 5s infinite ease-in-out 0.5s;
  }

  @keyframes floatLeaf3 {
    0%,
    100% {
      transform: translate(0, 0) rotate(80deg);
    }
    50% {
      transform: translate(-2px, 3px) rotate(77deg);
    }
  }
  .animate-float-leaf-3 {
    animation: floatLeaf3 4.5s infinite ease-in-out 1s;
  }

  @keyframes sparkleRise {
    0% {
      transform: translateY(0) scale(0.5);
      opacity: 0;
    }
    20% {
      opacity: 1;
      transform: translateY(-30px) scale(1.2);
    }
    80% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(-130px) scale(0.5);
      opacity: 0;
    }
  }
  .animate-sparkle-rise {
    animation: sparkleRise 4s infinite ease-out;
  }
</style>
