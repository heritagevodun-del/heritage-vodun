---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fcf9f2] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>

  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(217,119,6,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(217,119,6,0.03)_1px,transparent_1px)] bg-[size:40px_40px] z-0 pointer-events-none"
  >
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[32rem] h-80 md:h-[32rem] bg-amber-50 rounded-full blur-[50px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-30 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-6xl md:text-8xl lg:text-[9rem] font-black text-amber-900/5 uppercase tracking-[0.2em] w-full text-center transition-transform duration-1000 group-hover:scale-105"
    >
      FÂ
    </h1>
  </div>

  <div
    class="relative z-20 flex flex-col items-center justify-center w-72 h-72 md:w-[26rem] md:h-[26rem] mt-8 animate-float"
  >
    <div
      class="absolute inset-0 rounded-full border border-amber-200/60 animate-spin-slow"
    >
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-amber-400 rounded-full shadow-[0_0_10px_#f59e0b]"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-2 h-2 bg-amber-400 rounded-full shadow-[0_0_10px_#f59e0b]"
      >
      </div>
    </div>

    <div
      class="absolute inset-6 rounded-full border border-dashed border-amber-300/50 animate-spin-slow-reverse"
    >
    </div>
    <div
      class="absolute inset-12 rounded-full border border-amber-100/80 shadow-[inset_0_0_20px_rgba(251,191,36,0.1)]"
    >
    </div>

    <div
      class="absolute inset-0 flex items-center justify-center animate-spin-very-slow"
    >
      <div class="w-[70%] h-[70%] border border-amber-200/40 rotate-45"></div>
      <div
        class="absolute w-[70%] h-[70%] border border-amber-200/40 rotate-[135deg]"
      >
      </div>
    </div>

    <div
      class="relative w-32 h-32 md:w-40 md:h-40 bg-white rounded-full shadow-[0_15px_35px_rgba(217,119,6,0.15),inset_0_0_15px_rgba(251,191,36,0.2)] flex items-center justify-center overflow-hidden z-20 border border-amber-50"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_4px,rgba(251,191,36,0.05)_5px,rgba(251,191,36,0.05)_8px)] pointer-events-none"
      >
      </div>

      <div class="relative flex gap-4 md:gap-6 z-10">
        <div class="flex flex-col gap-2 md:gap-3 items-center">
          <div
            class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0s]"
          >
          </div>
          <div class="flex gap-1.5 md:gap-2">
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.2s]"
            >
            </div>
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.2s]"
            >
            </div>
          </div>
          <div class="flex gap-1.5 md:gap-2">
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.4s]"
            >
            </div>
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.4s]"
            >
            </div>
          </div>
          <div
            class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.6s]"
          >
          </div>
        </div>

        <div class="w-px h-[90%] bg-amber-200/60 self-center"></div>

        <div class="flex flex-col gap-2 md:gap-3 items-center">
          <div class="flex gap-1.5 md:gap-2">
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.8s]"
            >
            </div>
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:0.8s]"
            >
            </div>
          </div>
          <div
            class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:1s]"
          >
          </div>
          <div
            class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:1.2s]"
          >
          </div>
          <div class="flex gap-1.5 md:gap-2">
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:1.4s]"
            >
            </div>
            <div
              class="w-2.5 h-2.5 md:w-3 md:h-3 bg-gradient-to-br from-[#78350f] to-[#451a03] rounded-full shadow-[0_2px_4px_rgba(0,0,0,0.2)] animate-node-pulse [animation-delay:1.4s]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-[-10%] flex flex-col items-center">
      <span
        class="font-sans text-sm md:text-base font-bold text-[#3a1005] tracking-[0.3em] uppercase drop-shadow-[0_1px_1px_rgba(255,255,255,0.8)]"
      >
        SCIENCE SOUVERAINE
      </span>
      <span
        class="font-serif text-[0.6rem] md:text-xs text-[#8a4224] tracking-[0.4em] uppercase mt-1 opacity-90"
      >
        ALGORITHME COSMIQUE
      </span>
    </div>
  </div>

  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[25%] w-2 h-2 bg-white blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[25%] right-[25%] w-3 h-3 bg-amber-200 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[35%] left-[45%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 5s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes spinSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spinSlow 20s linear infinite;
  }

  @keyframes spinSlowReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }
  .animate-spin-slow-reverse {
    animation: spinSlowReverse 25s linear infinite;
  }

  @keyframes spinVerySlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-very-slow {
    animation: spinVerySlow 40s linear infinite;
  }

  @keyframes nodePulse {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
      filter: brightness(1.3);
    }
  }
  .animate-node-pulse {
    animation: nodePulse 3s infinite alternate ease-in-out;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-160px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 6s infinite ease-out;
  }
</style>
