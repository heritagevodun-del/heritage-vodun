---
// src/components/art/FaArt.astro
// Allégorie de l'Opon Ifa : La Matrice de Clarté et l'Ordre Intérieur (Lossa-Sa)
// Architecture : Astro + CSS Natif (Zéro JS) - 100% Responsive & Épuré
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 min-h-[30rem] sm:min-h-[28rem] md:h-96 bg-[#050302] rounded-2xl overflow-hidden border border-amber-900/30 shadow-[0_30px_60px_rgba(0,0,0,0.8)] flex flex-col items-center justify-center group p-6 opacity-0 animate-fade-up select-none"
>
  {/* Particules de données spirituelles (Or) */}
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div
      class="absolute w-1 h-1 bg-amber-500 rounded-full opacity-0 shadow-[0_0_8px_#fef08a] animate-float-up left-[25%] bottom-10"
    >
    </div>
    <div
      class="absolute w-1 h-1 bg-amber-500 rounded-full opacity-0 shadow-[0_0_8px_#fef08a] animate-float-up left-[50%] bottom-16 [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute w-1 h-1 bg-amber-400 rounded-full opacity-0 shadow-[0_0_8px_#fef08a] animate-float-up left-[75%] bottom-12 [animation-delay:3s]"
    >
    </div>
  </div>

  {/* Grille algorithmique de fond (Style Plan de Conception) */}
  <div
    class="absolute inset-0 bg-[radial-gradient(rgba(212,175,55,0.04)_1px,transparent_1px)] bg-[size:20px_20px] opacity-40 mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* Le Bokonon (Silhouette en arrière-plan) */}
  <div
    class="absolute top-6 flex flex-col items-center opacity-80 z-10 animate-breathe pointer-events-none"
  >
    <div
      class="w-12 h-8 bg-gradient-to-br from-[#7a1500] to-[#290000] rounded-t-full border-b-2 border-amber-600/40 shadow-lg"
    >
    </div>
    <div
      class="w-9 h-11 bg-[#030101] rounded-b-xl border border-amber-900/30 -mt-1 shadow-inner"
    >
    </div>
    <div
      class="w-48 h-32 bg-gradient-to-b from-[#111] to-[#050302] rounded-t-full border-t border-amber-900/20 -mt-3 shadow-2xl relative"
    >
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[1px] h-full bg-gradient-to-b from-amber-600/20 to-transparent"
      >
      </div>
    </div>
  </div>

  {/* L'OPON IFA (Le Plateau de Divination) */}
  <div
    class="relative z-20 w-64 h-64 sm:w-72 sm:h-72 md:w-80 md:h-80 rounded-full bg-[#451a03] border-2 border-amber-950/60 flex items-center justify-center shadow-[0_20px_40px_rgba(0,0,0,0.9),inset_0_8px_16px_rgba(255,255,255,0.05),inset_0_-12px_24px_rgba(0,0,0,0.8)] mt-20 sm:mt-16 md:mt-12 transition-transform duration-700 md:group-hover:scale-105"
  >
    {/* Visage sculpté d'Esu (Garant de l'équilibre) */}
    <div
      class="absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-6 bg-[#2a1104] rounded-t-full border-t border-amber-500/20 shadow-md flex justify-evenly items-center px-1"
    >
      <div
        class="w-1.5 h-1 bg-black rounded-full shadow-[0_1px_1px_rgba(255,255,255,0.1)]"
      >
      </div>
      <div
        class="w-1.5 h-1 bg-black rounded-full shadow-[0_1px_1px_rgba(255,255,255,0.1)]"
      >
      </div>
    </div>

    {/* L'Iyerosun (Poudre de Divination) */}
    <div
      class="w-[84%] h-[84%] rounded-full bg-gradient-to-b from-[#c5a059] to-[#8a6a32] shadow-[inset_0_6px_12px_rgba(0,0,0,0.8)] flex items-center justify-center gap-x-8 sm:gap-x-10 md:gap-x-12"
    >
      {/* TRACÉ DE LOSSA-SA (Osa-Irosun) */}

      {/* Colonne Gauche (Sa : II, I, I, I) */}
      <div class="flex flex-col gap-y-2.5 md:gap-y-3">
        <div class="fa-mark row-1 flex gap-x-1.5">
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign"
            >
            </div>
          </div>
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign"
            >
            </div>
          </div>
        </div>
        <div
          class="fa-mark row-2 w-8 sm:w-10 h-1.5 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:0.4s]"
          >
          </div>
        </div>
        <div
          class="fa-mark row-3 w-8 sm:w-10 h-1.5 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:0.8s]"
          >
          </div>
        </div>
        <div
          class="fa-mark row-4 w-8 sm:w-10 h-1.5 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:1.2s]"
          >
          </div>
        </div>
      </div>

      {/* Colonne Droite (Lossou : I, I, II, II) */}
      <div class="flex flex-col gap-y-2.5 md:gap-y-3">
        <div
          class="fa-mark row-1 w-8 sm:w-10 h-1.5 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign"
          >
          </div>
        </div>
        <div
          class="fa-mark row-2 w-8 sm:w-10 h-1.5 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:0.4s]"
          >
          </div>
        </div>
        <div class="fa-mark row-3 flex gap-x-1.5">
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:0.8s]"
            >
            </div>
          </div>
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:0.8s]"
            >
            </div>
          </div>
        </div>
        <div class="fa-mark row-4 flex gap-x-1.5">
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:1.2s]"
            >
            </div>
          </div>
          <div
            class="w-3 h-1.5 sm:w-4 sm:h-2 bg-[#5a3c18] rounded-full shadow-inner relative overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-amber-400/80 shadow-[0_0_8px_#fef08a] opacity-0 animate-pulse-sign [animation-delay:1.2s]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Textes HUD Metrique Spécifiques */}
  <div
    class="absolute bottom-4 left-6 font-mono text-[0.55rem] sm:text-[0.65rem] text-amber-600/60 tracking-[0.2em] uppercase pointer-events-none hidden sm:block"
  >
    ORACLE_MATRIX 
  </div>
  <div
    class="absolute top-4 right-6 font-mono text-[0.55rem] sm:text-[0.65rem] text-white/40 tracking-[0.2em] uppercase pointer-events-none flex items-center gap-2"
  >
    <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-ping"></span>
    SYSTEM.DECODE()
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(25px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes breathe {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-6px);
    }
  }
  .animate-breathe {
    animation: breathe 4s ease-in-out infinite alternate;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    20% {
      opacity: 0.6;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-120px) scale(0.5);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 5s infinite linear;
  }

  @keyframes pulseSign {
    0%,
    20%,
    100% {
      opacity: 0;
    }
    50%,
    80% {
      opacity: 1;
    }
  }
  .animate-pulse-sign {
    animation: pulseSign 4s infinite ease-in-out;
  }
</style>
