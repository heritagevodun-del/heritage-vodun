---
/*
  FaArt.astro - CSS Art
  Allégorie de l’Opon Ifa : Le pont entre le code binaire et le système du Fâ.
  Design : Matrice Holographique / Tech-Sombre (Zéro JS)
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-96 md:h-[32rem] bg-[#020101] rounded-2xl overflow-hidden border border-amber-900/30 shadow-[0_20px_50px_rgba(0,0,0,0.8)] flex flex-col items-center justify-center group opacity-0 animate-fade-up select-none"
>
  {/* 1. FOND MATRICIEL & TEXTURE */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(212,175,55,0.08)_0%,transparent_70%)]"
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(212,175,55,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(212,175,55,0.03)_1px,transparent_1px)] bg-[size:30px_30px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_80%)] pointer-events-none"
  >
  </div>

  {/* 2. ANNEAUX CYBERNÉTIQUES (L’Opon 2.0) */}
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[400px] md:h-[400px] flex items-center justify-center pointer-events-none"
  >
    {/* Anneau Externe (Lent) */}
    <div
      class="absolute inset-0 rounded-full border border-amber-500/10 border-dashed animate-[spin_20s_linear_infinite]"
    >
    </div>
    {/* Anneau Interne (Rapide, sens inverse) */}
    <div
      class="absolute inset-8 rounded-full border-2 border-amber-500/20 border-dotted animate-[spin_15s_linear_infinite_reverse]"
    >
    </div>
    {/* Anneau Central (Brillance) */}
    <div
      class="absolute inset-16 rounded-full border border-amber-400/30 shadow-[0_0_30px_rgba(212,175,55,0.1)]"
    >
    </div>
  </div>

  {/* 3. TITRE HOLOGRAPHIQUE (z-30) */}
  <div
    class="absolute top-8 w-full text-center z-30 pointer-events-none transition-transform duration-700 group-hover:scale-105"
  >
    <h2
      class="font-mono text-xl md:text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-500 to-amber-200 tracking-[0.3em] uppercase drop-shadow-[0_0_10px_rgba(212,175,55,0.5)]"
    >
      ODU : LOSSA-SA
    </h2>
    <p
      class="text-[0.6rem] md:text-xs text-amber-500/60 font-mono tracking-[0.4em] mt-2"
    >
      ALGORITHME BINAIRE PRIMORDIAL
    </p>
  </div>

  {/* 4. LE CIRCUIT DE DIVINATION (Signes I et II) */}
  <div
    class="relative z-20 flex gap-12 md:gap-20 items-center justify-center mt-12 p-8 rounded-full"
  >
    {/* Scanner Laser (Ligne lumineuse qui descend) */}
    <div
      class="absolute top-0 left-0 w-full h-[2px] bg-amber-300 shadow-[0_0_15px_#fceeb5,0_0_30px_#d4af37] animate-scan opacity-70 z-30 pointer-events-none"
    >
    </div>

    {/* COLONNE GAUCHE (Sa : II, I, I, I) */}
    <div class="flex flex-col gap-5 md:gap-6">
      {/* Ligne 1 : II */}
      <div class="flex gap-3 justify-center">
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] relative overflow-hidden group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-100"
        >
        </div>
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] relative overflow-hidden group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-100"
        >
        </div>
      </div>
      {/* Ligne 2 : I */}
      <div
        class="w-16 h-2 md:w-20 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] mx-auto group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-200"
      >
      </div>
      {/* Ligne 3 : I */}
      <div
        class="w-16 h-2 md:w-20 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] mx-auto group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-300"
      >
      </div>
      {/* Ligne 4 : I */}
      <div
        class="w-16 h-2 md:w-20 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] mx-auto group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-400"
      >
      </div>
    </div>

    {/* COLONNE DROITE (Lossou : I, I, II, II) */}
    <div class="flex flex-col gap-5 md:gap-6">
      {/* Ligne 1 : I */}
      <div
        class="w-16 h-2 md:w-20 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] mx-auto group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-100"
      >
      </div>
      {/* Ligne 2 : I */}
      <div
        class="w-16 h-2 md:w-20 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] mx-auto group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-200"
      >
      </div>
      {/* Ligne 3 : II */}
      <div class="flex gap-3 justify-center">
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-300"
        >
        </div>
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-300"
        >
        </div>
      </div>
      {/* Ligne 4 : II */}
      <div class="flex gap-3 justify-center">
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-400"
        >
        </div>
        <div
          class="w-6 h-2 md:w-8 md:h-2.5 bg-amber-500/20 border border-amber-400/50 rounded-sm shadow-[0_0_15px_rgba(212,175,55,0.4)] group-hover:bg-amber-400 group-hover:shadow-[0_0_20px_#d4af37] transition-all duration-500 delay-400"
        >
        </div>
      </div>
    </div>
  </div>

  {/* 5. ÉLÉMENTS HUD (Décorations informatiques) */}
  <div
    class="absolute bottom-4 left-6 font-mono text-[0.6rem] text-amber-500/50 tracking-[0.2em] uppercase hidden sm:block"
  >
    <span class="block mb-1">SYS.GEOMANCY.INIT()</span>
    <span class="block text-amber-300/30">MATRIX_SIZE: 256</span>
  </div>
  <div
    class="absolute bottom-4 right-6 font-mono text-[0.6rem] text-amber-500/50 tracking-[0.2em] uppercase flex items-center gap-2"
  >
    <div class="flex flex-col gap-1 items-end">
      <span>PROCESSING_FATE</span>
      <span class="text-amber-300/30">1001 1001 0110 0110</span>
    </div>
    <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-ping"></span>
  </div>
</div>

<style>
  /* --- Animations --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes scan {
    0% {
      top: -10%;
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      top: 110%;
      opacity: 0;
    }
  }
  .animate-scan {
    animation: scan 3s ease-in-out infinite;
  }
</style>
