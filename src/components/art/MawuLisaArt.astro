---
/*
  MawuLisaArt.astro - CSS Art
  Allégorie de la Création : L'Éclipse Originelle et l'Algorithme Binaire.
  Design : Aérospatial / Tech-Sombre (100% CSS, Zéro JS)
  Mise à jour : Dynamique orbitale, éruptions solaires et cratères lunaires.
*/
---

<div
  class="relative w-full max-w-3xl mx-auto my-10 h-[28rem] md:h-[34rem] bg-[#020104] rounded-2xl overflow-hidden border border-white/5 shadow-[0_20px_60px_rgba(0,0,0,0.9)] flex items-center justify-center group opacity-0 animate-fade-up select-none"
>
  {/* 1. L'ESPACE PROFOND ET LA MATRICE */}
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_0%,#020104_70%)] transition-colors duration-1000 group-hover:bg-[radial-gradient(circle_at_center,rgba(251,191,36,0.08)_0%,#020104_70%)]"
  >
  </div>
  <div
    class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.03%22/%3E%3C/svg%3E')] mix-blend-overlay pointer-events-none z-0"
  >
  </div>

  {/* Grille de calcul stellaire */}
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(circle_at_center,black_40%,transparent_80%)] pointer-events-none z-0"
  >
  </div>

  {/* 2. LE SYSTÈME BINAIRE (LISA ET MAWU) */}
  <div
    class="relative w-[300px] h-[300px] md:w-[380px] md:h-[380px] flex items-center justify-center z-20"
  >
    {/* --- LISA : L'ÉNERGIE SOLAIRE (Le 1, l'Actif, la Chaleur) --- */}
    {/* L'Aura Solaire Expansive */}
    <div
      class="absolute w-[80%] h-[80%] rounded-full bg-gradient-to-tr from-orange-500 via-amber-400 to-yellow-200 blur-2xl opacity-40 animate-pulse-solar shadow-[0_0_100px_rgba(251,191,36,0.6)]"
    >
    </div>

    {/* Le Noyau Solaire Interne */}
    <div
      class="absolute w-[60%] h-[60%] rounded-full bg-gradient-to-br from-amber-300 via-orange-500 to-red-600 shadow-[inset_0_0_20px_rgba(255,255,255,0.5),0_0_40px_#f59e0b] animate-spin-slow flex items-center justify-center overflow-hidden"
    >
      {/* Éruptions solaires internes */}
      <div
        class="absolute w-[150%] h-[150%] bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.02%22 numOctaves=%222%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.3%22/%3E%3C/svg%3E')] mix-blend-overlay animate-spin-reverse-slow"
      >
      </div>
    </div>

    {/* Anneau d'Équilibre (L'orbite) */}
    <div
      class="absolute inset-2 rounded-full border border-amber-300/20 border-dashed animate-[spin_40s_linear_infinite]"
    >
    </div>

    {/* --- MAWU : L'ÉNERGIE LUNAIRE (Le 0, le Réceptacle, la Fraîcheur) --- */}
    {/* Positionnée en orbite, elle vient occulter Lisa créant l'Éclipse */}
    <div
      class="absolute w-[58%] h-[58%] rounded-full bg-gradient-to-bl from-slate-700 via-[#070715] to-black border-l border-b border-slate-400/30 shadow-[inset_-10px_-10px_20px_rgba(255,255,255,0.05),0_0_50px_rgba(0,0,0,0.9)] flex items-center justify-center z-30 animate-lunar-transit group-hover:translate-x-4"
    >
      {/* Reliefs Lunaires (Cratères en box-shadow) */}
      <div
        class="absolute top-[20%] left-[25%] w-[15%] h-[15%] rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.8),inset_-1px_-1px_2px_rgba(255,255,255,0.1)] opacity-60"
      >
      </div>
      <div
        class="absolute bottom-[30%] right-[20%] w-[25%] h-[25%] rounded-full shadow-[inset_3px_3px_6px_rgba(0,0,0,0.9),inset_-1px_-1px_2px_rgba(255,255,255,0.05)] opacity-40"
      >
      </div>
      <div
        class="absolute top-[50%] left-[15%] w-[10%] h-[10%] rounded-full shadow-[inset_1px_1px_3px_rgba(0,0,0,0.8)] opacity-50"
      >
      </div>

      {/* Halo argenté sur le bord d'occultation */}
      <div
        class="absolute inset-y-0 right-0 w-[20%] bg-gradient-to-l from-white/10 to-transparent rounded-r-full blur-sm"
      >
      </div>
    </div>

    {/* L'ÉTINCELLE DE SINGULARITÉ (Point d'intersection parfait) */}
    <div
      class="absolute z-40 top-1/2 left-1/2 -translate-x-[20px] -translate-y-[20px] w-2 h-2 bg-white rounded-full blur-[1px] shadow-[0_0_20px_5px_#fff,0_0_40px_10px_#60a5fa,0_0_60px_#fcd34d] animate-flicker-singularity pointer-events-none"
    >
    </div>
  </div>

  {/* 3. LA PLUIE DE CODE SOURCE (0 et 1 générés depuis l'éclipse) */}
  <div
    class="absolute inset-0 z-15 overflow-hidden font-mono text-[0.65rem] font-bold pointer-events-none opacity-20 group-hover:opacity-50 transition-opacity duration-1000"
  >
    <div
      class="absolute top-[-10%] left-[15%] text-slate-300 animate-data-rain [animation-delay:0.2s]"
    >
      0
    </div>
    <div
      class="absolute top-[-10%] left-[25%] text-amber-400 animate-data-rain [animation-delay:1.5s]"
    >
      1
    </div>
    <div
      class="absolute top-[-10%] left-[35%] text-slate-400 animate-data-rain [animation-delay:0.8s]"
    >
      0
    </div>
    <div
      class="absolute top-[-10%] left-[50%] text-amber-300 animate-data-rain [animation-delay:0.1s]"
    >
      1
    </div>
    <div
      class="absolute top-[-10%] left-[65%] text-slate-300 animate-data-rain [animation-delay:2.1s]"
    >
      0
    </div>
    <div
      class="absolute top-[-10%] left-[80%] text-amber-500 animate-data-rain [animation-delay:1.1s]"
    >
      1
    </div>
    <div
      class="absolute top-[-10%] left-[90%] text-slate-500 animate-data-rain [animation-delay:2.7s]"
    >
      0
    </div>
  </div>

  {/* 4. GÉOMÉTRIE AXIALE */}
  <div
    class="absolute top-0 bottom-0 left-1/2 w-[1px] bg-gradient-to-b from-transparent via-white/10 to-transparent z-10"
  >
  </div>
  <div
    class="absolute left-0 right-0 top-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent z-10"
  >
  </div>

  {/* 5. HUD - INTERFACE DE MONITORING DU KERNEL */}
  <div
    class="absolute top-6 left-6 font-mono text-[0.55rem] sm:text-[0.65rem] text-slate-400 tracking-[0.2em] uppercase z-40"
  >
    <span
      class="block text-white/90 drop-shadow-[0_0_5px_rgba(255,255,255,0.5)]"
    >
      MAWU_LISA</span
    >
  </div>

  <div
    class="absolute bottom-6 right-6 font-mono text-[0.55rem] sm:text-[0.65rem] text-amber-200/60 tracking-[0.2em] uppercase text-right z-40 flex items-center gap-2"
  >
    <div class="flex flex-col gap-1 items-end">
      <span>ÉTAT_0 : <span class="text-slate-300">LUNE</span></span>
      <span
        >ÉTAT_1 : <span class="text-amber-400 animate-pulse">SOLEIL</span></span
      >
    </div>
    <span
      class="w-1.5 h-1.5 bg-white rounded-full shadow-[0_0_10px_#fff] animate-ping"
    ></span>
  </div>

  {/* 6. TYPOGRAPHIE MASQUÉE (Signature d'arrière-plan) */}
  <div
    class="absolute inset-x-0 top-[12%] text-center pointer-events-none z-0 transition-transform duration-1000 group-hover:-translate-y-2"
  >
    <span
      class="font-serif text-6xl md:text-8xl font-black text-white/5 tracking-[0.3em] uppercase drop-shadow-[0_4px_10px_rgba(0,0,0,0.5)]"
      >MAWU</span
    >
  </div>
  <div
    class="absolute inset-x-0 bottom-[12%] text-center pointer-events-none z-0 transition-transform duration-1000 group-hover:translate-y-2"
  >
    <span
      class="font-serif text-6xl md:text-8xl font-black text-amber-500/5 tracking-[0.3em] uppercase drop-shadow-[0_4px_10px_rgba(0,0,0,0.5)]"
      >LISA</span
    >
  </div>
</div>

<style>
  /* --- Apparition --- */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* --- Respiration du Soleil (Lisa) --- */
  @keyframes pulseSolar {
    0%,
    100% {
      transform: scale(0.95);
      opacity: 0.3;
      filter: brightness(1);
    }
    50% {
      transform: scale(1.05);
      opacity: 0.5;
      filter: brightness(1.2);
    }
  }
  .animate-pulse-solar {
    animation: pulseSolar 5s infinite alternate ease-in-out;
  }

  @keyframes spinSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spinSlow 30s linear infinite;
  }

  @keyframes spinReverseSlow {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }
  .animate-spin-reverse-slow {
    animation: spinReverseSlow 20s linear infinite;
  }

  /* --- Transit de la Lune (Mawu) --- */
  /* Crée un léger mouvement asymétrique pour simuler l'orbite */
  @keyframes lunarTransit {
    0%,
    100% {
      transform: translate(-8px, -4px);
    }
    50% {
      transform: translate(8px, 4px);
    }
  }
  .animate-lunar-transit {
    animation: lunarTransit 8s infinite alternate ease-in-out;
  }

  /* --- Singularité (Le point de contact éclatant) --- */
  @keyframes flickerSingularity {
    0%,
    100% {
      opacity: 0.8;
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.8);
      filter: brightness(1.5);
    }
    25%,
    75% {
      opacity: 0.5;
      transform: scale(0.8);
    }
  }
  .animate-flicker-singularity {
    animation: flickerSingularity 0.2s infinite alternate;
  }

  /* --- La Pluie du Code Source (Data Rain) --- */
  @keyframes dataRain {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
      filter: blur(1px);
    }
    10% {
      opacity: 1;
      filter: blur(0px);
    }
    80% {
      opacity: 0.5;
    }
    100% {
      transform: translateY(400px) scale(0.5);
      opacity: 0;
      filter: blur(2px);
    }
  }
  .animate-data-rain {
    animation: dataRain 4s infinite linear;
  }
</style>
