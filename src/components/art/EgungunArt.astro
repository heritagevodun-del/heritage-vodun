---
/*
  EgungunArt.astro - CSS Art animé
  Représente le tourbillon majestueux des étoffes et le souffle de l&apos;Ancêtre.
  Optimisé Tailwind v4 - Thème Sombre
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2d1f1b_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-white/5 opacity-0 animate-fade-up"
>
  <div class="relative w-[250px] h-[250px] flex justify-center items-center">
    {/* Énergie spirituelle / Ashe (Lueur dorée) */}
    <div
      class="absolute w-[180px] h-[180px] bg-[radial-gradient(circle,rgba(212,175,55,0.3)_0%,transparent_60%)] rounded-full animate-spirit-pulse z-10"
    >
    </div>

    {/* Le Masque Egungun (Superposition d'étoffes) */}
    <div
      class="relative w-[140px] h-[200px] flex flex-col items-center justify-start animate-mystic-sway z-20"
    >
      {/* Panneaux de tissus volant au vent (Arrière-plan) */}
      <div
        class="absolute top-[80px] w-[40px] h-[100px] bg-[#d4af37] z-0 rounded-b-[20px] left-[-20px] origin-top-right animate-fabric-flap-left shadow-[0_5px_15px_rgba(0,0,0,0.4)]"
      >
      </div>
      <div
        class="absolute top-[80px] w-[40px] h-[100px] bg-[#d4af37] z-0 rounded-b-[20px] right-[-20px] origin-top-left animate-fabric-flap-right shadow-[0_5px_15px_rgba(0,0,0,0.4)]"
      >
      </div>

      {/* Couche de Tissus - Base (Rouge) */}
      <div
        class="absolute top-[40px] w-[140px] h-[160px] bg-[repeating-linear-gradient(45deg,#c62828,#c62828_10px,#8e0000_10px,#8e0000_20px)] rounded-[10px_10px_50px_50px] shadow-[0_5px_15px_rgba(0,0,0,0.4)] z-10"
      >
      </div>

      {/* Couche de Tissus - Milieu (Vert) */}
      <div
        class="absolute top-[20px] w-[110px] h-[140px] bg-[repeating-linear-gradient(-45deg,#2e7d32,#2e7d32_10px,#1b5e20_10px,#1b5e20_20px)] rounded-[10px_10px_50px_50px] shadow-[0_5px_15px_rgba(0,0,0,0.4)] border-b-[5px] border-[#d4af37] z-20"
      >
      </div>

      {/* Couche de Tissus - Sommet (Masque/Visage) */}
      <div
        class="absolute top-0 w-[80px] h-[100px] bg-[#1a1512] border-[4px] border-[#d4af37] rounded-[40px_40px_10px_10px] z-30 flex flex-col items-center pt-[15px] shadow-[0_5px_15px_rgba(0,0,0,0.4)]"
      >
        {/* Cauris sacrés (masque) */}
        <div
          class="w-[8px] h-[14px] bg-[#fdfbf7] rounded-full mb-[5px] shadow-[inset_0_0_3px_rgba(0,0,0,0.5)] relative flex justify-center items-center"
        >
          <div class="w-[2px] h-[10px] bg-[#ccc] rounded-full"></div>
        </div>
        <div
          class="w-[8px] h-[14px] bg-[#fdfbf7] rounded-full mb-[5px] shadow-[inset_0_0_3px_rgba(0,0,0,0.5)] relative flex justify-center items-center"
        >
          <div class="w-[2px] h-[10px] bg-[#ccc] rounded-full"></div>
        </div>
        <div
          class="w-[8px] h-[14px] bg-[#fdfbf7] rounded-full mb-[5px] shadow-[inset_0_0_3px_rgba(0,0,0,0.5)] relative flex justify-center items-center"
        >
          <div class="w-[2px] h-[10px] bg-[#ccc] rounded-full"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Animations complexes du souffle et de l'énergie */
  @keyframes spirit-pulse {
    0% {
      transform: scale(0.9);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.2);
      opacity: 1;
    }
  }
  .animate-spirit-pulse {
    animation: spirit-pulse 3s ease-in-out infinite alternate;
  }

  @keyframes mystic-sway {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    25% {
      transform: translateY(-5px) rotate(-3deg);
    }
    75% {
      transform: translateY(-5px) rotate(3deg);
    }
  }
  .animate-mystic-sway {
    animation: mystic-sway 4s ease-in-out infinite;
  }

  @keyframes fabric-flap-left {
    0%,
    100% {
      transform: rotate(15deg);
    }
    50% {
      transform: rotate(35deg);
    }
  }
  .animate-fabric-flap-left {
    animation: fabric-flap-left 2s ease-in-out infinite;
  }

  @keyframes fabric-flap-right {
    0%,
    100% {
      transform: rotate(-15deg);
    }
    50% {
      transform: rotate(-35deg);
    }
  }
  .animate-fabric-flap-right {
    animation: fabric-flap-right 2.2s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
