---
layout: false;
---

<div
  class="relative w-full max-w-4xl mx-auto my-12 h-[28rem] md:h-[34rem] bg-[#fdfbf7] rounded-3xl overflow-hidden border border-amber-100 shadow-[0_20px_50px_rgba(217,119,6,0.08)] flex items-center justify-center opacity-0 animate-fade-up select-none group"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#ffffff] via-[#fcf9f2] to-[#f5ead5] z-0"
  >
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[32rem] h-80 md:h-[32rem] bg-white rounded-full blur-[60px] z-0 animate-pulse-light"
  >
  </div>

  <div
    class="absolute top-[8%] inset-x-0 flex flex-col items-center justify-center z-30 pointer-events-none px-4"
  >
    <h1
      class="font-serif text-6xl md:text-8xl lg:text-9xl font-black text-amber-900/70 uppercase tracking-[0.15em] w-full text-center drop-shadow-[0_2px_4px_rgba(217,119,6,0.25)] transition-transform duration-1000 group-hover:scale-105"
    >
      EGUNGUN
    </h1>
  </div>

  <div
    class="absolute bottom-0 w-full h-[30%] bg-gradient-to-t from-[#d97706]/15 to-transparent z-10"
  >
  </div>
  <div
    class="absolute bottom-[10%] w-[60%] h-10 bg-amber-900/15 blur-[12px] rounded-[100%] z-15"
  >
  </div>

  <div class="relative z-20 flex flex-col items-center mt-16 animate-float">
    <div
      class="relative w-16 h-20 md:w-20 md:h-24 bg-gradient-to-b from-amber-400 to-amber-600 rounded-t-[40px] z-40 shadow-[0_10px_20px_rgba(0,0,0,0.3)] flex flex-col items-center justify-center gap-2 border-b-4 border-amber-800"
    >
      <div
        class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(255,255,255,0.2)_3px,rgba(255,255,255,0.2)_4px)] rounded-t-[40px]"
      >
      </div>

      <div class="flex gap-1.5 md:gap-2 z-10">
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_3px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_3px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_3px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>
      <div class="flex gap-1.5 md:gap-2 z-10">
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_3px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
          class="w-1.5 h-3 md:w-2 md:h-4 bg-white rounded-full shadow-[inset_0_1px_3px_rgba(0,0,0,0.5)]"
        >
        </div>
      </div>
    </div>

    <div
      class="relative w-48 h-64 md:w-64 md:h-80 -mt-2 z-30 flex justify-center perspective-[1000px]"
    >
      <div
        class="absolute top-0 w-16 md:w-20 h-[85%] bg-gradient-to-b from-indigo-600 to-indigo-900 origin-top shadow-[0_10px_20px_rgba(0,0,0,0.4)] animate-fabric-left-back"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_4px,rgba(0,0,0,0.1)_5px,rgba(0,0,0,0.1)_8px)]"
        >
        </div>
        <div class="absolute bottom-0 w-full h-4 bg-amber-400"></div>
      </div>

      <div
        class="absolute top-0 w-16 md:w-20 h-[85%] bg-gradient-to-b from-indigo-600 to-indigo-900 origin-top shadow-[0_10px_20px_rgba(0,0,0,0.4)] animate-fabric-right-back"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_4px,rgba(0,0,0,0.1)_5px,rgba(0,0,0,0.1)_8px)]"
        >
        </div>
        <div class="absolute bottom-0 w-full h-4 bg-amber-400"></div>
      </div>

      <div
        class="absolute top-0 w-20 md:w-28 h-[95%] bg-gradient-to-b from-rose-600 to-rose-900 origin-top shadow-[0_10px_25px_rgba(0,0,0,0.5)] animate-fabric-left-mid"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_4px,rgba(255,255,255,0.1)_5px,rgba(255,255,255,0.1)_8px)]"
        >
        </div>
        <div
          class="absolute bottom-0 w-full h-6 bg-white flex items-center justify-around px-1"
        >
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
        </div>
      </div>

      <div
        class="absolute top-0 w-20 md:w-28 h-[95%] bg-gradient-to-b from-rose-600 to-rose-900 origin-top shadow-[0_10px_25px_rgba(0,0,0,0.5)] animate-fabric-right-mid"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_4px,rgba(255,255,255,0.1)_5px,rgba(255,255,255,0.1)_8px)]"
        >
        </div>
        <div
          class="absolute bottom-0 w-full h-6 bg-white flex items-center justify-around px-1"
        >
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
          <div class="w-2 h-2 bg-rose-800 rounded-full"></div>
        </div>
      </div>

      <div
        class="absolute top-0 w-24 md:w-32 h-full bg-gradient-to-b from-amber-300 via-amber-500 to-amber-700 origin-top shadow-[0_15px_30px_rgba(0,0,0,0.6)] z-20 flex flex-col items-center animate-fabric-center"
      >
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(90deg,transparent,transparent_3px,rgba(0,0,0,0.05)_4px,rgba(0,0,0,0.05)_6px)]"
        >
        </div>
        <div
          class="w-2 md:w-3 h-full bg-gradient-to-b from-amber-100 to-amber-300 shadow-[0_0_10px_rgba(255,255,255,0.5)]"
        >
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 z-30 pointer-events-none overflow-hidden mix-blend-overlay"
  >
    <div
      class="absolute bottom-[20%] left-[25%] w-2 h-2 bg-white blur-[1px] rounded-full animate-float-up [animation-delay:0s]"
    >
    </div>
    <div
      class="absolute top-[30%] right-[25%] w-3 h-3 bg-amber-200 blur-[2px] rounded-full animate-float-up [animation-delay:1.5s]"
    >
    </div>
    <div
      class="absolute bottom-[40%] right-[15%] w-1.5 h-1.5 bg-white rounded-full animate-float-up [animation-delay:0.8s]"
    >
    </div>
    <div
      class="absolute bottom-[30%] left-[40%] w-2.5 h-2.5 bg-rose-300 blur-[2px] rounded-full animate-float-up [animation-delay:2s]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulseLight {
    0%,
    100% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(0.95);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .animate-pulse-light {
    animation: pulseLight 6s infinite alternate ease-in-out;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }

  @keyframes fabricLeftBack {
    0%,
    100% {
      transform: rotate(-25deg) skewX(-10deg);
    }
    50% {
      transform: rotate(-35deg) skewX(-15deg);
    }
  }
  .animate-fabric-left-back {
    animation: fabricLeftBack 4s infinite ease-in-out;
  }

  @keyframes fabricRightBack {
    0%,
    100% {
      transform: rotate(25deg) skewX(10deg);
    }
    50% {
      transform: rotate(35deg) skewX(15deg);
    }
  }
  .animate-fabric-right-back {
    animation: fabricRightBack 4s infinite ease-in-out;
  }

  @keyframes fabricLeftMid {
    0%,
    100% {
      transform: rotate(-12deg) skewX(-5deg);
    }
    50% {
      transform: rotate(-20deg) skewX(-8deg);
    }
  }
  .animate-fabric-left-mid {
    animation: fabricLeftMid 3.5s infinite ease-in-out;
  }

  @keyframes fabricRightMid {
    0%,
    100% {
      transform: rotate(12deg) skewX(5deg);
    }
    50% {
      transform: rotate(20deg) skewX(8deg);
    }
  }
  .animate-fabric-right-mid {
    animation: fabricRightMid 3.5s infinite ease-in-out;
  }

  @keyframes fabricCenter {
    0%,
    100% {
      transform: scaleY(1);
    }
    50% {
      transform: scaleY(0.95);
    }
  }
  .animate-fabric-center {
    animation: fabricCenter 3s infinite ease-in-out;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.8;
    }
    80% {
      opacity: 0.4;
    }
    100% {
      transform: translateY(-150px) scale(1.2);
      opacity: 0;
    }
  }
  .animate-float-up {
    animation: floatUp 6s infinite ease-out;
  }
</style>
