---
/* GlobalLightbox.astro 
  Détecte automatiquement toutes les images de l&apos;article et permet de les afficher en plein écran.
*/
---

{/* La Fenêtre Modale (Cachée par défaut) */}
<dialog
  id="global-lightbox"
  class="backdrop:bg-[#050505]/95 bg-transparent p-0 w-screen h-screen max-w-none max-h-none border-none m-0 focus:outline-none"
>
  <div
    class="flex flex-col items-center justify-center w-full h-full p-4 md:p-10 cursor-zoom-out"
    id="lightbox-close-zone"
  >
    <img
      id="lightbox-img"
      src=""
      alt="Zoom"
      class="max-w-full max-h-[85vh] object-contain rounded-md shadow-[0_0_50px_rgba(212,175,55,0.15)] border border-white/10"
    />

    <span
      class="text-[#d4af37] font-mono text-[10px] tracking-[0.3em] uppercase mt-6 border border-[#d4af37]/30 px-6 py-2 rounded-full pointer-events-none"
    >
      Fermer l&apos;image
    </span>
  </div>
</dialog>

<script>
  function initLightbox() {
    const dialog = document.getElementById(
      "global-lightbox",
    ) as HTMLDialogElement;
    const lightboxImg = document.getElementById(
      "lightbox-img",
    ) as HTMLImageElement;
    const closeZone = document.getElementById("lightbox-close-zone");

    if (!dialog || !lightboxImg) return;

    // Cible toutes les images dans la balise principale de l'article
    // Ajustez 'main img' ou 'article img' selon la structure de votre site
    const images = document.querySelectorAll(
      "article img, main img, .prose img",
    );

    images.forEach((img: any) => {
      // Ajoute le curseur de zoom et un petit effet de survol
      img.classList.add(
        "cursor-zoom-in",
        "transition-transform",
        "duration-300",
        "hover:scale-[1.02]",
        "hover:shadow-lg",
      );

      // Au clic, on copie la source de l'image dans la modale et on l'ouvre
      img.addEventListener("click", () => {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt || "Image de l'article";
        dialog.showModal();
      });
    });

    // Fermer la modale au clic sur la zone ou le fond
    if (closeZone) {
      closeZone.addEventListener("click", () => dialog.close());
    }
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  // Exécution au chargement classique et lors des transitions Astro
  document.addEventListener("DOMContentLoaded", initLightbox);
  document.addEventListener("astro:page-load", initLightbox);
</script>

<style>
  /* Animations fluides */
  dialog[open] {
    animation: fadeIn 0.3s ease-out forwards;
  }

  dialog::backdrop {
    background: rgba(5, 5, 5, 0.95);
    animation: fadeIn 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.98);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Empêche la page de défiler derrière l'image zoomée */
  html:has(dialog[open]) {
    overflow: hidden;
  }
</style>
