---
/* src/components/HeroSlider.astro - Version Premium Sombre avec astro:assets */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

// Récupération dynamique de toutes les images du dossier assets
const assetsImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,webp}",
);

// On référence les images par leur vrai nom (sans le / de public)
const rawSlides = [
  { img: "divinites-vodun.jpeg", alt: "Cérémonie des Divinités" },
  { img: "jumeaux-ibeji.jpeg", alt: "Spiritualité et Esprit" },
];

// Construction du tableau final avec les résolveurs d'images
const slides = rawSlides.map((slide) => {
  const expectedPath = `/src/assets/${slide.img}`;
  return {
    ...slide,
    imageFn: assetsImages[expectedPath] || null,
  };
});
---

<div class="absolute inset-0 z-0 overflow-hidden bg-dark-bg">
  {
    slides.map((slide, index) => (
      <div
        class={`hero-slide absolute inset-0 transition-opacity duration-[2500ms] ease-in-out will-change-opacity ${index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"}`}
      >
        {/* LOGIQUE D'AFFICHAGE OPTIMISÉE AVEC ASTRO:ASSETS */}
        {slide.imageFn ? (
          <Image
            src={slide.imageFn()}
            alt={slide.alt}
            format="webp"
            quality={85}
            class={`hero-img w-full h-full object-cover transition-transform duration-[8000ms] ease-out ${index === 0 ? "scale-100" : "scale-110"}`}
            loading={index === 0 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "auto"}
            decoding="async"
          />
        ) : (
          <div
            class={`hero-img w-full h-full bg-dark-surface transition-transform duration-[8000ms] ease-out ${index === 0 ? "scale-100" : "scale-110"}`}
          />
        )}

        {/* Overlay progressif : assombrit le fond pour faire ressortir l'Or */}
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.3)_0%,rgba(5,5,5,0.85)_100%)] pointer-events-none" />
        {/* Dégradé de base pour le fondu avec la section suivante */}
        <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark-bg to-transparent pointer-events-none" />
      </div>
    ))
  }
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const slides = document.querySelectorAll(".hero-slide");
    // On cible la classe spécifique .hero-img pour inclure les div fallback si une image manque
    const images = document.querySelectorAll(".hero-img");
    if (slides.length <= 1) return;

    let current = 0;
    const total = slides.length;

    const nextSlide = () => {
      // Retirer le slide actif actuel
      slides[current].classList.remove("opacity-100", "z-10");
      slides[current].classList.add("opacity-0", "z-0");
      images[current].classList.add("scale-110");
      images[current].classList.remove("scale-100");

      // Passer au suivant
      current = (current + 1) % total;

      // Activer le nouveau slide
      slides[current].classList.remove("opacity-0", "z-0");
      slides[current].classList.add("opacity-100", "z-10");
      images[current].classList.remove("scale-110");
      images[current].classList.add("scale-100");
    };

    const interval = setInterval(nextSlide, 7000); // 7s pour laisser le temps au zoom de se déployer

    document.addEventListener(
      "astro:before-swap",
      () => {
        clearInterval(interval);
      },
      { once: true },
    );
  });
</script>
