---
import { Redis } from "@upstash/redis";

// Initialisation de la connexion Redis via les variables d'environnement
const redis = Redis.fromEnv();

export interface Props {
  slug: string; // L'identifiant unique de l'article
}

const { slug } = Astro.props;

// Incrémente le compteur pour cet article de 1 et récupère le nouveau total
const views = await redis.incr(`pageviews:${slug}`);
---

<div
  class="flex items-center space-x-2 text-sm text-emerald-800/80 font-montserrat font-medium py-2"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-5 w-5 opacity-70"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
    ></path>
  </svg>
  <span>{views} {views > 1 ? "lectures" : "lecture"}</span>
</div>
