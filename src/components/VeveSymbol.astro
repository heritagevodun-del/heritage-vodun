---
// src/components/VeveSymbol.astro
interface Props {
  type: "legba" | "sakpata" | "heviesso" | "dan";
  className?: string;
}

const { type, className = "" } = Astro.props;

// Couleurs rituelles adaptées au thème sombre avec lueur (Glow)
const colorMap = {
  legba: "text-[#a0522d] drop-shadow-[0_0_8px_rgba(160,82,45,0.6)]", // Terre brûlée (Rouge/Sang)
  sakpata: "text-[#8B4513] drop-shadow-[0_0_8px_rgba(139,69,19,0.6)]", // Brun profond (Terre)
  heviesso: "text-gold drop-shadow-[0_0_8px_rgba(212,175,55,0.6)]", // Or électrique (Foudre)
  dan: "text-cyan-400 drop-shadow-[0_0_8px_rgba(34,211,238,0.6)]", // Cyan mystique (Arc-en-ciel)
};

const activeColorClass = colorMap[type];
---

<div
  class={`relative w-16 h-16 flex items-center justify-center opacity-80 transition-all duration-300 hover:scale-110 hover:rotate-6 hover:opacity-100 ${activeColorClass} ${type} ${className}`}
  aria-hidden="true"
>
  {/* Axes de la croix (Héritent de la couleur via bg-current) */}
  <div class="absolute w-0.5 h-full bg-current rounded-sm axis-v"></div>
  <div class="absolute w-full h-0.5 bg-current rounded-sm axis-h"></div>

  {/* Cœur du symbole (Hérite de la couleur via border-current) */}
  <div
    class="relative w-[40%] h-[40%] border border-current flex items-center justify-center rotate-45 core-symbol transition-all duration-300"
  >
    <div
      class="w-[60%] h-[60%] border border-current rounded-full inner-circle transition-all duration-300"
    >
    </div>
  </div>

  {/* Points cardinaux spécifiques à Legba */}
  {
    type === "legba" && (
      <>
        <span class="absolute w-1.5 h-1.5 bg-current rounded-full top-0" />
        <span class="absolute w-1.5 h-1.5 bg-current rounded-full bottom-0" />
        <span class="absolute w-1.5 h-1.5 bg-current rounded-full right-0" />
        <span class="absolute w-1.5 h-1.5 bg-current rounded-full left-0" />
      </>
    )
  }
</div>

<style>
  /* --- VARIATIONS STRUCTURELLES PAR DIVINITÉ --- */

  /* LEGBA (Le Carrefour - Complexe) */
  .legba .core-symbol {
    border-style: double;
    border-width: 3px;
  }

  /* SAKPATA (La Terre - Standard, conserve la forme de base) */

  /* HEVIESSO (La Foudre - Tranchant) */
  .heviesso .core-symbol {
    border-radius: 0;
    border-width: 2px;
  }
  .heviesso .inner-circle {
    border-radius: 0; /* Devient un carré interne */
    transform: rotate(45deg);
  }

  /* DAN (Le Serpent - Ondulation/Courbe) */
  .dan .axis-v {
    height: 80%;
  }
  .dan .axis-h {
    width: 80%;
  }
  .dan .core-symbol {
    border-radius: 50%; /* Devient un cercle parfait */
    border-width: 2px;
    border-style: dotted;
  }
</style>
