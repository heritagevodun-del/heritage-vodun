---
const currentPath = Astro.url.pathname;

const navLinks = [
  { name: "Accueil", href: "/" },
  { name: "Lexique", href: "/lexique" },
  { name: "Récits", href: "/blog" },
  { name: "Mission", href: "/about" },
  { name: "Le Label", href: "/label" },
  { name: "Contact", href: "/contact" },
];
---

<nav
  id="nav-menu"
  class="hidden lg:flex absolute lg:relative top-full left-0 w-full lg:w-auto bg-[#050505]/95 lg:bg-transparent backdrop-blur-xl lg:backdrop-blur-none flex-col lg:flex-row items-center py-6 lg:py-0 px-4 lg:px-0 gap-4 lg:gap-6 xl:gap-8 border-b lg:border-none border-white/10 shadow-2xl lg:shadow-none transition-all duration-300 z-50"
>
  {
    navLinks.map((link) => {
      const isActive =
        currentPath === link.href ||
        (link.href !== "/" && currentPath.startsWith(link.href));

      return (
        <a
          href={link.href}
          class={`w-full lg:w-auto py-3 lg:py-0 font-sans font-bold uppercase text-[0.8rem] xl:text-[0.85rem] tracking-widest transition-all duration-300 relative group text-center lg:text-left rounded-md lg:rounded-none hover:bg-white/5 lg:hover:bg-transparent ${
            isActive
              ? "text-gold bg-white/5 lg:bg-transparent"
              : "text-gray-300 hover:text-gold"
          }`}
        >
          {link.name}
          <span
            class={`hidden lg:block absolute -bottom-2 left-0 h-[2px] bg-gold transition-all duration-300 ${isActive ? "w-full" : "w-0 group-hover:w-full"}`}
          />
        </a>
      );
    })
  }

  {/* SÉLECTEUR DE LANGUE (i18n) */}
  <div
    class="relative group mt-4 lg:mt-0 w-full lg:w-auto flex justify-center lg:ml-2"
  >
    <button
      id="lang-btn"
      class="flex items-center justify-center gap-1.5 text-gray-300 hover:text-gold transition-colors font-sans uppercase text-sm tracking-wider px-4 py-3 lg:px-2 lg:py-2 rounded-md hover:bg-white/5 lg:hover:bg-transparent w-full lg:w-auto cursor-pointer"
      aria-label="Changer de langue"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="2" y1="12" x2="22" y2="12"></line>
        <path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path>
      </svg>
      <span class="inline">FR</span>
    </button>

    {/* Menu Déroulant des Langues */}
    <div
      id="lang-dropdown"
      class="absolute top-full right-auto lg:left-1/2 lg:-translate-x-1/2 mt-1 w-48 lg:w-40 bg-dark-surface border border-white/10 rounded-lg shadow-2xl opacity-0 invisible lg:group-hover:opacity-100 lg:group-hover:visible transition-all duration-300 flex flex-col overflow-hidden z-50 origin-top"
    >
      <a
        href="/fon"
        class="px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors flex items-center gap-3"
        >🇧🇯 Fongbé</a
      >
      <a
        href="/"
        class="px-4 py-3 text-sm text-gold bg-white/5 hover:bg-gold/10 transition-colors flex items-center gap-3 border-b border-white/5"
        >🇫🇷 Français</a
      >
      <a
        href="/en"
        class="px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors flex items-center gap-3 border-b border-white/5"
        >🇬🇧 English</a
      >
      <a
        href="/pt"
        class="px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors flex items-center gap-3 border-b border-white/5"
        >🇵🇹 Português</a
      >
      <a
        href="/es"
        class="px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors flex items-center gap-3 border-b border-white/5"
        >🇪🇸 Español</a
      >
      <a
        href="/yo"
        class="px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors flex items-center gap-3 border-b border-white/5"
        >🇳🇬 Yorùbá</a
      >
    </div>
  </div>

  {/* BOUTON ORACLE PREMIUM */}
  <a
    href="#"
    class="open-oracle w-full max-w-[280px] lg:w-auto mt-6 lg:mt-0 flex items-center justify-center gap-2.5 px-4 lg:px-5 py-4 lg:py-1.5 rounded-full border border-gold lg:border-green-500/30 hover:border-gold lg:hover:bg-gold/5 bg-gold/10 lg:bg-transparent text-gold lg:text-gray-300 hover:text-gold transition-all duration-300 shadow-[0_5px_15px_rgba(212,175,55,0.2)] lg:shadow-none lg:hover:-translate-y-0.5 mx-auto xl:ml-2"
  >
    <span class="relative flex h-2 w-2">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold lg:bg-green-400 lg:opacity-75 opacity-100"
      ></span>
      <span
        class="relative inline-flex rounded-full h-2 w-2 bg-gold lg:bg-green-500"
      ></span>
    </span>
    <span
      class="font-serif lg:font-sans font-bold text-[0.95rem] lg:text-[0.75rem] xl:text-[0.8rem] uppercase tracking-[2px] lg:tracking-[1px] whitespace-nowrap"
    >
      Parler à l'Oracle
    </span>
  </a>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    const langBtn = document.getElementById("lang-btn");
    const langDropdown = document.getElementById("lang-dropdown");

    if (langBtn && langDropdown) {
      const newLangBtn = langBtn.cloneNode(true);
      langBtn.parentNode?.replaceChild(newLangBtn, langBtn);

      newLangBtn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        const isClosed = langDropdown.classList.contains("opacity-0");
        if (isClosed) {
          langDropdown.classList.remove("opacity-0", "invisible");
          langDropdown.classList.add("opacity-100", "visible");
        } else {
          langDropdown.classList.add("opacity-0", "invisible");
          langDropdown.classList.remove("opacity-100", "visible");
        }
      });

      document.addEventListener("click", (e) => {
        if (
          !newLangBtn.contains(e.target as Node) &&
          !langDropdown.contains(e.target as Node)
        ) {
          langDropdown.classList.add("opacity-0", "invisible");
          langDropdown.classList.remove("opacity-100", "visible");
        }
      });
    }
  });
</script>
