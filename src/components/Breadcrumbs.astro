---
// src/components/Breadcrumbs.astro

interface Props {
  // Optionnel : Permet de forcer une hiérarchie spécifique (ex: pour les articles)
  customPaths?: { label: string; href: string }[];
}

const { customPaths } = Astro.props;
const currentPath = Astro.url.pathname;

// Logique pour construire automatiquement le fil d'ariane si customPaths n'est pas fourni
let paths = [{ label: "Accueil", href: "/" }];

if (customPaths) {
  paths = [...paths, ...customPaths];
} else {
  // Découpage de l'URL actuelle (ex: /posts/legba -> ['posts', 'legba'])
  const pathSegments = currentPath
    .split("/")
    .filter((segment) => segment !== "");

  let accumulatedPath = "";
  pathSegments.forEach((segment, index) => {
    accumulatedPath += `/${segment}`;

    // Remplacement des tirets par des espaces et mise en majuscule de la première lettre
    let formattedLabel = segment.replace(/-/g, " ");
    formattedLabel =
      formattedLabel.charAt(0).toUpperCase() + formattedLabel.slice(1);

    // Si on est dans les articles, on peut renommer "Posts" ou "Blog" pour l'UI
    if (segment.toLowerCase() === "posts") {
      formattedLabel = "Articles";
    }

    paths.push({
      label: formattedLabel,
      href: accumulatedPath,
    });
  });
}

// Construction du script JSON-LD pour le SEO (Schema.org BreadcrumbList)
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: paths.map((path, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: path.label,
    item: new URL(path.href, Astro.site || Astro.url.origin).toString(),
  })),
};
---

<nav
  aria-label="Fil d'Ariane"
  class="w-full max-w-4xl mx-auto px-4 py-4 md:py-6 text-sm text-gray-400"
>
  <ol class="flex flex-wrap items-center gap-2 m-0 p-0 list-none font-sans">
    {
      paths.map((path, index) => {
        const isLast = index === paths.length - 1;

        return (
          <li class="flex items-center">
            {isLast ? (
              // L'élément actuel (non cliquable, couleur or ou blanche)
              <span
                class="text-gold-vodun font-semibold uppercase tracking-wider"
                aria-current="page"
              >
                {path.label}
              </span>
            ) : (
              // Les éléments parents (cliquables, avec effet de survol)
              <>
                <a
                  href={path.href}
                  class="hover:text-white transition-colors duration-200 uppercase tracking-wider"
                >
                  {path.label}
                </a>
                {/* Le séparateur (Chevron SVG) */}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 mx-2 text-gray-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

{/* Injection du script SEO dans le <head> de la page via Astro */}
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<style>
  /* Ajout d'une couleur Tailwind personnalisée si vous ne l'avez pas configurée globalement */
  .text-gold-vodun {
    color: #d4af37;
  }
</style>
