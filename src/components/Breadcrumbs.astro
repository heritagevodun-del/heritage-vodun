---
// src/components/Breadcrumbs.astro

interface Props {
  customPaths?: { label: string; href: string }[];
}

const { customPaths } = Astro.props;
const currentPath = Astro.url.pathname;

let paths = [{ label: "Accueil", href: "/" }];

if (customPaths) {
  paths = [...paths, ...customPaths];
} else {
  const pathSegments = currentPath
    .split("/")
    .filter((segment) => segment !== "");

  let accumulatedPath = "";
  pathSegments.forEach((segment) => {
    accumulatedPath += `/${segment}`;

    let formattedLabel = segment.replace(/-/g, " ");
    formattedLabel =
      formattedLabel.charAt(0).toUpperCase() + formattedLabel.slice(1);

    if (segment.toLowerCase() === "posts") {
      formattedLabel = "Articles";
    }

    paths.push({
      label: formattedLabel,
      href: accumulatedPath,
    });
  });
}

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: paths.map((path, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: path.label,
    item: new URL(path.href, Astro.site || Astro.url.origin).toString(),
  })),
};
---

<nav
  aria-label="Fil d'Ariane"
  class="w-full bg-dark-surface border border-white/5 rounded-xl px-5 py-3.5 my-6 backdrop-blur-sm shadow-sm"
>
  <ol
    class="flex flex-wrap items-center gap-1.5 m-0 p-0 list-none font-sans text-xs md:text-sm tracking-wider"
  >
    {
      paths.map((path, index) => {
        const isLast = index === paths.length - 1;

        return (
          <li class="flex items-center">
            {isLast ? (
              <span
                class="text-gold font-bold uppercase drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)]"
                aria-current="page"
              >
                {path.label}
              </span>
            ) : (
              <>
                <a
                  href={path.href}
                  class="text-vodun-cendre hover:text-gold font-medium uppercase transition-colors duration-200"
                >
                  {path.label}
                </a>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-3.5 w-3.5 mx-2 text-gold/40 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(schemaData)}
/>
