---
// src/components/Newsletter.astro - Version Tailwind v4 Premium
---

<section
  class="py-24 px-6 bg-gradient-to-b from-dark-bg to-dark-surface flex justify-center border-t border-white/5 relative overflow-hidden"
>
  {/* Lueur d'arrière-plan */}
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gold/5 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div class="w-full max-w-4xl relative z-10">
    <div
      class="bg-dark-surface border border-gold/30 rounded-2xl p-10 md:p-16 text-center relative shadow-[0_10px_40px_rgba(0,0,0,0.5),0_0_20px_rgba(212,175,55,0.1)] animate-[breathing-glow_6s_infinite_ease-in-out]"
    >
      {/* Ornement Haut */}
      <div class="text-gold text-2xl mb-6 select-none">✦</div>

      <div class="max-w-2xl mx-auto">
        <span
          class="block text-gold text-xs uppercase tracking-[0.25em] font-bold mb-4"
          >Le Cercle des Initiés</span
        >
        <h2
          class="font-serif text-4xl md:text-5xl text-white mb-6 leading-tight"
        >
          Restez connecté à la Source
        </h2>
        <p class="font-sans text-gray-400 text-lg leading-relaxed mb-10">
          Rejoignez-nous. Recevez les dates des cérémonies, la sagesse du Fâ et
          l&apos;essence de nos traditions directement dans votre cœur (et votre
          boîte mail).
        </p>

        <form id="form-newsletter" class="w-full max-w-md mx-auto">
          <input
            type="hidden"
            name="access_key"
            value="90fd8cd4-08c6-427b-9e44-ae19d6c3f487"
          />
          <input
            type="hidden"
            name="subject"
            value="Nouvel abonné Newsletter (Site Web)"
          />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display: none;"
          />

          <div class="flex flex-col md:flex-row gap-3 justify-center">
            <input
              type="email"
              name="email"
              placeholder="Votre adresse email..."
              required
              class="flex-1 px-5 py-4 rounded-md border border-white/10 bg-white/5 text-white font-sans focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-all duration-300 placeholder-gray-500"
              aria-label="Adresse email pour la newsletter"
            />
            <button
              type="submit"
              class="bg-gold hover:bg-gold-hover text-black border border-gold hover:border-gold-hover px-8 py-4 rounded-md font-bold uppercase tracking-wider transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:grayscale min-w-[160px] shadow-[0_4px_15px_rgba(212,175,55,0.3)] hover:shadow-[0_6px_20px_rgba(212,175,55,0.5)] hover:-translate-y-0.5 btn-inscription flex items-center justify-center"
            >
              <span class="btn-text">S&apos;inscrire</span>
              <span class="btn-loader hidden">...</span>
            </button>
          </div>
          <p
            class="mt-4 font-bold min-h-[24px] text-sm transition-colors duration-300 message-resultat"
            id="resultat-newsletter"
          >
          </p>
        </form>

        <p class="text-xs text-gray-600 mt-8 italic">
          Nous respectons votre tranquillité. Pas de spam.
        </p>
      </div>

      {/* Ornement Bas */}
      <div class="text-gold text-2xl mt-8 select-none">✦</div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const formNews = document.getElementById(
      "form-newsletter",
    ) as HTMLFormElement;
    const resNews = document.getElementById("resultat-newsletter");
    const btn = document.querySelector(".btn-inscription") as HTMLButtonElement;
    const btnText = document.querySelector(".btn-text") as HTMLElement;
    const btnLoader = document.querySelector(".btn-loader") as HTMLElement;

    if (formNews && resNews && btn) {
      formNews.addEventListener("submit", function (e) {
        e.preventDefault();
        const formData = new FormData(formNews);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        resNews.innerHTML = "";
        resNews.className =
          "mt-4 font-bold min-h-[24px] text-sm transition-colors duration-300 message-resultat";
        btn.disabled = true;

        if (btnText) btnText.classList.add("hidden");
        if (btnLoader) btnLoader.classList.remove("hidden");

        fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        })
          .then(async (response) => {
            if (response.status == 200) {
              resNews.innerHTML =
                "✨ Merci. Votre inscription est confirmée. Bienvenue dans le Cercle.";
              resNews.classList.add("text-gold");
              formNews.reset();
            } else {
              resNews.innerHTML =
                "Une erreur est survenue. Veuillez réessayer.";
              resNews.classList.add("text-red-500");
            }
          })
          .catch((error) => {
            resNews.innerHTML = "Erreur de connexion.";
            resNews.classList.add("text-red-500");
            console.error(error);
          })
          .finally(() => {
            btn.disabled = false;
            if (btnText) btnText.classList.remove("hidden");
            if (btnLoader) btnLoader.classList.add("hidden");
          });
      });
    }
  });
</script>

<style>
  /* L'animation de respiration de la carte (seul style gardé pour les performances GPU) */
  @keyframes breathing-glow {
    0%,
    100% {
      box-shadow:
        0 10px 40px rgba(0, 0, 0, 0.5),
        0 0 20px rgba(212, 175, 55, 0.1);
      border-color: rgba(212, 175, 55, 0.3);
    }
    50% {
      box-shadow:
        0 15px 50px rgba(0, 0, 0, 0.6),
        0 0 35px rgba(212, 175, 55, 0.3);
      border-color: rgba(212, 175, 55, 0.6);
    }
  }
</style>
