---
/* ArticleImage.astro - Version Robuste avec Script Scoped */
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="article-image-container my-12 group">
  {/* L'IMAGE DANS L'ARTICLE */}
  <div
    class="lightbox-trigger relative overflow-hidden rounded-xl border border-white/10 shadow-2xl cursor-zoom-in bg-[#0a0a0a]"
  >
    <img
      src={src}
      alt={alt}
      class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div
      class="absolute inset-0 bg-gold/0 group-hover:bg-gold/5 transition-colors duration-300 flex items-center justify-center"
    >
      <span
        class="opacity-0 group-hover:opacity-100 text-gold text-[10px] font-mono bg-black/80 px-4 py-2 rounded-full border border-gold/30 transition-all uppercase tracking-widest"
      >
        Voir en grand
      </span>
    </div>
  </div>

  {
    caption && (
      <figcaption class="mt-4 text-center text-gray-500 italic font-serif text-sm">
        {caption}
      </figcaption>
    )
  }

  {/* LA MODALE (LIGHTBOX) */}
  <dialog
    class="lightbox-modal backdrop:bg-black/95 p-0 bg-transparent border-none outline-none w-full h-full max-w-none max-h-none"
  >
    <div class="w-full h-full flex flex-col items-center justify-center p-4">
      <img
        src={src}
        alt={alt}
        class="max-w-full max-h-[80vh] object-contain rounded shadow-2xl border border-white/10"
      />
      <div class="mt-8 flex flex-col items-center gap-4">
        <p class="text-white font-serif italic text-center">{alt}</p>
        <button
          class="close-button text-gold font-mono text-[10px] uppercase tracking-[0.3em] border border-gold/30 px-8 py-3 rounded-full hover:bg-gold hover:text-black transition-all"
        >
          Fermer l&apos;image
        </button>
      </div>
    </div>
  </dialog>
</figure>

<script>
  // Ce script s'exécute côté client et gère tous les composants Image du site
  function setupLightboxes() {
    const containers = document.querySelectorAll(".article-image-container");

    containers.forEach((container) => {
      const trigger = container.querySelector(".lightbox-trigger");
      const modal = container.querySelector(
        ".lightbox-modal",
      ) as HTMLDialogElement;
      const closeBtn = container.querySelector(".close-button");

      if (trigger && modal) {
        // Ouvrir au clic sur l'image
        trigger.addEventListener("click", () => {
          modal.showModal();
        });

        // Fermer au clic sur le bouton
        closeBtn?.addEventListener("click", (e) => {
          e.stopPropagation();
          modal.close();
        });

        // Fermer au clic sur le fond noir
        modal.addEventListener("click", (e) => {
          if (e.target === modal) modal.close();
        });
      }
    });
  }

  // Initialisation au chargement et lors de la navigation Astro
  setupLightboxes();
  document.addEventListener("astro:after-swap", setupLightboxes);
</script>

<style>
  dialog[open] {
    animation: zoomIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  dialog::backdrop {
    animation: fadeIn 0.3s ease-out forwards;
  }

  @keyframes zoomIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  html:has(dialog[open]) {
    overflow: hidden;
  }
</style>
