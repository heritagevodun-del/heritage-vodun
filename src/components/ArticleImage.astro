---
/* Composant Image avec Zoom Plein Écran (Lightbox) */
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;

// Génère un ID unique basé sur le nom du fichier image
const imageId =
  src
    .split("/")
    .pop()
    ?.replace(/[^a-z0-9]/gi, "") || Math.random().toString(36).substring(7);
---

<figure class="my-12 group">
  {/* L'IMAGE MINIATURE (Celle qui est dans l'article) */}
  <div
    class="relative overflow-hidden rounded-xl border border-white/10 shadow-2xl cursor-zoom-in bg-dark-surface"
    onclick={`document.getElementById('lightbox-${imageId}').showModal()`}
  >
    <img
      src={src}
      alt={alt}
      class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    {/* Overlay discret au survol */}
    <div
      class="absolute inset-0 bg-gold/0 group-hover:bg-gold/5 transition-colors duration-300 flex items-center justify-center"
    >
      <span
        class="opacity-0 group-hover:opacity-100 text-gold text-xs font-mono bg-black/60 px-3 py-1 rounded-full transition-opacity"
      >
        [ CLIQUER POUR AGRANDIR ]
      </span>
    </div>
  </div>

  {
    caption && (
      <figcaption class="mt-4 text-center text-gray-500 italic font-serif text-sm">
        {caption}
      </figcaption>
    )
  }

  {/* LA FENÊTRE PLEIN ÉCRAN (Invisible par défaut) */}
  <dialog
    id={`lightbox-${imageId}`}
    class="backdrop:bg-black/95 p-0 bg-transparent overflow-hidden focus:outline-none w-screen h-screen max-w-none max-h-none border-none"
    onclick="this.close()"
  >
    <div
      class="w-full h-full flex flex-col items-center justify-center p-4 md:p-12"
    >
      <img
        src={src}
        alt={alt}
        class="max-w-full max-h-[85vh] object-contain rounded shadow-[0_0_50px_rgba(0,0,0,0.8)] border border-white/5"
      />

      <div class="mt-8 flex flex-col items-center gap-2">
        <p class="text-white/80 font-serif italic text-center text-lg">{alt}</p>
        <button
          class="text-gold font-mono text-[10px] uppercase tracking-[0.3em] border border-gold/30 px-6 py-2 rounded-full hover:bg-gold hover:text-black transition-all"
        >
          Fermer l&apos;image
        </button>
      </div>
    </div>
  </dialog>
</figure>

<style>
  /* Animation d'ouverture fluide */
  dialog[open] {
    animation: zoomIn 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
  }

  dialog::backdrop {
    animation: fadeBackdrop 0.4s ease-out forwards;
  }

  @keyframes zoomIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fadeBackdrop {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Bloquer le scroll de la page principale quand le zoom est ouvert */
  html:has(dialog[open]) {
    overflow: hidden;
  }
</style>
