---
/*
  SakpataAltar.astro - CSS Art
  Représente le Gozen (jarre sacrée) et l&apos;énergie tellurique d&apos;Ayinon.
  Optimisé Tailwind v4 - Thème Sombre
*/
---

<div
  class="w-full h-80 bg-[radial-gradient(circle_at_center,#2a120e_0%,#050505_100%)] flex justify-center items-center relative overflow-hidden mb-12 rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.5)] border border-white/5 opacity-0 animate-fade-up"
>
  {/* Lueur dorée subtile pour intégration au thème */}
  <div
    class="absolute top-0 right-0 w-48 h-48 bg-gold/5 rounded-full blur-[50px] pointer-events-none z-0"
  >
  </div>

  <div class="relative w-[200px] h-[220px] flex justify-center items-end">
    {/* Énergie de guérison (Aura) */}
    <div
      class="absolute bottom-8 w-40 h-40 bg-[radial-gradient(circle,rgba(139,0,0,0.4)_0%,transparent_60%)] rounded-full animate-earth-pulse z-10"
    >
    </div>

    {/* La Terre (Socle) */}
    <div
      class="absolute bottom-0 w-[180px] h-10 bg-[#1a1512] rounded-[50%_50%_10%_10%] shadow-[inset_0_10px_10px_rgba(0,0,0,0.8)] z-20"
    >
    </div>

    {/* La Jarre Sacrée (Gozen) */}
    <div
      class="absolute bottom-6 flex flex-col items-center z-30 group cursor-default"
    >
      <div
        class="w-[60px] h-[20px] bg-gradient-to-r from-[#4e342e] via-[#795548] to-[#4e342e] rounded-t-[10px] border-b-[3px] border-[#1a1512]"
      >
      </div>

      <div
        class="w-[110px] h-[100px] bg-gradient-to-br from-[#795548] to-[#3e2723] rounded-[40%_40%_50%_50%] relative shadow-[inset_-10px_-10px_20px_rgba(0,0,0,0.6),0_10px_15px_rgba(0,0,0,0.4)] group-hover:brightness-110 transition-all duration-500"
      >
        {/* Les trous symboliques du Gozen */}
        <div
          class="absolute w-3 h-3 bg-[#1a1512] rounded-full shadow-[inset_2px_2px_5px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.1)] top-[30%] left-[20%]"
        >
        </div>
        <div
          class="absolute w-3 h-3 bg-[#1a1512] rounded-full shadow-[inset_2px_2px_5px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.1)] top-[25%] right-[25%]"
        >
        </div>
        <div
          class="absolute w-3 h-3 bg-[#1a1512] rounded-full shadow-[inset_2px_2px_5px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.1)] top-[50%] left-[45%]"
        >
        </div>
        <div
          class="absolute w-3 h-3 bg-[#1a1512] rounded-full shadow-[inset_2px_2px_5px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.1)] bottom-[25%] left-[30%]"
        >
        </div>
        <div
          class="absolute w-3 h-3 bg-[#1a1512] rounded-full shadow-[inset_2px_2px_5px_rgba(0,0,0,0.8),0_1px_1px_rgba(255,255,255,0.1)] bottom-[30%] right-[20%]"
        >
        </div>
      </div>
    </div>

    {
      /* Perles rituelles (Rouge / Noir / Blanc) - Utilisation de transform inline pour la 3D */
    }
    <div
      class="absolute bottom-4 w-[130px] h-[20px] rounded-full border-[6px] border-dashed border-[#8b0000] shadow-[0_0_0_4px_#1a1512,inset_0_0_0_4px_#fdfbf7] z-40 opacity-90 [transform:rotateX(70deg)]"
    >
    </div>
  </div>
</div>

<style>
  /* Animations complexes conservées en CSS pour de meilleures performances */
  @keyframes earth-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }
  .animate-earth-pulse {
    animation: earth-pulse 4s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
</style>
