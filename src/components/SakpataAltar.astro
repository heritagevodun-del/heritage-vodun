---
/*
  SakpataAltar.astro - CSS Art
  Représente le Gozen (jarre sacrée) et l&apos;énergie tellurique d&apos;Ayinon.
*/
---

<div class="sakpata-art-canvas animate-enter">
  <div class="telluric-stage">
    {/* Énergie de guérison (Aura) */}
    <div class="healing-aura"></div>

    {/* La Terre (Socle) */}
    <div class="earth-mound"></div>

    {/* La Jarre Sacrée (Gozen) */}
    <div class="gozen-jar">
      <div class="jar-neck"></div>
      <div class="jar-body">
        {/* Les trous symboliques du Gozen */}
        <div class="hole h1"></div>
        <div class="hole h2"></div>
        <div class="hole h3"></div>
        <div class="hole h4"></div>
        <div class="hole h5"></div>
      </div>
    </div>

    {/* Perles rituelles (Rouge / Noir / Blanc) */}
    <div class="beads-ring"></div>
  </div>
</div>

<style>
  :root {
    --sakpata-earth: #5d4037;
    --sakpata-dark: #1a1512;
    --sakpata-red: #8b0000;
    --sakpata-white: #fdfbf7;
    --sakpata-glow: rgba(139, 0, 0, 0.4);
  }

  .sakpata-art-canvas {
    width: 100%;
    height: 320px;
    background: radial-gradient(circle at center, #3e2723 0%, #1a110e 100%);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    margin-bottom: 3rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }

  .telluric-stage {
    position: relative;
    width: 200px;
    height: 220px;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  /* --- AURA DE GUÉRISON --- */
  .healing-aura {
    position: absolute;
    bottom: 30px;
    width: 160px;
    height: 160px;
    background: radial-gradient(
      circle,
      var(--sakpata-glow) 0%,
      transparent 60%
    );
    border-radius: 50%;
    animation: earth-pulse 4s ease-in-out infinite;
    z-index: 1;
  }

  /* --- LE MONTICULE DE TERRE --- */
  .earth-mound {
    position: absolute;
    bottom: 0;
    width: 180px;
    height: 40px;
    background: var(--sakpata-dark);
    border-radius: 50% 50% 10% 10%;
    box-shadow: inset 0 10px 10px rgba(0, 0, 0, 0.8);
    z-index: 2;
  }

  /* --- LA JARRE GOZEN --- */
  .gozen-jar {
    position: absolute;
    bottom: 25px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 3;
  }

  .jar-neck {
    width: 60px;
    height: 20px;
    background: linear-gradient(90deg, #4e342e, #795548, #4e342e);
    border-radius: 10px 10px 0 0;
    border-bottom: 3px solid var(--sakpata-dark);
  }

  .jar-body {
    width: 110px;
    height: 100px;
    background: linear-gradient(135deg, #795548, #3e2723);
    border-radius: 40% 40% 50% 50%;
    position: relative;
    box-shadow:
      inset -10px -10px 20px rgba(0, 0, 0, 0.6),
      0 10px 15px rgba(0, 0, 0, 0.4);
  }

  /* Trous du Gozen */
  .hole {
    position: absolute;
    width: 12px;
    height: 12px;
    background-color: var(--sakpata-dark);
    border-radius: 50%;
    box-shadow:
      inset 2px 2px 5px rgba(0, 0, 0, 0.8),
      0 1px 1px rgba(255, 255, 255, 0.1);
  }
  .h1 {
    top: 30%;
    left: 20%;
  }
  .h2 {
    top: 25%;
    right: 25%;
  }
  .h3 {
    top: 50%;
    left: 45%;
  }
  .h4 {
    bottom: 25%;
    left: 30%;
  }
  .h5 {
    bottom: 30%;
    right: 20%;
  }

  /* --- PERLES RITUELLES --- */
  .beads-ring {
    position: absolute;
    bottom: 15px;
    width: 130px;
    height: 20px;
    border-radius: 50%;
    border: 6px dashed var(--sakpata-red);
    box-shadow:
      0 0 0 4px var(--sakpata-dark),
      inset 0 0 0 4px var(--sakpata-white);
    z-index: 4;
    opacity: 0.9;
    transform: rotateX(70deg);
  }

  /* --- ANIMATIONS --- */
  @keyframes earth-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-enter {
    animation: fadeInUp 1s ease forwards;
  }
</style>
