---
// src/components/Search.astro
---

{/* 1. Le Bouton de déclenchement (Compact & Élégant) */}
<button
  id="search-trigger"
  class="flex items-center justify-center w-10 h-10 md:w-11 md:h-11 rounded-full bg-dark-surface border border-gold/30 hover:bg-gold/20 hover:border-gold/60 text-gold hover:text-white transition-all duration-300 shadow-[0_0_15px_rgba(212,175,55,0.15)] hover:shadow-[0_0_20px_rgba(212,175,55,0.3)] group"
  aria-label="Rechercher sur le site"
  title="Rechercher (Ctrl+K)"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-5 w-5 transform group-hover:scale-110 transition-transform"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
</button>

{/* 2. La Modale (Command Palette) */}
<div
  id="search-modal"
  class="fixed inset-0 z-[100] bg-dark-bg/90 backdrop-blur-md hidden flex-col items-center pt-16 md:pt-24 px-4 transition-opacity duration-300 opacity-0"
>
  {/* Conteneur principal */}
  <div
    id="search-container"
    class="w-full max-w-3xl bg-dark-surface border border-gold/30 rounded-2xl shadow-[0_30px_70px_rgba(0,0,0,0.9),0_0_40px_rgba(212,175,55,0.15)] relative overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[85vh]"
  >
    {/* En-tête de la modale */}
    <div
      class="p-4 md:p-5 border-b border-white/10 flex justify-between items-center bg-gradient-to-r from-dark-surface to-dark-bg"
    >
      <span
        class="text-gold font-serif tracking-[0.2em] text-xs md:text-sm uppercase flex items-center gap-3"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
          ></path></svg
        >
        Oracle de Recherche
      </span>
      <button
        id="close-search"
        class="text-vodun-cendre hover:text-vodun-kaolin bg-white/5 hover:bg-white/10 rounded-full p-2 transition-colors"
        title="Fermer (Échap)"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
    </div>

    {/* Zone d'injection Pagefind */}
    <div class="p-4 md:p-8 overflow-y-auto flex-1 custom-scrollbar bg-dark-bg">
      <div id="pagefind-search"></div>
    </div>
  </div>
</div>

{/* 3. Styles globaux pour Surcharger STRICTEMENT Pagefind */}
<style is:global>
  /* Variables de base Pagefind */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-gold); /* Or */
    --pagefind-ui-text: var(--color-vodun-kaolin); /* Blanc doux */
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgba(255, 255, 255, 0.1);
    --pagefind-ui-tag: rgba(212, 175, 55, 0.1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 16 / 9;
    --pagefind-ui-font: var(--font-sans);
  }

  /* --- CIBLAGE CSS STRICT POUR ÉCRASER LES STYLES PAR DÉFAUT --- */

  /* 1. L'Input de Recherche (La barre où l'on tape) */
  .pagefind-ui__search-input {
    font-size: 1.1rem !important;
    font-weight: 400 !important;
    color: var(--color-vodun-kaolin) !important;
    background-color: rgba(255, 255, 255, 0.03) !important;
    padding: 1.2rem 1.5rem 1.2rem 3rem !important;
  }

  .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: var(--pagefind-ui-primary) !important;
    background-color: rgba(255, 255, 255, 0.05) !important;
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2) !important;
  }

  .pagefind-ui__search-input::placeholder {
    color: var(--color-vodun-cendre) !important;
  }

  /* 2. Le Bouton "Effacer" (Croix dans l'input) */
  .pagefind-ui__search-clear {
    background-color: transparent !important;
    color: var(--color-vodun-cendre) !important;
  }
  .pagefind-ui__search-clear:hover {
    color: var(--color-vodun-kaolin) !important;
  }

  /* 3. Bloc de Résultat Individuel */
  .pagefind-ui__result {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
    padding: 1.5rem 0 !important;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .pagefind-ui__result:hover {
    transform: translateX(4px);
  }

  /* Titre du Résultat */
  .pagefind-ui__result-title,
  .pagefind-ui__result-title .pagefind-ui__result-link {
    font-family: var(--font-serif) !important;
    font-weight: 700 !important;
    color: var(--color-gold) !important;
    font-size: 1.3rem !important;
    letter-spacing: 0.02em;
    text-decoration: none !important;
    transition: color 0.2s ease;
  }

  .pagefind-ui__result-title .pagefind-ui__result-link:hover {
    color: var(--color-gold-hover) !important;
  }

  /* Extrait de Texte (Excerpt) */
  .pagefind-ui__result-excerpt {
    color: var(--color-vodun-cendre) !important;
    font-weight: 300 !important;
    line-height: 1.6 !important;
    margin-top: 0.75rem !important;
  }

  /* Surlignage du mot recherché (Mark) */
  .pagefind-ui__result-excerpt mark {
    background-color: rgba(212, 175, 55, 0.15) !important;
    color: var(--color-vodun-kaolin) !important;
    font-weight: 700 !important;
    padding: 0 4px !important;
    border-radius: 4px !important;
    border-bottom: 1px solid var(--color-gold) !important;
  }

  /* Méta-données (Date, Auteur) si Pagefind les remonte */
  .pagefind-ui__message {
    color: var(--color-vodun-cendre) !important;
    font-size: 0.9rem !important;
    padding-bottom: 1rem !important;
    font-style: italic;
  }

  /* Bouton "Voir plus" */
  .pagefind-ui__button {
    background-color: rgba(212, 175, 55, 0.1) !important;
    color: var(--color-gold) !important;
    border: 1px solid rgba(212, 175, 55, 0.3) !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    border-radius: 8px !important;
    transition: all 0.3s ease !important;
  }
  .pagefind-ui__button:hover {
    background-color: var(--color-gold) !important;
    color: var(--color-vodun-bg) !important;
  }
</style>

{/* 4. Logique JS Corrigée pour Astro (ViewTransitions) */}
<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const oldTrigger = document.getElementById("search-trigger");
    if (!oldTrigger) return;

    const trigger = oldTrigger.cloneNode(true);
    oldTrigger.parentNode.replaceChild(trigger, oldTrigger);

    const modal = document.getElementById("search-modal");
    const container = document.getElementById("search-container");
    const closeBtn = document.getElementById("close-search");

    if (!modal || !container || !closeBtn) return;

    const openModal = () => {
      modal.classList.remove("hidden");
      setTimeout(() => {
        modal.classList.remove("opacity-0");
        container.classList.remove("scale-95");
      }, 10);

      if (!window.pagefindLoaded) {
        try {
          const cssLink = document.createElement("link");
          cssLink.rel = "stylesheet";
          cssLink.href = "/pagefind/pagefind-ui.css";
          document.head.appendChild(cssLink);

          const script = document.createElement("script");
          script.src = "/pagefind/pagefind-ui.js";
          script.onload = () => {
            new PagefindUI({
              element: "#pagefind-search",
              showImages: true,
              showSubResults: true,
              translations: {
                placeholder: "Rechercher une divinité, un mythe...",
                clear_search: "Effacer",
                load_more: "Voir plus de résultats",
                search_label: "Recherche",
                filters_label: "Filtres",
                zero_results:
                  "L'Oracle n'a trouvé aucun résultat pour [SEARCH_TERM]",
                many_results: "[COUNT] révélations trouvées pour [SEARCH_TERM]",
                one_result: "Une révélation trouvée pour [SEARCH_TERM]",
                alt_search:
                  "Aucun résultat trouvé pour [SEARCH_TERM]. Affichage pour [DIFFERENT_TERM]",
                search_suggestion: "Aucun résultat trouvé. Essayez :",
                searching: "Consultation des esprits...",
              },
            });
            setTimeout(() => {
              document.querySelector(".pagefind-ui__search-input")?.focus();
            }, 100);
          };
          document.body.appendChild(script);
          window.pagefindLoaded = true;
        } catch (e) {
          console.error("Erreur Pagefind", e);
        }
      } else {
        setTimeout(() => {
          document.querySelector(".pagefind-ui__search-input")?.focus();
        }, 100);
      }
    };

    const closeModal = () => {
      modal.classList.add("opacity-0");
      container.classList.add("scale-95");
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
    };

    trigger.addEventListener("click", openModal);
    closeBtn.addEventListener("click", closeModal);

    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openModal();
      }
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });
  });
</script>
