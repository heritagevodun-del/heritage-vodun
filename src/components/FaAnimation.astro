---
/* On récupère le mode : "hero" (grand) ou "vignette" (petit) */
const { mode = "hero" } = Astro.props;
---

<div
  class={`relative overflow-hidden flex flex-col items-center justify-center border border-gold/10 bg-dark-bg ${mode === "hero" ? "py-20 px-6 rounded-2xl my-10 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.8),inset_0_0_40px_rgba(217,119,6,0.05)] w-full" : "w-full h-full min-h-[220px] p-0"}`}
>
  {/* Effet de lueur divine en arrière-plan */}
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-[radial-gradient(circle,rgba(217,119,6,0.15)_0%,transparent_70%)] blur-[40px] z-0"
  >
  </div>

  {/* Grille binaire/informatique */}
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:20px_20px] z-10"
  >
  </div>

  {/* LA MATRICE (Points et Animation) */}
  <div
    class={`inline-flex items-center z-20 ${mode === "hero" ? "gap-8" : "gap-5 scale-75"}`}
  >
    <div class="flex flex-col gap-4">
      <div
        class={`fa-dot open animate-[fa-pulse_4s_infinite_ease-in-out_0s] ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot closed ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot closed ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot open animate-[fa-pulse_4s_infinite_ease-in-out_1.5s] ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
    </div>

    {/* La ligne d'énergie au centre de l'Opele */}
    <div
      class={`w-px bg-gradient-to-b from-transparent via-gold/50 to-transparent ${mode === "hero" ? "h-32" : "h-20"}`}
    >
    </div>

    <div class="flex flex-col gap-4">
      <div
        class={`fa-dot open animate-[fa-pulse_4s_infinite_ease-in-out_2s] ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot closed ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot open animate-[fa-pulse_4s_infinite_ease-in-out_3s] ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
      <div
        class={`fa-dot closed ${mode === "hero" ? "w-9 h-3 rounded-md my-1.5" : "w-6 h-6 rounded-full"}`}
      >
      </div>
    </div>
  </div>

  {
    mode === "hero" && (
      <div class="relative z-20 mt-10 text-center">
        <p class="text-white/80 font-serif italic text-lg mb-2">
          La danse binaire de l&apos;invisible
        </p>
        <p class="text-amber-500/50 font-mono text-[0.65rem] tracking-[0.3em] uppercase m-0">
          DÙ: LOSSO-SA // SYSTEM.READY
        </p>
      </div>
    )
  }
</div>

<style>
  /* Définition des couleurs spécifiques au FA qui ne sont pas dans Tailwind de base */
  .fa-dot.open {
    background-color: #f59e0b;
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.4);
  }
  .fa-dot.closed {
    background-color: #171717;
    border: 2px solid #78350f;
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8);
  }

  @keyframes fa-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
      box-shadow: 0 0 30px rgba(245, 158, 11, 0.8);
    }
  }
</style>
