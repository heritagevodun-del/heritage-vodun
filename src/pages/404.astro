---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout titrePage="Page introuvable | Héritage Vodun">
  <div
    class="min-h-[70vh] flex flex-col items-center justify-center text-center px-6 relative overflow-hidden bg-dark-bg"
  >
    {/* Lueur mystique en arrière-plan */}
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 opacity-0 animate-fade-up">
      <h1
        class="font-serif text-[8rem] md:text-[12rem] leading-none text-transparent bg-clip-text bg-gradient-to-b from-gold to-gold-hover drop-shadow-[0_0_30px_rgba(212,175,55,0.2)] mb-2"
      >
        404
      </h1>

      <h2
        class="font-sans text-xl md:text-2xl font-bold text-white uppercase tracking-[0.3em] mb-6"
      >
        Chemin Perdu
      </h2>

      <p
        class="font-sans text-lg text-gray-400 max-w-md mx-auto mb-12 leading-relaxed"
      >
        Oups ! Vous vous êtes égaré loin des sentiers sacrés. L&apos;information
        que vous cherchez n&apos;existe plus ou a été déplacée par les esprits.
      </p>

      <a
        href="/"
        class="inline-block border border-gold bg-gold/5 hover:bg-gold text-gold hover:text-black font-bold uppercase tracking-widest px-8 py-4 rounded-full transition-all duration-300 hover:shadow-[0_0_20px_rgba(212,175,55,0.4)] hover:-translate-y-1"
      >
        Retourner à l&apos;accueil
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.8s ease-out forwards;
  }
</style>
