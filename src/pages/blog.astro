---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaAnimation from "../components/FaAnimation.astro";

// --- DEFINITION DES TYPES ---
interface Frontmatter {
  title: string;
  pubDate: string;
  date?: string;
  description: string;
  categorie: string;
  tags?: string[];
  type_image?: string;
  image?: string;
}

interface MarkdownPost {
  frontmatter: Frontmatter;
  url: string;
}

// --- 1. RÉCUPÉRATION DES DONNÉES ---
const matches = import.meta.glob<MarkdownPost>("./posts/*.{md,mdx}", {
  eager: true,
});
const allPosts = Object.values(matches);

// Tri du plus récent au plus ancien
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(
    a.frontmatter.pubDate || a.frontmatter.date || "",
  ).valueOf();
  const dateB = new Date(
    b.frontmatter.pubDate || b.frontmatter.date || "",
  ).valueOf();
  return (isNaN(dateB) ? 0 : dateB) - (isNaN(dateA) ? 0 : dateA);
});

// --- 2. EXTRACTION POUR LES FILTRES ---
const uniqueCategories = [
  ...new Set(
    sortedPosts.map((post) => post.frontmatter.categorie).filter(Boolean),
  ),
];

const allTags = sortedPosts.map((post) => post.frontmatter.tags || []).flat();
const tagCounts = allTags.reduce((acc: any, tag: string) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});
const topTags = Object.keys(tagCounts)
  .sort((a, b) => tagCounts[b] - tagCounts[a])
  .slice(0, 10);

function formatDate(dateInput: string | Date | undefined) {
  if (!dateInput) return "Date inconnue";
  const date = new Date(dateInput);
  if (isNaN(date.getTime())) return "Date inconnue";
  const options: Intl.DateTimeFormatOptions = {
    year: "numeric",
    month: "long",
    day: "numeric",
  };
  return date.toLocaleDateString("fr-FR", options);
}

// --- 3. SEO ---
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Chroniques du Sacré - Héritage Vodun",
  description: "Explorez les mythes, les rites et l'histoire du Bénin.",
  blogPost: sortedPosts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.frontmatter.title,
    description: post.frontmatter.description,
    datePublished: post.frontmatter.pubDate || post.frontmatter.date,
    author: { "@type": "Organization", name: "Héritage Vodun" },
    url: `https://heritagevodun.com${post.url}`,
  })),
};
---

<BaseLayout titrePage="Le Blog | Chroniques du Sacré">
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <div class="min-h-screen bg-dark-bg pb-24">
    {/* --- EN-TÊTE --- */}
    <header
      class="text-center pt-20 pb-12 px-6 max-w-3xl mx-auto opacity-0 animate-fade-up"
    >
      <span
        class="block text-gold text-xs uppercase tracking-[0.25em] font-bold mb-4"
        >Héritage & Transmission</span
      >
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 leading-tight">
        Chroniques du Sacré
      </h1>
      <div class="w-16 h-1 bg-gold mx-auto mb-8"></div>
      <p class="text-lg text-gray-400 leading-relaxed font-sans">
        Plongez au cœur des mythes, décryptez les rites et redécouvrez
        l&apos;histoire du Bénin à travers nos récits.
      </p>
    </header>

    {/* --- FILTRES --- */}
    <section
      class="max-w-5xl mx-auto px-6 mb-20 text-center opacity-0 animate-fade-up"
      style="animation-delay: 150ms;"
    >
      <div class="mb-10">
        <h3
          class="font-sans text-sm text-gray-500 uppercase tracking-widest mb-6"
        >
          Parcourir par Thème :
        </h3>
        <div class="flex flex-wrap justify-center gap-4">
          {
            uniqueCategories.map((cat) => (
              <a
                href={`/categories/${cat}`}
                class="px-6 py-2.5 rounded-full border border-gold/40 text-gold text-sm font-bold uppercase tracking-wider hover:bg-gold hover:text-black transition-all duration-300 hover:-translate-y-1 shadow-[0_4px_10px_rgba(212,175,55,0.05)] hover:shadow-[0_6px_15px_rgba(212,175,55,0.2)]"
              >
                {cat}
              </a>
            ))
          }
        </div>
      </div>

      {
        topTags.length > 0 && (
          <div>
            <h3 class="font-sans text-sm text-gray-500 uppercase tracking-widest mb-4">
              Mots-clés du moment :
            </h3>
            <div class="flex flex-wrap justify-center gap-5">
              {topTags.map((tag) => (
                <a
                  href={`/tags/${tag}`}
                  class="text-sm text-gray-400 hover:text-gold transition-colors border-b border-transparent hover:border-gold pb-0.5"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )
      }
    </section>

    {/* --- GRILLE D'ARTICLES --- */}
    <section
      class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10"
    >
      {
        sortedPosts.map((post, index) => (
          <article
            class="group bg-dark-surface border border-white/5 hover:border-gold/30 rounded-xl overflow-hidden flex flex-col shadow-xl hover:shadow-[0_15px_40px_rgba(212,175,55,0.12)] transition-all duration-500 hover:-translate-y-2 opacity-0 animate-fade-up"
            style={`animation-delay: ${Math.min((index + 2) * 100, 1000)}ms`}
          >
            <a
              href={post.url}
              class="block relative w-full h-60 overflow-hidden bg-black"
              aria-label={`Lire l'article : ${post.frontmatter.title}`}
            >
              {post.frontmatter.type_image === "animation_fa" ? (
                <FaAnimation mode="vignette" />
              ) : post.frontmatter.image ? (
                <div
                  class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                  style={`background-image: url(${post.frontmatter.image});`}
                  role="img"
                  aria-label={post.frontmatter.title}
                />
              ) : (
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,#1a1a1a_0%,#050505_100%)] flex items-center justify-center">
                  <div class="w-12 h-12 border-2 border-gold/30 rotate-45" />
                </div>
              )}
              {/* Dégradé pour fluidifier la transition avec le fond de la carte */}
              <div class="absolute inset-0 bg-gradient-to-t from-dark-surface via-transparent to-transparent opacity-90" />
            </a>

            <div class="p-8 flex flex-col flex-grow relative z-10">
              <div class="flex justify-between items-center mb-5">
                <a
                  href={`/categories/${post.frontmatter.categorie}`}
                  class="bg-gold/10 text-gold border border-gold/20 px-3 py-1 text-xs font-bold uppercase tracking-wider rounded hover:bg-gold hover:text-black transition-colors"
                >
                  {post.frontmatter.categorie}
                </a>
                <span class="text-gray-500 text-xs font-sans italic">
                  {formatDate(
                    post.frontmatter.pubDate || post.frontmatter.date,
                  )}
                </span>
              </div>

              <a href={post.url} class="flex flex-col flex-grow">
                <h3 class="font-serif text-2xl text-white mb-4 leading-snug group-hover:text-gold transition-colors">
                  {post.frontmatter.title}
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed mb-8 line-clamp-3 flex-grow">
                  {post.frontmatter.description}
                </p>

                <span class="mt-auto flex items-center gap-2 text-gold font-bold uppercase tracking-wider text-sm transition-all duration-300 group-hover:gap-4">
                  Lire l&apos;article <span class="text-lg">&rarr;</span>
                </span>
              </a>
            </div>
          </article>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.8s ease-out forwards;
  }
</style>
