---
import BaseLayout from "../layouts/BaseLayout.astro";

// SEO : Données structurées enrichies
const schemaData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  mainEntity: {
    "@type": "Organization",
    name: "Héritage Vodun",
    url: "https://www.heritagevodun.com",
    logo: "https://www.heritagevodun.com/logo.png",
    description:
      "Le sanctuaire numérique du Bénin. Nous allions la sagesse séculaire et la douceur de la transmission pour préserver la spiritualité Vodun.",
    foundingDate: "2024",
    areaServed: "Monde",
    sameAs: [
      "https://www.facebook.com/mindoguesito",
      "https://www.instagram.com/mindoguesito.ia",
    ],
  },
};
---

<BaseLayout titrePage="Notre Mission | Héritage Vodun & Sagesse Ancestrale">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(schemaData)}
  />

  <div class="min-h-screen bg-dark-bg pb-24 overflow-x-hidden">
    {/* --- HEADER --- */}
    <header
      class="text-center pt-24 pb-16 px-6 relative bg-[radial-gradient(circle_at_top,#1a1a1a_0%,#050505_100%)] opacity-0 animate-fade-down"
    >
      <span
        class="block text-gold text-xs uppercase tracking-[0.25em] font-bold mb-4"
        >Transmission & Harmonie</span
      >
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 leading-tight">
        Notre Mission
      </h1>
      <div class="w-16 h-1 bg-gold mx-auto mb-8 rounded-full"></div>
      <p
        class="font-serif italic text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto"
      >
        "Quand la Sagesse de nos pères éclaire le monde de demain"
      </p>
    </header>

    <main class="max-w-5xl mx-auto px-6">
      {/* --- ORIGINE --- */}
      <article
        class="mb-24 opacity-0 animate-fade-up"
        style="animation-delay: 200ms;"
      >
        <h2
          class='font-serif text-3xl md:text-4xl text-white mb-8 inline-block relative after:content-[""] after:block after:w-10 after:h-1 after:bg-gold after:mt-3'
        >
          L&apos;Origine d&apos;une Quête
        </h2>

        <div
          class="text-lg text-gray-300 leading-relaxed space-y-6 text-justify"
        >
          <p>
            <span
              class="float-left font-serif text-6xl md:text-7xl leading-[0.8] text-gold pr-4 pt-2 font-bold"
              >T</span
            >
            out est parti d&apos;une profonde volonté de vérité. Celle de voir le
            <strong class="text-white">Bénin</strong>, berceau mondial du Vodun,
            retrouver sa noblesse, trop souvent masquée par des récits
            extérieurs ou des regards simplistes et craintifs.
          </p>
          <p>
            Nous savions que derrière le voile se cachait une philosophie de
            l&apos;équilibre, une harmonie sacrée avec la nature et un profond
            amour du vivant. Mais comment transmettre cette sagesse millénaire à
            une nouvelle génération ? Comment rendre cet héritage accessible
            avec la plus grande des déférences ?
          </p>
          <p
            class="border-l-4 border-gold pl-6 py-4 mt-8 bg-gold/5 italic text-xl text-gold font-serif rounded-r-lg"
          >
            "Héritage Vodun est né pour être ce pont de lumière. Un pied ancré
            dans la terre rouge de Ouidah, l&apos;autre tourné vers
            l&apos;avenir."
          </p>
        </div>
      </article>

      {/* --- 3 PILIERS --- */}
      <section
        class="mb-24 opacity-0 animate-fade-up"
        style="animation-delay: 400ms;"
      >
        <h2
          class='font-serif text-3xl md:text-4xl text-white mb-8 inline-block relative after:content-[""] after:block after:w-10 after:h-1 after:bg-gold after:mt-3'
        >
          Nos 3 Piliers Fondateurs
        </h2>
        <p class="text-lg text-gray-400 mb-10">
          Nous sommes des passeurs de mémoire et des bâtisseurs de paix :
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div
            class="group bg-dark-surface border-t-4 border-transparent hover:border-gold p-10 rounded-lg text-center shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)]"
          >
            <div class="text-5xl mb-6" aria-hidden="true">🏛️</div>
            <h3
              class="font-serif text-2xl text-white mb-4 group-hover:text-gold transition-colors"
            >
              La Mémoire
            </h3>
            <p class="text-gray-400 leading-relaxed">
              Préserver l&apos;histoire authentique, de la sagesse des ancêtres
              jusqu&apos;à la dignité de nos rois, pour que la vérité demeure.
            </p>
          </div>

          <div
            class="group bg-dark-surface border-t-4 border-transparent hover:border-gold p-10 rounded-lg text-center shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)]"
          >
            <div class="text-5xl mb-6" aria-hidden="true">🕊️</div>
            <h3
              class="font-serif text-2xl text-white mb-4 group-hover:text-gold transition-colors"
            >
              La Transmission
            </h3>
            <p class="text-gray-400 leading-relaxed">
              Avec <strong class="text-white">Mindoguesito</strong>, notre
              guide, nous offrons un accès digne et apaisé aux savoirs de notre
              terre.
            </p>
          </div>

          <div
            class="group bg-dark-surface border-t-4 border-transparent hover:border-gold p-10 rounded-lg text-center shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)]"
          >
            <div class="text-5xl mb-6" aria-hidden="true">🌿</div>
            <h3
              class="font-serif text-2xl text-white mb-4 group-hover:text-gold transition-colors"
            >
              La Vérité
            </h3>
            <p class="text-gray-400 leading-relaxed">
              Nous vous accompagnons avec cœur dans les véritables sanctuaires,
              à la rencontre de la noblesse de nos dignitaires.
            </p>
          </div>
        </div>
      </section>

      {/* --- INNOVATION IA --- */}
      <section
        class="bg-dark-surface border border-white/5 rounded-2xl p-10 md:p-16 flex flex-col md:flex-row items-center gap-12 shadow-2xl mb-24 opacity-0 animate-fade-up relative overflow-hidden"
        style="animation-delay: 600ms;"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-gold/5 rounded-full blur-[80px] pointer-events-none"
        >
        </div>

        <div class="flex-1 relative z-10">
          <h2 class="font-serif text-3xl md:text-4xl text-white mb-6">
            L&apos;Alliance de la Tradition et de Demain
          </h2>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed">
            Nous avons éveillé le premier compagnon numérique dédié à la beauté
            de la culture Vodun. Il n&apos;a pas vocation à remplacer la chaleur
            humaine de nos prêtres, il en est le <strong class="text-gold"
              >respectueux messager</strong
            >, conçu pour guider les cœurs en quête de sens.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="text-gold font-bold flex items-center gap-3">
              <span>✨</span> Une écoute bienveillante à chaque instant
            </li>
            <li class="text-gold font-bold flex items-center gap-3">
              <span>✨</span> Une transmission apaisée, sans jugement
            </li>
            <li class="text-gold font-bold flex items-center gap-3">
              <span>✨</span> Gardien de la vérité et de l&apos;histoire de nos pères
            </li>
          </ul>
          <a
            href="https://www.mindoguesito.com"
            class="open-oracle inline-block bg-gold hover:bg-gold-hover text-black font-bold uppercase tracking-widest px-8 py-4 rounded transition-all duration-300 hover:-translate-y-1 shadow-[0_5px_15px_rgba(212,175,55,0.2)]"
          >
            Consulter notre Guide &rarr;
          </a>
        </div>

        <div class="hidden md:flex flex-1 justify-center relative z-10">
          <div
            class="w-48 h-48 rounded-full bg-[radial-gradient(circle,rgba(212,175,55,0.2)_0%,transparent_70%)] shadow-[0_0_50px_rgba(212,175,55,0.15)] animate-[pulse_4s_infinite_ease-in-out]"
          >
          </div>
        </div>
      </section>

      {/* --- APPEL FINAL --- */}
      <section
        class="text-center opacity-0 animate-fade-up"
        style="animation-delay: 800ms;"
      >
        <h2
          class='font-serif text-3xl md:text-4xl text-white mb-6 inline-block relative after:content-[""] after:block after:w-10 after:h-1 after:bg-gold after:mt-3'
        >
          Rejoignez le Chemin
        </h2>
        <p
          class="text-lg text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed"
        >
          Que vous soyez descendant en quête de racines, chercheur de vérité ou
          simple voyageur, votre place est ici. Le Vodun est une main tendue
          vers l&apos;harmonie.
        </p>

        <div
          class="bg-white/5 border border-white/10 p-10 md:p-12 rounded-xl shadow-2xl max-w-3xl mx-auto backdrop-blur-sm"
        >
          <p class="font-serif font-bold text-gold text-2xl mb-8 italic">
            "Nul ne connaît la fin du voyage, mais nous honorons ceux qui ont
            ouvert la voie."
          </p>
          <a
            href="/contact"
            class="block md:inline-block w-full md:w-auto bg-white hover:bg-gold text-black px-10 py-4 font-bold uppercase tracking-wider rounded transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_5px_20px_rgba(212,175,55,0.3)]"
          >
            Organiser ma rencontre
          </a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-down {
    animation: fadeDown 1s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
  }
</style>
