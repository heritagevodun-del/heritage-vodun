---
import BaseLayout from "../layouts/BaseLayout.astro";

// SEO : Schema.org pour la page Contact
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@type": "Organization",
    name: "Héritage Vodun",
    url: "https://www.heritagevodun.com",
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "customer service",
      areaServed: "BJ",
      availableLanguage: ["French", "English"],
    },
  },
};
---

<BaseLayout titrePage="Contact & Réservation | L'Arbre à Palabre">
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <div class="min-h-screen bg-dark-bg pb-24 overflow-x-hidden">
    {/* --- HEADER --- */}
    <div
      class="text-center pt-24 pb-16 px-6 max-w-3xl mx-auto opacity-0 animate-fade-down relative z-10"
    >
      <span
        class="block text-gold text-xs uppercase tracking-[0.25em] font-bold mb-4"
        >L&apos;Arbre à Palabre</span
      >
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 leading-tight">
        Parlons ensemble
      </h1>
      <div class="w-16 h-1 bg-gold mx-auto mb-8 rounded-full"></div>
      <p class="text-lg text-gray-400 leading-relaxed font-sans">
        Sous l&apos;arbre à palabre, la parole se libère. Que ce soit pour
        organiser votre voyage ou proposer un partenariat, nous sommes à votre
        écoute.
      </p>
    </div>

    {/* --- LAYOUT PRINCIPAL --- */}
    <div
      class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-16 relative z-10"
    >
      {/* --- SIDEBAR INFO --- */}
      <aside
        class="flex flex-col gap-8 order-2 lg:order-1 opacity-0 animate-fade-right"
        style="animation-delay: 200ms;"
      >
        {/* Carte IA */}
        <div
          class="bg-gradient-to-br from-gold/10 to-transparent border border-gold/30 p-8 rounded-xl text-center shadow-[0_10px_30px_rgba(212,175,55,0.1)] hover:shadow-[0_15px_40px_rgba(212,175,55,0.2)] transition-all duration-300"
        >
          <div class="text-4xl mb-4 animate-[bounce_3s_infinite]">✨</div>
          <h3 class="font-serif text-2xl text-white mb-3">
            Une question sur le Vodun ?
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">
            Vous voulez savoir ce qu&apos;est le Fâ ou l&apos;histoire d&apos;un
            masque ? Pas besoin d&apos;attendre un email !
          </p>
          <a
            href="https://www.mindoguesito.com"
            class="open-oracle inline-block bg-gold hover:bg-gold-hover text-black font-bold uppercase tracking-widest text-xs px-6 py-3 rounded-full transition-all duration-300 hover:-translate-y-1 shadow-[0_5px_15px_rgba(212,175,55,0.2)]"
          >
            Demander à Mindoguesito
          </a>
        </div>

        {/* Carte Localisation */}
        <div
          class="bg-dark-surface border border-white/5 p-8 rounded-xl text-center"
        >
          <div class="text-4xl mb-4 opacity-80">📍</div>
          <h3 class="font-serif text-xl text-white mb-2">Localisation</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Ouidah, Bénin<br />Cité historique
          </p>
        </div>
      </aside>

      {/* --- FORMULAIRE --- */}
      <main
        class="lg:col-span-2 order-1 lg:order-2 opacity-0 animate-fade-up"
        style="animation-delay: 400ms;"
      >
        <div
          class="bg-dark-surface border border-gold/20 rounded-2xl p-8 md:p-12 shadow-2xl relative overflow-hidden"
        >
          {/* Lueur déco */}
          <div
            class="absolute top-0 right-0 w-64 h-64 bg-gold/5 rounded-full blur-[80px] pointer-events-none"
          >
          </div>

          <h2
            class="font-serif text-3xl md:text-4xl text-white mb-2 relative z-10"
          >
            Envoyer un message officiel
          </h2>
          <p class="text-gray-400 text-sm mb-10 relative z-10">
            Pour les demandes de guides, presse ou collaborations.
          </p>

          <form id="form-contact" class="flex flex-col gap-6 relative z-10">
            <input
              type="hidden"
              name="access_key"
              value="90fd8cd4-08c6-427b-9e44-ae19d6c3f487"
            />
            <input
              type="hidden"
              name="subject"
              id="hidden-subject"
              value="Nouveau Message Site Web"
            />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display: none;"
            />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label
                  for="nom"
                  class="text-xs font-bold uppercase tracking-widest text-gold"
                  >Nom complet</label
                >
                <input
                  type="text"
                  id="nom"
                  name="name"
                  required
                  placeholder="Votre Nom"
                  class="bg-black/50 border border-white/10 rounded-md px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-all duration-300"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label
                  for="email-contact"
                  class="text-xs font-bold uppercase tracking-widest text-gold"
                  >Email</label
                >
                <input
                  type="email"
                  id="email-contact"
                  name="email"
                  required
                  placeholder="votre@email.com"
                  class="bg-black/50 border border-white/10 rounded-md px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-all duration-300"
                />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label
                for="sujet-select"
                class="text-xs font-bold uppercase tracking-widest text-gold"
                >Objet de la demande</label
              >
              <div class="relative">
                <select
                  id="sujet-select"
                  name="topic"
                  required
                  class="w-full bg-black/50 border border-white/10 rounded-md px-4 py-3 text-white appearance-none cursor-pointer focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-all duration-300 [&>option]:bg-dark-surface [&>option]:text-white"
                >
                  <option value="" disabled selected
                    >-- Choisissez un sujet --</option
                  >
                  <option value="Voyage">Organiser une visite à Ouidah</option>
                  <option value="Partenariat">Proposition de Partenariat</option
                  >
                  <option value="Presse">Presse & Médias</option>
                  <option value="Autre">Autre demande</option>
                </select>
                <div
                  class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-gold text-xs"
                >
                  ▼
                </div>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label
                for="message"
                class="text-xs font-bold uppercase tracking-widest text-gold"
                >Votre Message</label
              >
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Dites-nous en plus sur votre projet..."
                class="bg-black/50 border border-white/10 rounded-md px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-all duration-300 resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-envoi bg-gold hover:bg-gold-hover text-black font-bold uppercase tracking-widest py-4 rounded-md transition-all duration-300 mt-4 disabled:opacity-50 disabled:cursor-not-allowed hover:-translate-y-1 shadow-[0_5px_15px_rgba(212,175,55,0.2)]"
            >
              Envoyer le message
            </button>

            <div
              id="resultat-contact"
              class="hidden text-center font-bold text-sm mt-2 p-4 rounded-md"
            >
            </div>
          </form>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById("form-contact");
  const result = document.getElementById("resultat-contact");
  const btn = document.querySelector(".btn-envoi");
  const subjectSelect = document.getElementById("sujet-select");
  const hiddenSubject = document.getElementById("hidden-subject");

  if (form && result && btn && subjectSelect && hiddenSubject) {
    subjectSelect.addEventListener("change", (e) => {
      hiddenSubject.value = `[Héritage Vodun] Nouveau message : ${e.target.value}`;
    });

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.innerHTML = "Envoi en cours...";
      result.className =
        "block text-center font-bold text-sm mt-2 p-4 rounded-md text-gold"; // Style Loading
      btn.innerHTML = "Patientez...";
      btn.disabled = true;

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let jsonResponse = await response.json();
          if (response.status == 200) {
            result.innerHTML =
              "✨ Message reçu !<br>Nous vous répondrons sous peu.";
            result.className =
              "block text-center font-bold text-sm mt-2 p-4 rounded-md bg-green-900/30 text-green-400 border border-green-500/30"; // Style Success
            form.reset();
            btn.innerHTML = "Message Envoyé";
          } else {
            console.log(response);
            result.innerHTML =
              jsonResponse.message || "Erreur lors de l'envoi.";
            result.className =
              "block text-center font-bold text-sm mt-2 p-4 rounded-md bg-red-900/30 text-red-400 border border-red-500/30"; // Style Error
            btn.innerHTML = "Réessayer";
            btn.disabled = false;
          }
        })
        .catch((error) => {
          console.log(error);
          result.innerHTML = "Erreur de connexion.";
          result.className =
            "block text-center font-bold text-sm mt-2 p-4 rounded-md bg-red-900/30 text-red-400 border border-red-500/30"; // Style Error
          btn.innerHTML = "Réessayer";
          btn.disabled = false;
        });
    });
  }
</script>

<style>
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-down {
    animation: fadeDown 0.8s ease-out forwards;
  }

  @keyframes fadeRight {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .animate-fade-right {
    animation: fadeRight 0.8s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
  }
</style>
