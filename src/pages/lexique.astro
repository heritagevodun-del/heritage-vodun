---
// src/pages/lexique.astro
import BaseLayout from "../layouts/BaseLayout.astro";

// LISTE ENRICHIE EXPERTE (Encyclopédie Vodun)
const termes = [
  {
    mot: "Agbadja",
    def: "Rythme et danse emblématique du peuple Fon et Ewe. Caractérisé par le mouvement des épaules qui s&apos;ouvrent et se ferment, il symbolise l&apos;envol de l&apos;oiseau et la vitalité.",
  },
  {
    mot: "Akwé",
    def: "Le Cauris. Coquillage blanc servant autrefois de monnaie, mais surtout instrument divinatoire de base. &apos;Jeter les cauris&apos; est la première étape pour interroger les esprits.",
  },
  {
    mot: "Asen",
    def: "Autel portatif en métal (généralement en fer forgé) planté en terre. Il sert de réceptacle pour invoquer, honorer et nourrir les esprits des ancêtres défunts au sein de la famille.",
  },
  {
    mot: "Atakoun",
    def: "La maniguette ou &apos;Graine de Paradis&apos;. Épice sacrée indispensable aux rituels. Mâchée avec du gin et projetée (postillonnée), elle active les prières et réveille les fétiches.",
  },
  {
    mot: "Atchè",
    def: "Le pouvoir spirituel, l&apos;autorité ou la &apos;force de réalisation&apos;. Quand un dignitaire prononce une bénédiction avec Atchè, elle se manifeste obligatoirement dans la réalité.",
  },
  {
    mot: "Ayido Hwedo",
    def: "Le Serpent Arc-en-ciel cosmique. Souvent associé à Dan, il est l&apos;entité qui soutient la Terre pour l&apos;empêcher de tomber dans l&apos;abîme. Il représente l&apos;éternité et la continuité.",
  },
  {
    mot: "Azan",
    def: "Franges de feuilles de palmier déchiquetées installées à l&apos;entrée des lieux sacrés. Elles marquent la frontière entre le monde profane et le monde sacré, et servent de barrière contre les impuretés.",
  },
  {
    mot: "Azé",
    def: "La sorcellerie ou l&apos;énergie destructrice nocturne (souvent associée à l&apos;oiseau). Contrairement au Vodun qui cherche l&apos;équilibre, l&apos;Azé est une force de prédation que les rites cherchent à neutraliser.",
  },
  {
    mot: "Bo",
    def: "Souvent appelé &apos;Gris-gris&apos; par erreur, le Bo est une science occulte utilisant les propriétés des plantes, des minéraux et des incantations pour protéger, guérir ou agir sur le destin.",
  },
  {
    mot: "Bokonon",
    def: "Prêtre du Fâ. Contrairement au Hounnon (chef de couvent), le Bokonon est le devin, l&apos;initié qui maîtrise la science géomantique pour lire le destin et prescrire les sacrifices.",
  },
  {
    mot: "Botchio",
    def: "Littéralement &apos;Cadavre magique&apos; ou &apos;Réceptacle de force&apos;. Statuette en bois sculptée, chargée d&apos;éléments actifs, qui sert de sentinelle pour absorber les attaques malveillantes à la place de son propriétaire.",
  },
  {
    mot: "Dan",
    def: "Divinité de la prospérité et de la richesse. Il est le principe du mouvement sinueux et de l&apos;eau qui coule. Il apporte l&apos;abondance mais exige une propreté absolue.",
  },
  {
    mot: "Dangbé",
    def: "Le Python Royal Sacré. Ancêtre totémique du peuple Xwéda de Ouidah. Il est vénéré comme un dieu bienveillant garantissant la pluie et la fécondité. Il ne doit jamais être tué.",
  },
  {
    mot: "Dja",
    def: "Huile de palme rouge (zomi). C&apos;est le &apos;sang végétal&apos;. Elle est l&apos;offrande apaisante par excellence, versée sur les autels (notamment Legba et Gou) pour calmer les énergies &apos;chaudes&apos;.",
  },
  {
    mot: "Egungun",
    def: "Société de masques incarnant l&apos;esprit des ancêtres revenants. Lorsqu&apos;un Egungun sort, c&apos;est l&apos;ancêtre lui-même qui revient bénir ou juger les vivants.",
  },
  {
    mot: "Fâ",
    def: "Science divinatoire et système de sagesse originaire d&apos;Ifé. Ce n&apos;est pas une religion à part entière, mais la &apos;boussole&apos; du Vodun. Il repose sur 256 signes (Dù) mathématiques.",
  },
  {
    mot: "Gan",
    def: "Le Gong ou la cloche rituelle. Son son métallique et perçant sert à &apos;réveiller&apos; les divinités et à marquer le tempo des chants sacrés. On dit que le Gan parle aux esprits.",
  },
  {
    mot: "Gbadu",
    def: "Principe féminin du Fâ, représentant la matrice universelle et le secret de la vie. Elle complète le Fâ qui est le principe masculin.",
  },
  {
    mot: "Gbè",
    def: "Concept philosophique signifiant à la fois &apos;La Vie&apos;, &apos;Le Monde&apos; et &apos;La Parole&apos;. Dans la pensée Vodun, la parole crée la vie (Gbè).",
  },
  {
    mot: "Gla",
    def: "Terme générique pour désigner le Masque ou l&apos;esprit qui l&apos;habite. Le masque n&apos;est pas un déguisement, c&apos;est une incarnation temporaire d&apos;une force invisible.",
  },
  {
    mot: "Gléxwé",
    def: "Nom endogène et historique de la ville de Ouidah, signifiant &apos;La Maison des Champs&apos;. C&apos;est le cœur historique du commerce et du Vodun sur la côte.",
  },
  {
    mot: "Gou (Gu)",
    def: "Divinité du fer, de la guerre et de la technologie. Il est le patron des forgerons et des chasseurs. Il tranche l&apos;ignorance et ouvre les chemins, mais il est aussi le dieu du sang versé.",
  },
  {
    mot: "Gueledé",
    def: "Société de masques (Patrimoine UNESCO) célébrant le pouvoir des Mères (les femmes âgées et ancêtres féminins) pour assurer la fertilité et la paix sociale.",
  },
  {
    mot: "Heviosso",
    def: "Divinité du tonnerre et de la foudre. Il incarne la justice divine immédiate. Il frappe ceux qui commettent des crimes graves ou ne respectent pas l&apos;ordre naturel.",
  },
  {
    mot: "Houn",
    def: "Le Tambour. Dans le Vodun, le tambour n&apos;est pas un simple instrument de musique, c&apos;est une entité vivante qui possède son propre esprit et qui permet d&apos;appeler les divinités (Houn-yè).",
  },
  {
    mot: "Hounkpame",
    def: "Le Couvent Vodun. C&apos;est le sanctuaire fermé où les initiés se retirent pour &apos;mourir&apos; à leur ancienne vie et renaître avec un nouveau nom et une connexion aux dieux.",
  },
  {
    mot: "Hounnon",
    def: "Littéralement &apos;Mère/Possesseur du Vodun&apos;. C&apos;est le chef spirituel d&apos;un couvent, celui qui détient les secrets des rites et qui initie les adeptes.",
  },
  {
    mot: "Hounnongan",
    def: "Dignitaire de très haut rang dans la hiérarchie Vodun. Il assiste le Hounnon et joue un rôle clé dans ceremonies publiques et secrètes.",
  },
  {
    mot: "Ikin",
    def: "Noix de palme sacrées utilisées pour la consultation majeure du Fâ. Elles sont considérées comme supérieures au chapelet (Opele) car elles ne mentent jamais.",
  },
  {
    mot: "Joto",
    def: "L&apos;ancêtre tutélaire. Selon le Vodun, chaque enfant est la réincarnation partielle d&apos;un ancêtre. Le Joto est révélé par le Fâ à la naissance (rite du To-Fâ).",
  },
  {
    mot: "Kaolin",
    def: "Argile blanche (Calcaire) utilisée pour tracer les signes sacrés (Vê) sur le sol ou sur le corps des initiés. Le blanc symbolise la pureté et le monde des esprits.",
  },
  {
    mot: "Klegba",
    def: "Représentation physique de Legba, souvent sous la forme d&apos;une butte de terre érigée à l&apos;entrée des concessions ou des villages pour la protection.",
  },
  {
    mot: "Kouvito",
    def: "Les &apos;revenants&apos; ou esprits des morts. Terme souvent utilisé pour désigner les membres de la société Egungun.",
  },
  {
    mot: "Kpassè",
    def: "Roi fondateur légendaire de Ouidah. Il ne serait pas mort mais se serait transformé en arbre Iroko. La Forêt Sacrée de Kpassè à Ouidah est un haut lieu de pèlerinage.",
  },
  {
    mot: "Legba",
    def: "Divinité messagère et gardienne des seuils. Il est l&apos;intermédiaire indispensable : sans lui, aucune prière n&apos;arrive aux autres dieux. C&apos;est le diplomate cosmique.",
  },
  {
    mot: "Loko",
    def: "Divinité liée à l&apos;arbre Iroko. Loko est l&apos;arbre-mémoire, le gardien des traditions et le lieu de rassemblement des esprits.",
  },
  {
    mot: "Makpo",
    def: "La Récade. Bâton de commandement royal ou sacerdotal, souvent orné d&apos;un symbole métallique. Il représente l&apos;autorité de la parole et le pouvoir du Roi ou du Prêtre.",
  },
  {
    mot: "Mami Wata",
    def: "Divinité des eaux. Souvent représentée comme une sirène ou une femme d&apos;une grande beauté entourée de serpents. Elle symbolise la puissance de l&apos;océan, la séduction et la richesse.",
  },
  {
    mot: "Mawu-Lisa",
    def: "Le couple créateur suprême. Mawu (féminin, la Lune) et Lisa (masculin, le Soleil). Ils représentent l&apos;équilibre parfait du monde, le froid et le chaud, la nuit et le jour.",
  },
  {
    mot: "Nana Buluku",
    def: "La Grande-Mère primordiale. Divinité suprême et très ancienne, elle aurait engendré Mawu et Lisa. Elle est l&apos;origine mystérieuse de toute chose.",
  },
  {
    mot: "Opele",
    def: "Chapelet divinatoire composé de 8 demi-coques, utilisé par le Bokonon pour les consultations rapides du Fâ.",
  },
  {
    mot: "Oro",
    def: "Société secrète très puissante, dont la sortie est annoncée par un vrombissement terrifiant (le taureau-rugissant). Elle est strictement interdite aux femmes et aux non-initiés.",
  },
  {
    mot: "Sakpata",
    def: "Divinité de la Terre. Il est craint car associé aux maladies éruptives, mais il est surtout respecté comme le propriétaire du sol et de toutes les richesses terrestres.",
  },
  {
    mot: "Sato",
    def: "Tambour géant (souvent plus de 1m50) utilisé lors des funérailles de grands dignitaires. On dit que c&apos;est le &apos;Tambour Orphelin&apos; car il pleure les morts.",
  },
  {
    mot: "Se",
    def: "Le Destin ou l&apos;Âme divine. C&apos;est la parcelle du dieu créateur (Mawu) que chaque être humain porte en lui. Le &apos;Se&apos; détermine notre mission sur terre.",
  },
  {
    mot: "Sodabi",
    def: "Alcool local (vin de palme distillé). Il est indispensable pour les libations : on verse le Sodabi sur le sol pour inviter les ancêtres à boire avec nous.",
  },
  {
    mot: "Tassinon",
    def: "Dignitaire femme, souvent une tante ou une matriarche, chargée de veiller sur les autels des ancêtres (Asen) de la famille.",
  },
  {
    mot: "Tohossou",
    def: "Divinité des eaux royales. Protecteur des enfants nés avec des particularités physiques ou des malformations, considérés comme des envoyés des eaux.",
  },
  {
    mot: "Tron",
    def: "Divinité guerrière et protectrice (Thron Kpeto Deka Alafia). Très populaire aujourd&apos;hui pour son efficacité contre la sorcellerie et pour la protection des foyers.",
  },
  {
    mot: "Vi-kpe",
    def: "L&apos;eau lustrale ou eau sacrée, souvent mélangée à des herbes et de la kaolin, utilisée pour la purification des adeptes et le nettoyage des souillures spirituelles.",
  },
  {
    mot: "Vodun",
    def: "Terme Fon signifiant &apos;Ce qu&apos;on ne peut élucider&apos;, &apos;Esprit&apos; ou &apos;Divinité&apos;. Désigne à la fois les entités invisibles, les objets sacrés, et la culture spirituelle née au Bénin.",
  },
  {
    mot: "Vodunsi",
    def: "Littéralement &apos;Épouse du Vodun&apos;. Désigne tout initié(e) (homme ou femme) qui a traversé les rites du couvent et qui est au service d&apos;une divinité spécifique.",
  },
  {
    mot: "Vossa",
    def: "Le sacrifice ou l&apos;offrande rituelle. Ce n&apos;est pas une perte, mais un échange d&apos;énergie vital pour rétablir l&apos;équilibre ou remercier les divinités.",
  },
  {
    mot: "Xwéda",
    def: "Peuple autochtone de la région de Ouidah (Gléxwé). Ce sont les adorateurs originels du Python Dangbé.",
  },
  {
    mot: "Yê",
    def: "L&apos;ombre ou la silhouette d&apos;une personne, considérée comme une composante spirituelle fragile qui peut être attaquée ou volée par les sorciers.",
  },
  {
    mot: "Yêhwe",
    def: "Terme respectueux pour désigner une divinité ou un esprit saint. Les adeptes du Vodun sont souvent appelés Yêhwe-si.",
  },
  {
    mot: "Zangbeto",
    def: "Le &apos;Gardien de la Nuit&apos;. Société de masques de paille qui tournent comme des toupies. Ils assurent la police traditionnelle, chassent les sorciers et protègent le village.",
  },
  {
    mot: "Zin",
    def: "La jarre en terre cuite ou canari. Elle est l&apos;élément fondamental des autels Vodun, contenant l&apos;eau sacrée, les plantes ou les &apos;secrets&apos; de la divinité.",
  },
];

// Tri automatique alphabétique (Indispensable pour l'UX)
termes.sort((a, b) => a.mot.localeCompare(b.mot));

// Création des lettres pour l'index (A, B, D...)
const lettres = [...new Set(termes.map((t) => t.mot.charAt(0).toUpperCase()))];

// --- SEO : JSON-LD (Données Structurées pour Google) ---
const schemaData = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "Glossaire Vodun & Culture Béninoise",
  description:
    "Définitions authentiques des termes clés du Vodun, des divinités et des traditions de Ouidah.",
  hasDefinedTerm: termes.map((t) => ({
    "@type": "DefinedTerm",
    termCode: t.mot,
    name: t.mot,
    description: t.def,
  })),
};
---

<BaseLayout titrePage="Lexique Sacré | Glossaire du Vodun & Ouidah">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <div class="min-h-screen bg-dark-bg pb-24">
    {/* --- HEADER --- */}
    <header
      class="text-center pt-24 pb-16 px-6 max-w-3xl mx-auto opacity-0 animate-fade-down"
    >
      <span
        class="block text-gold text-xs uppercase tracking-[0.25em] font-bold mb-4"
        >Comprendre les mots sacrés</span
      >
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 leading-tight">
        Le Glossaire Vodun
      </h1>
      <div class="w-16 h-1 bg-gold mx-auto mb-8 rounded-full"></div>
      <p class="text-lg text-gray-400 leading-relaxed font-sans">
        Pour appréhender la philosophie de nos ancêtres, il faut d&apos;abord
        maîtriser les mots. Voici les définitions authentiques et clés de notre
        tradition.
      </p>

      {/* --- INDEX ALPHABÉTIQUE --- */}
      <div class="flex flex-wrap justify-center gap-3 mt-12">
        {
          lettres.map((lettre) => (
            <a
              href={`#lettre-${lettre}`}
              class="flex items-center justify-center w-12 h-12 rounded-full border border-gold/40 text-gold font-bold text-lg hover:bg-gold hover:text-black transition-all duration-300 hover:-translate-y-1 shadow-[0_4px_10px_rgba(212,175,55,0.05)] hover:shadow-[0_6px_15px_rgba(212,175,55,0.2)]"
            >
              {lettre}
            </a>
          ))
        }
      </div>
    </header>

    {/* --- LISTE DES DÉFINITIONS --- */}
    <div
      class="max-w-4xl mx-auto px-6 flex flex-col gap-8 opacity-0 animate-fade-up"
      style="animation-delay: 200ms;"
    >
      {
        termes.map((item) => {
          const premiereLettre = item.mot.charAt(0).toUpperCase();
          return (
            <div
              class="group bg-dark-surface p-8 md:p-10 rounded-xl border-l-4 border-gold/50 shadow-xl hover:border-gold hover:translate-x-2 transition-all duration-300 scroll-mt-32 relative overflow-hidden"
              id={`lettre-${premiereLettre}`}
            >
              {/* Lueur de survol subtile */}
              <div class="absolute inset-0 bg-gradient-to-r from-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />

              <div class="relative z-10">
                <h2 class="font-serif text-3xl text-white mb-4 relative inline-block after:content-[&quot;&quot;] after:absolute after:-bottom-2 after:left-0 after:w-12 after:h-0.5 after:bg-gold/30 group-hover:after:bg-gold transition-colors duration-300">
                  {item.mot}
                </h2>
                <p class="font-sans text-lg text-gray-400 leading-relaxed text-justify mt-4">
                  {item.def}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-down {
    animation: fadeDown 0.8s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
  }
</style>