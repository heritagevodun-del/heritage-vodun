---
import BaseLayout from "../layouts/BaseLayout.astro";

// Métadonnées pour le Ministre et le SEO
const pageTitle = "Label Qualité & Certification | Héritage Vodun";
const description =
  "Découvrez la Charte de Confiance Héritage Vodun. Le premier label garantissant l'authenticité, l'éthique et la sécurité du tourisme spirituel au Bénin.";
---

<BaseLayout titrePage={pageTitle} description={description}>
  <div class="min-h-screen bg-dark-bg pb-24 overflow-x-hidden">
    {/* --- HERO SECTION --- */}
    <section
      class="relative text-center pt-24 pb-20 px-6 bg-[radial-gradient(ellipse_at_top,#1a1a1a_0%,#050505_100%)] opacity-0 animate-fade-down"
    >
      <div class="flex justify-center items-end gap-4 md:gap-8 mb-16 flex-wrap">
        {/* LOGO 1: Héritage Vodun */}
        <div
          class="flex flex-col items-center w-24 md:w-32 group transition-transform duration-500 hover:-translate-y-2"
          title="Héritage Vodun - La Tradition"
        >
          <svg
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-auto drop-shadow-[0_10px_15px_rgba(212,175,55,0.2)]"
          >
            <defs>
              <linearGradient
                id="bronzeStem"
                x1="47"
                y1="0"
                x2="53"
                y2="0"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#8B4513"></stop>
                <stop offset="40%" stop-color="#E68A5C"></stop>
                <stop offset="60%" stop-color="#CD853F"></stop>
                <stop offset="100%" stop-color="#5D4037"></stop>
              </linearGradient>
              <linearGradient
                id="bronzeBase"
                x1="50"
                y1="85"
                x2="50"
                y2="92"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#D2691E"></stop>
                <stop offset="100%" stop-color="#8B4513"></stop>
              </linearGradient>
              <radialGradient id="beadGrad" cx="50%" cy="40%" r="50%">
                <stop offset="0%" stop-color="#F4A460"></stop>
                <stop offset="100%" stop-color="#8B4513"></stop>
              </radialGradient>
            </defs>
            <circle
              cx="50"
              cy="50"
              r="45"
              fill="none"
              stroke="#C06C3B"
              stroke-width="0.5"
              opacity="0.4"
              stroke-dasharray="2 2"></circle>
            <circle
              cx="50"
              cy="50"
              r="42"
              fill="none"
              stroke="#C06C3B"
              stroke-width="0.2"
              opacity="0.2"></circle>
            <path
              d="M42 85 L58 85 L54 92 L46 92 Z"
              fill="url(#bronzeBase)"
              stroke="#5D4037"
              stroke-width="0.5"></path>
            <rect x="47" y="38" width="6" height="47" fill="url(#bronzeStem)"
            ></rect>
            <rect x="47" y="38" width="6" height="2" fill="#000" opacity="0.3"
            ></rect>
            <circle
              cx="50"
              cy="25"
              r="12"
              fill="none"
              stroke="url(#bronzeStem)"
              stroke-width="4"></circle>
            <circle
              cx="50"
              cy="25"
              r="13.5"
              fill="none"
              stroke="#5D4037"
              stroke-width="0.2"
              opacity="0.8"></circle>
            <circle
              cx="50"
              cy="25"
              r="10.5"
              fill="none"
              stroke="#5D4037"
              stroke-width="0.2"
              opacity="0.8"></circle>
            <line
              x1="50"
              y1="13"
              x2="50"
              y2="37"
              stroke="#8B4513"
              stroke-width="0.8"></line>
            <line
              x1="38"
              y1="25"
              x2="62"
              y2="25"
              stroke="#8B4513"
              stroke-width="0.8"></line>
            <circle
              cx="50"
              cy="25"
              r="3.5"
              fill="url(#beadGrad)"
              stroke="#5D4037"
              stroke-width="0.2"></circle>
            <circle cx="50" cy="11" r="2.8" fill="url(#beadGrad)"></circle>
            <circle cx="50" cy="39" r="2.8" fill="url(#beadGrad)"></circle>
            <circle cx="36" cy="25" r="2.8" fill="url(#beadGrad)"></circle>
            <circle cx="64" cy="25" r="2.8" fill="url(#beadGrad)"></circle>
          </svg>
          <span
            class="font-serif text-[0.65rem] md:text-xs text-gold uppercase tracking-widest mt-4 font-bold opacity-80 group-hover:opacity-100 transition-opacity"
            >Héritage Vodun</span
          >
        </div>

        <div
          class="font-serif text-3xl md:text-5xl text-gold/30 mb-8 md:mb-10 px-2 select-none"
        >
          ×
        </div>

        {/* LOGO 2: Mindoguesito */}
        <div
          class="flex flex-col items-center w-24 md:w-32 group transition-transform duration-500 hover:-translate-y-2"
          title="Mindoguesito - Le Gardien"
        >
          <svg
            viewBox="0 0 320 320"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-auto drop-shadow-[0_10px_15px_rgba(212,175,55,0.2)]"
          >
            <defs>
              <linearGradient
                id="goldRoof"
                x1="160"
                y1="40"
                x2="160"
                y2="140"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#FFD700"></stop>
                <stop offset="50%" stop-color="#DAA520"></stop>
                <stop offset="100%" stop-color="#B8860B"></stop>
              </linearGradient>
              <linearGradient
                id="goldBase"
                x1="160"
                y1="260"
                x2="160"
                y2="285"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#DAA520"></stop>
                <stop offset="100%" stop-color="#8B4513"></stop>
              </linearGradient>
              <linearGradient id="woodPillar" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#4E342E"></stop>
                <stop offset="40%" stop-color="#8D6E63"></stop>
                <stop offset="60%" stop-color="#8D6E63"></stop>
                <stop offset="100%" stop-color="#3E2723"></stop>
              </linearGradient>
            </defs>
            <ellipse
              cx="160"
              cy="300"
              rx="130"
              ry="12"
              fill="#5d4037"
              opacity="0.3"
              filter="blur(8px)"></ellipse>
            <path
              d="M90 140V260"
              stroke="url(#woodPillar)"
              stroke-width="36"
              stroke-linecap="butt"></path>
            <path
              d="M90 140C100 160 80 180 90 200C100 220 80 240 90 260"
              stroke="#3E2723"
              stroke-width="4"
              fill="none"
              opacity="0.6"></path>
            <path
              d="M230 140V260"
              stroke="url(#woodPillar)"
              stroke-width="36"
              stroke-linecap="butt"></path>
            <path
              d="M230 140C220 160 240 180 230 200C220 220 240 240 230 260"
              stroke="#3E2723"
              stroke-width="4"
              fill="none"
              opacity="0.6"></path>
            <rect
              x="60"
              y="260"
              width="200"
              height="25"
              rx="4"
              fill="url(#goldBase)"
              stroke="#8B4513"
              stroke-width="2"></rect>
            <path
              d="M160 40L280 140H40L160 40Z"
              fill="url(#goldRoof)"
              stroke="#8B4513"
              stroke-width="3"></path>
          </svg>
          <span
            class="font-serif text-[0.65rem] md:text-xs text-gold uppercase tracking-widest mt-4 font-bold opacity-80 group-hover:opacity-100 transition-opacity"
            >Mindoguesito</span
          >
        </div>
      </div>

      <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 leading-tight">
        Le Label <span
          class="font-bold italic bg-gradient-to-r from-white to-gold bg-clip-text text-transparent"
          >Héritage Vodun</span
        >
      </h1>
      <div class="w-16 h-1 bg-gold mx-auto mb-8 rounded-full"></div>
      <p
        class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed font-sans"
      >
        Face à la "folklorisation" du sacré, nous établissons le premier
        standard de qualité pour le tourisme spirituel au Bénin. Une garantie
        pour le visiteur, une fierté pour le guide.
      </p>
    </section>

    {/* --- LES 3 PILIERS DU LABEL --- */}
    <section
      class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-3 gap-10"
    >
      <div
        class="bg-dark-surface p-10 rounded-xl border-t-4 border-gold shadow-xl hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-up"
        style="animation-delay: 200ms;"
      >
        <div class="text-5xl mb-6">📜</div>
        <h3 class="font-serif text-2xl text-white mb-4">
          1. Authenticité Historique
        </h3>
        <p class="text-gray-400 leading-relaxed text-sm md:text-base">
          Fini les légendes inventées pour les touristes. Chaque guide certifié
          par le Label s&apos;engage à transmettre l&apos;histoire réelle,
          vérifiée auprès des anciens et des historiens. Nous distinguons
          clairement le mythe de la réalité.
        </p>
      </div>

      <div
        class="bg-dark-surface p-10 rounded-xl border-t-4 border-gold shadow-xl hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-up"
        style="animation-delay: 400ms;"
      >
        <div class="text-5xl mb-6">🤝</div>
        <h3 class="font-serif text-2xl text-white mb-4">
          2. Éthique & Respect
        </h3>
        <p class="text-gray-400 leading-relaxed text-sm md:text-base">
          Le Vodun n&apos;est pas un spectacle de zoo. Nos partenaires
          s&apos;engagent à respecter la dignité des prêtres, le secret des
          couvents et l&apos;intégrité des visiteurs. Aucune extorsion, aucune
          mise en scène forcée.
        </p>
      </div>

      <div
        class="bg-dark-surface p-10 rounded-xl border-t-4 border-gold shadow-xl hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-up"
        style="animation-delay: 600ms;"
      >
        <div class="text-5xl mb-6">🛡️</div>
        <h3 class="font-serif text-2xl text-white mb-4">
          3. Sécurité & Confiance
        </h3>
        <p class="text-gray-400 leading-relaxed text-sm md:text-base">
          Un visiteur serein est un visiteur qui revient. Le Label garantit des
          parcours sécurisés, des tarifs transparents affichés à l&apos;avance
          et une identité numérique vérifiée pour chaque intervenant.
        </p>
      </div>
    </section>

    {/* --- MANIFESTE INSTITUTIONNEL --- */}
    <section
      class="max-w-4xl mx-auto px-6 mb-24 opacity-0 animate-fade-up"
      style="animation-delay: 800ms;"
    >
      <div
        class="bg-dark-surface/50 border border-gold/30 p-10 md:p-16 rounded-2xl relative overflow-hidden backdrop-blur-md"
      >
        {/* Lueur décorative */}
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-gold/10 rounded-full blur-[80px] pointer-events-none"
        >
        </div>

        <div class="relative z-10 text-center">
          <h2 class="font-serif text-3xl md:text-4xl text-white mb-8">
            Notre Engagement envers l&apos;État
          </h2>
          <div
            class="text-lg text-gray-300 leading-relaxed space-y-6 max-w-2xl mx-auto text-left md:text-center"
          >
            <p>
              <strong class="text-gold">Héritage Vodun</strong> ne se substitue pas
              aux institutions, il les accompagne. Notre mission est de numériser
              et structurer l&apos;offre touristique informelle pour en faire un levier
              de développement économique fiable.
            </p>
            <p>
              Nous construisons la base de données de confiance du Bénin Révélé.
            </p>
          </div>

          <div
            class="mt-12 pt-8 border-t border-gold/20 flex flex-col items-end max-w-2xl mx-auto text-right"
          >
            <span class="font-serif italic text-2xl text-gold mb-1"
              >La Direction Héritage Vodun</span
            >
            <span
              class="font-sans text-xs uppercase tracking-widest text-gray-500"
              >Ouidah, 2026</span
            >
          </div>
        </div>
      </div>
    </section>

    {/* --- CTA --- */}
    <section
      class="text-center px-6 opacity-0 animate-fade-up"
      style="animation-delay: 1000ms;"
    >
      <h2 class="font-serif text-3xl text-white mb-4">
        Vous êtes Guide ou Gardien de Temple ?
      </h2>
      <p class="font-sans text-gray-400 mb-8">
        Rejoignez le réseau d&apos;excellence.
      </p>
      <a
        href="/contact"
        class="inline-block bg-gold hover:bg-gold-hover text-black font-bold uppercase tracking-widest px-10 py-4 rounded-full transition-all duration-300 hover:shadow-[0_0_20px_rgba(212,175,55,0.4)] hover:-translate-y-1"
      >
        Rejoindre le label &rarr;
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-down {
    animation: fadeDown 1s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
  }
</style>
