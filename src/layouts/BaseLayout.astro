---
import Navigation from "../components/Navigation.astro";
import Logo from "../components/Logo.astro";
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";

// 1. Imports de Tailwind et des polices optimisées
import "../styles/global.css";
import "@fontsource/lato/300.css";
import "@fontsource/lato/400.css";
import "@fontsource/lato/700.css";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/600.css";
import "@fontsource/playfair-display/700.css";
import "@fontsource/playfair-display/400-italic.css";

// Props SEO enrichies
const {
  titrePage = "Héritage Vodun | Guide Spirituel, Fâ & Tourisme à Ouidah",
  description = "Plongez au cœur du Vodun au Bénin. Visites guidées à Ouidah, consultation du Fâ, et histoire de la Route des Esclaves. Une spiritualité authentique.",
  image = "/vodunsi.jpeg",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.url);
---

<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <ClientRouter />

    {
      noindex ? (
        <meta name="robots" content="noindex, follow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    <meta
      name="google-site-verification"
      content="vVcu2NVdsuB7Nu6DtS7nl5cZUPzeALF1fuGVk_Udf7g"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />

    <title>{titrePage}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={titrePage} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={titrePage} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "TravelAgency",
        "name": "Héritage Vodun",
        "url": "https://www.heritagevodun.com",
        "image": "https://www.heritagevodun.com/vodunsi.jpeg",
        "description": "Guide culturel et spirituel à Ouidah. Spécialiste du Vodun, du Fâ et de l'histoire du Bénin.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Ouidah",
          "addressRegion": "Atlantique",
          "addressCountry": "BJ"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 6.3667,
          "longitude": 2.0833
        },
        "telephone": "+2290169783365",
        "priceRange": "$$"
      }
    </script>
  </head>

  <body
    class="bg-dark-bg text-gray-300 font-sans antialiased flex flex-col min-h-screen selection:bg-gold/30 selection:text-white overflow-x-hidden"
  >
    {/* --- HEADER RESPONSIVE --- */}
    <header
      class="sticky top-0 z-50 bg-dark-bg/90 backdrop-blur-lg border-b border-white/10 transition-all duration-300"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center relative"
      >
        {/* LOGO */}
        <a
          href="/"
          class="flex items-center gap-3 sm:gap-4 group decoration-transparent z-[60]"
        >
          <Logo
            width="40"
            height="40"
            class="group-hover:scale-105 transition-transform duration-300 md:w-[45px] md:h-[45px]"
          />
          <span
            class="font-serif font-bold text-xl sm:text-2xl text-gray-100 uppercase tracking-wider group-hover:text-gold transition-colors"
          >
            Héritage Vodun
          </span>
        </a>

        {/* BOUTON MENU MOBILE */}
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-1.5 p-2 z-[60]"
          aria-label="Ouvrir le menu"
        >
          <span class="w-6 h-0.5 bg-gray-300 rounded-full transition-all"
          ></span>
          <span class="w-6 h-0.5 bg-gray-300 rounded-full transition-all"
          ></span>
          <span class="w-6 h-0.5 bg-gray-300 rounded-full transition-all"
          ></span>
        </button>

        {
          /* CONTENEUR DU MENU (Le composant Navigation.astro gère maintenant lui-même sa classe id="nav-menu") */
        }
        <Navigation />
      </div>
    </header>

    {/* --- CONTENU PRINCIPAL --- */}
    <main class="flex-1 w-full">
      <slot />
    </main>

    {/* --- FOOTER RESPONSIVE --- */}
    <footer
      class="bg-dark-surface border-t border-gold/30 pt-12 md:pt-16 pb-8 mt-16 text-gray-400 font-sans"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 mb-12"
      >
        <div>
          <h3 class="font-serif text-2xl text-white mb-4">Héritage Vodun</h3>
          <p class="text-sm leading-relaxed mb-6">
            Le portail de référence pour comprendre la spiritualité, l'histoire
            et les rites du Bénin. Une tradition vivante, expliquée avec respect
            et authenticité.
          </p>
        </div>

        <div>
          <h4 class="font-serif text-gold text-lg mb-4">Explorer</h4>
          <ul class="space-y-3 text-sm">
            <li>
              <a href="/" class="hover:text-gold transition-colors block py-1"
                >Accueil</a
              >
            </li>
            <li>
              <a
                href="/lexique"
                class="hover:text-gold transition-colors block py-1"
                >Le Lexique Sacré</a
              >
            </li>
            <li>
              <a
                href="/blog"
                class="hover:text-gold transition-colors block py-1"
                >Articles & Récits</a
              >
            </li>
            <li>
              <a
                href="/about"
                class="hover:text-gold transition-colors block py-1"
                >Notre Mission</a
              >
            </li>
          </ul>
        </div>

        <div>
          <h4 class="font-serif text-gold text-lg mb-4">Restez Connecté</h4>
          <p class="text-sm mb-4">
            Recevez chaque mois un récit ou une découverte sur la culture Vodun.
          </p>
          <form id="footer-newsletter-form" class="flex flex-col gap-2">
            <input
              type="hidden"
              name="access_key"
              value="90fd8cd4-08c6-427b-9e44-ae19d6c3f487"
            />
            <input type="hidden" name="subject" value="Nouvel abonné Footer" />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display: none;"
            />
            <div class="flex">
              <input
                type="email"
                name="email"
                placeholder="Votre email..."
                required
                class="flex-1 w-full bg-white/5 border border-white/10 text-white px-4 py-3 md:py-2 text-sm focus:outline-none focus:border-gold rounded-l-md"
              />
              <button
                type="submit"
                class="bg-gold hover:bg-gold-hover text-white px-5 py-3 md:py-2 font-bold transition-colors rounded-r-md"
                >→</button
              >
            </div>
            <p id="footer-result" class="text-xs font-bold mt-1 h-4"></p>
          </form>
        </div>

        <div>
          <h4 class="font-serif text-gold text-lg mb-4">Nous Trouver</h4>
          <div class="space-y-3 text-sm">
            <p class="flex items-center gap-2">
              <span>📍</span>
              <a
                href="https://www.google.com/maps/search/?api=1&query=Ouidah+Benin"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-gold transition-colors py-1 block"
                >Ouidah, Bénin</a
              >
            </p>
            <p class="flex items-center gap-2">
              <span>📧</span>
              <a
                href="mailto:contact@heritagevodun.com"
                class="hover:text-gold transition-colors py-1 block"
                >contact@heritagevodun.com</a
              >
            </p>
            <a
              href="/contact"
              class="inline-block mt-4 text-gold border-b border-gold/50 hover:border-gold pb-1 transition-all"
              >Nous écrire</a
            >
          </div>
        </div>
      </div>

      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-center md:text-left gap-4"
      >
        <p>
          © {new Date().getFullYear()} Héritage Vodun. Tous droits réservés.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="#" class="hover:text-white transition-colors"
            >Mentions Légales</a
          >
          <span class="opacity-30 hidden sm:inline">|</span>
          <a href="#" class="hover:text-white transition-colors"
            >Politique de Confidentialité</a
          >
        </div>
      </div>
    </footer>

    {/* --- ORACLE WIDGET RESPONSIVE --- */}
    <div
      id="oracle-widget"
      class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-[9999] font-sans"
    >
      <div
        id="oracle-window"
        class="hidden absolute bottom-20 right-0 w-[calc(100vw-2rem)] sm:w-[380px] h-[70vh] max-h-[600px] bg-white rounded-xl shadow-2xl overflow-hidden flex-col border border-black/10 origin-bottom-right transition-all duration-300"
      >
        <div
          class="bg-dark-surface p-4 flex justify-between items-center text-white shrink-0"
        >
          <div class="flex items-center gap-2">
            <span
              class="w-2 h-2 bg-green-500 rounded-full shadow-[0_0_5px_#2ecc71]"
            ></span>
            <span class="font-bold text-sm">Mindoguesito (En ligne)</span>
          </div>
          <div class="flex gap-3 items-center">
            <a
              href="https://www.mindoguesito.com"
              target="_blank"
              class="text-gray-400 hover:text-white text-lg transition-colors leading-none"
              title="Ouvrir en grand">↗</a
            >
            <button
              id="close-oracle"
              class="text-gray-400 hover:text-white text-3xl leading-none transition-colors pb-1"
              aria-label="Fermer">×</button
            >
          </div>
        </div>

        <div
          class="flex-1 bg-gray-100 relative flex items-center justify-center"
        >
          <div
            id="loader-oracle"
            class="absolute text-gray-500 text-sm z-10 flex items-center gap-2"
          >
            <div
              class="w-4 h-4 border-2 border-gold border-t-transparent rounded-full animate-[spin-slow_1s_linear_infinite]"
            >
            </div>
            Connexion spirituelle...
          </div>
          <iframe
            id="mindoguesito-frame"
            class="w-full h-full border-none block relative z-20 bg-transparent"
            title="Chat avec Mindoguesito"
            allow="microphone; clipboard-write;"></iframe>
        </div>
      </div>

      <button
        id="oracle-trigger"
        class="relative w-14 h-14 md:w-16 md:h-16 bg-gold hover:bg-gold-hover rounded-full shadow-[0_4px_20px_rgba(212,175,55,0.4)] flex items-center justify-center transition-all hover:scale-110 ml-auto"
        aria-label="Ouvrir l'Oracle"
      >
        <svg
          viewBox="0 0 100 100"
          class="w-7 h-7 md:w-9 md:h-9"
          fill="none"
          stroke="white"
          stroke-width="6"
        >
          <path d="M10 50 Q50 10 90 50 Q50 90 10 50 Z"></path>
          <circle cx="50" cy="50" r="12" fill="white" stroke="none"></circle>
        </svg>
        <div
          class="absolute inset-0 rounded-full border-2 border-gold animate-[pulse-glow_2s_infinite]"
        >
        </div>
      </button>
    </div>

    {/* --- SCRIPTS --- */}
    <script>
      if (window.location.hostname.includes("vercel.app")) {
        window.location.replace(
          "https://www.heritagevodun.com" + window.location.pathname,
        );
      }

      document.addEventListener("astro:page-load", () => {
        // GESTION CORRIGÉE DU MENU MOBILE
        const menuBtn = document.getElementById("menu-toggle");
        // On cible spécifiquement l'ID nav-menu généré par Navigation.astro
        const navMenu = document.getElementById("nav-menu");

        if (menuBtn && navMenu) {
          // Retire les anciens écouteurs (crucial avec View Transitions)
          const newMenuBtn = menuBtn.cloneNode(true) as HTMLElement;
          menuBtn.parentNode?.replaceChild(newMenuBtn, menuBtn);

          newMenuBtn.addEventListener("click", () => {
            // Logique de bascule stricte
            if (navMenu.classList.contains("hidden")) {
              navMenu.classList.remove("hidden");
              navMenu.classList.add("flex");
            } else {
              navMenu.classList.add("hidden");
              navMenu.classList.remove("flex");
            }
          });
        }

        // GESTION DE LA NEWSLETTER FOOTER
        const footerForm = document.getElementById(
          "footer-newsletter-form",
        ) as HTMLFormElement | null;
        const footerResult = document.getElementById("footer-result");
        const footerBtn = footerForm
          ? (footerForm.querySelector(
              "button[type='submit']",
            ) as HTMLButtonElement)
          : null;

        if (footerForm && footerResult && footerBtn) {
          footerForm.addEventListener("submit", function (e) {
            e.preventDefault();
            const formData = new FormData(footerForm);
            const object = Object.fromEntries(formData);
            const json = JSON.stringify(object);

            footerResult.innerHTML = "...";
            footerResult.style.color = "#d4af37";
            footerBtn.disabled = true;
            footerBtn.style.opacity = "0.7";

            fetch("https://api.web3forms.com/submit", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
              },
              body: json,
            })
              .then(async (response) => {
                if (response.status == 200) {
                  footerResult.innerHTML = "✨ Merci ! Inscription validée.";
                  footerResult.style.color = "#4CAF50";
                  footerForm.reset();
                  setTimeout(() => {
                    footerResult.innerHTML = "";
                    footerBtn.disabled = false;
                    footerBtn.style.opacity = "1";
                  }, 3000);
                } else {
                  footerResult.innerHTML = "Une erreur est survenue.";
                  footerResult.style.color = "red";
                  footerBtn.disabled = false;
                  footerBtn.style.opacity = "1";
                }
              })
              .catch((error) => {
                console.error(error);
                footerResult.innerHTML = "Erreur de connexion.";
                footerResult.style.color = "red";
                footerBtn.disabled = false;
                footerBtn.style.opacity = "1";
              });
          });
        }

        // GESTION DE L'ORACLE
        const oracleTrigger = document.getElementById("oracle-trigger");
        const oracleWindow = document.getElementById("oracle-window");
        const closeOracle = document.getElementById("close-oracle");
        const iframe = document.getElementById(
          "mindoguesito-frame",
        ) as HTMLIFrameElement;
        const loader = document.getElementById("loader-oracle");

        function getContextUrl() {
          const path = window.location.pathname;
          let context = "heritage_widget";
          if (path.includes("fa")) context = "fa";
          else if (path.includes("zangbeto")) context = "zangbeto";
          else if (path.includes("ouidah")) context = "ouidah";
          else if (path === "/" || path === "") context = "heritage_home";
          return `https://www.mindoguesito.com/?context=${context}`;
        }

        function openOracleWidget() {
          if (!oracleWindow) return;
          oracleWindow.classList.remove("hidden");
          oracleWindow.classList.add("flex");
          if (iframe && (!iframe.src || iframe.src === "about:blank")) {
            iframe.src = getContextUrl();
            iframe.onload = () => {
              if (loader) loader.style.display = "none";
            };
          }
        }

        function closeOracleWidget() {
          if (oracleWindow) {
            oracleWindow.classList.add("hidden");
            oracleWindow.classList.remove("flex");
          }
        }

        if (oracleTrigger)
          oracleTrigger.addEventListener("click", openOracleWidget);
        if (closeOracle)
          closeOracle.addEventListener("click", closeOracleWidget);

        const remoteTriggers = document.querySelectorAll(".open-oracle");
        remoteTriggers.forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.preventDefault();
            openOracleWidget();
            if (window.innerWidth < 768)
              window.scrollTo({
                top: document.body.scrollHeight,
                behavior: "smooth",
              });
          });
        });
      });
    </script>
    <SpeedInsights />
  </body>
</html>
