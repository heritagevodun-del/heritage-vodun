---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import GlobalLightbox from "../components/GlobalLightbox.astro";
import ViewCounter from "../components/ViewCounter.astro";
import type { ImageMetadata } from "astro";
import { Image, getImage } from "astro:assets";

// Typage pour rassurer TypeScript
const { frontmatter } = Astro.props as { frontmatter: any };

// Formatage de la date en français
const date = new Date(frontmatter.pubDate || frontmatter.date || Date.now());
const formattedDate = new Intl.DateTimeFormat("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(date);

const isProd = import.meta.env.PROD;

// --- AUTOMATISATION WEBP & ASSETS ---
// 1. On liste dynamiquement toutes les images du dossier src/assets/
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,webp}",
);

// 2. On recompose le chemin d'après le frontmatter (ex: "/mon-image.jpg" -> "/src/assets/mon-image.jpg")
const imagePath = frontmatter.image ? `/src/assets${frontmatter.image}` : null;
let optimizedOgImage = frontmatter.image; // Fallback de sécurité

// 3. Si l'image existe bien dans src/assets, on génère son URL WebP pour le SEO
if (imagePath && images[imagePath]) {
  const imgMeta = await images[imagePath]();
  const ogImage = await getImage({
    src: imgMeta.default,
    format: "webp",
    width: 1200,
  });
  optimizedOgImage = ogImage.src;
}
---

<BaseLayout
  titrePage={`${frontmatter.titrePage || frontmatter.title} | Héritage Vodun`}
  description={frontmatter.description}
  image={optimizedOgImage}
>
  <article data-pagefind-body class="max-w-4xl mx-auto mt-4 mb-24 px-4">
    <div class="mb-6 border-b border-white/5 pb-2" data-pagefind-ignore>
      <Breadcrumbs
        customPaths={[
          {
            label: frontmatter.categorie || "Articles",
            href: frontmatter.categorie
              ? `/categories/${frontmatter.categorie}`
              : "/blog",
          },
          { label: frontmatter.title, href: Astro.url.pathname },
        ]}
      />
    </div>

    <header class="text-center mb-12 mt-8">
      {
        frontmatter.categorie && (
          <a
            href={`/categories/${frontmatter.categorie}`}
            class="inline-block px-4 py-1.5 rounded-full bg-gold/10 text-gold border border-gold/30 text-sm font-bold uppercase tracking-widest hover:bg-gold hover:text-dark-bg transition-all duration-300 hover:-translate-y-0.5 mb-6"
            data-pagefind-ignore
          >
            {frontmatter.categorie}
          </a>
        )
      }

      <div
        class="text-vodun-cendre font-sans text-sm uppercase tracking-widest mb-6"
      >
        <time datetime={date.toISOString()}>{formattedDate}</time> | Par {
          frontmatter.author || "Héritage Vodun"
        }
      </div>

      <h1
        class="font-serif text-4xl md:text-5xl lg:text-6xl text-vodun-kaolin font-bold leading-tight mb-4"
      >
        {frontmatter.titrePage || frontmatter.title}
      </h1>

      <div class="flex justify-center items-center mb-8" data-pagefind-ignore>
        {
          isProd ? (
            <ViewCounter
              slug={
                frontmatter.slug ||
                Astro.url.pathname.replace(/\/$/, "").split("/").pop()
              }
            />
          ) : (
            <span class="text-vodun-cendre text-sm">
              👀 Mode Dev (Compteur désactivé)
            </span>
          )
        }
      </div>
    </header>

    {/* --- IMAGE DE COUVERTURE AUTOMATISÉE --- */}
    <div class="mb-12">
      {
        imagePath && images[imagePath] && !frontmatter.hide_top_image && (
          <div class="w-full h-[40vh] md:h-[60vh] rounded-2xl overflow-hidden border border-white/10 shadow-2xl relative">
            <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent z-10 pointer-events-none" />

            <Image
              src={images[imagePath]()}
              alt={frontmatter.title}
              format="webp"
              quality={90}
              class="zoomable-image w-full h-full object-cover transform hover:scale-105 transition-transform duration-700 cursor-zoom-in relative z-20"
              data-pagefind-meta="image[src], image_alt[alt]"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )
      }
    </div>

    {/* --- CONTENU DE L'ARTICLE --- */}
    <div
      class="prose prose-invert prose-lg md:prose-xl mx-auto prose-headings:font-serif prose-headings:font-bold prose-headings:text-gold prose-p:font-sans prose-p:text-vodun-kaolin prose-p:leading-relaxed prose-a:text-gold hover:prose-a:text-gold-hover prose-strong:text-white prose-blockquote:border-gold prose-blockquote:bg-gold/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:rounded-r-lg prose-blockquote:font-serif prose-blockquote:italic"
    >
      <slot />
    </div>

    {/* --- APPEL À L'ACTION --- */}
    <div
      class="mt-20 mb-8 p-8 bg-gradient-to-br from-dark-surface to-dark-bg border border-gold/20 rounded-2xl flex flex-col items-center text-center shadow-2xl relative overflow-hidden group"
      data-pagefind-ignore
    >
      <div class="absolute top-0 left-0 w-full h-1 bg-gold"></div>
      <div class="text-4xl mb-4 animate-[bounce_3s_infinite]">✨</div>
      <h3 class="font-serif text-2xl text-vodun-kaolin mb-2">
        Une question sur ce sujet ?
      </h3>
      <p class="text-vodun-cendre mb-8 max-w-lg">
        Ne restez pas avec des doutes. Demandez des précisions à <strong
          class="text-gold">Mindoguesito</strong
        >, notre gardien numérique.
      </p>
      <button
        class="open-oracle bg-gold hover:bg-gold-hover text-dark-bg px-8 py-3 rounded-full font-bold transition-all duration-300 shadow-[0_4px_15px_rgba(212,175,55,0.3)] hover:shadow-[0_6px_20px_rgba(212,175,55,0.5)] hover:-translate-y-1"
      >
        Interroger l&apos;Esprit &rarr;
      </button>
    </div>

    {/* --- TAGS --- */}
    {
      frontmatter.tags && (
        <div class="mt-12 pt-8 border-t border-white/10" data-pagefind-ignore>
          <h3 class="font-serif text-xl text-vodun-kaolin mb-6 text-center">
            Sujets abordés dans cet article :
          </h3>
          <div class="flex flex-wrap gap-3 justify-center">
            {frontmatter.tags.map((tag: string) => (
              <a
                href={`/tags/${tag}`}
                class="px-4 py-1.5 rounded-full bg-dark-surface border border-white/10 text-vodun-cendre text-sm hover:text-dark-bg hover:bg-gold hover:border-gold transition-all duration-300 font-sans tracking-wide"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </article>

  <GlobalLightbox />

  <script>
    document.addEventListener("astro:page-load", () => {
      const modal = document.getElementById(
        "global-lightbox",
      ) as HTMLDialogElement;
      const modalImg = document.getElementById(
        "lightbox-img",
      ) as HTMLImageElement;

      if (!modal || !modalImg) return;

      const articleImages = document.querySelectorAll(
        ".zoomable-image, .prose img",
      );

      articleImages.forEach((img: any) => {
        if (!img.classList.contains("zoomable-image")) {
          img.setAttribute("loading", "lazy");
          img.setAttribute("decoding", "async");
        }

        img.style.cursor = "zoom-in";
        img.classList.add("hover:opacity-90", "transition-opacity");

        img.onclick = (e: Event) => {
          e.preventDefault();
          e.stopPropagation();

          modalImg.src = img.currentSrc || img.src;
          modalImg.alt = img.alt || "Image de l'article agrandie";

          modal.showModal();
        };
      });
    });
  </script>
</BaseLayout>
